@page
@model MyApp.Areas.Admin.Pages.Announcements.IndexModel
@{
  ViewData["title"] = await T.GetAsync("Announcement.PageTitle");
}

@section VendorStyles {
  <link rel="stylesheet" href="~/vendor/libs/sweetalert2/sweetalert2.dist.css" />
}

@{
  var lblToggleTitle   = await T.GetAsync("ToggleStatusTitle");
  var lblToggleConfirm = await T.GetAsync("ToggleStatusConfirm");
  var lblToggleYes     = await T.GetAsync("ToggleStatusYes");
  var lblCancel        = await T.GetAsync("Cancel");
  var lblToggleFailed  = await T.GetAsync("ToggleFailed");
  var lblToggleError   = await T.GetAsync("ToggleError");
}

<div class="d-flex justify-content-between align-items-center py-3 mb-4">
  <div>
    <h4 class="mb-0">@await T.GetAsync("Announcement.PageTitle")</h4>
    <small class="text-muted">@await T.GetAsync("Announcement.PageSubtitle")</small>
  </div>
  <div class="d-flex gap-2">
    <a asp-area="Admin" asp-page="/Announcements/List" class="btn btn-outline-secondary">
      <i class="ri ri-list-check me-1"></i>@await T.GetAsync("Announcement.ListTitle")
    </a>
    <a asp-area="Admin" asp-page="/Announcements/Create" class="btn btn-primary">
      <i class="ri ri-add-line me-1"></i>@await T.GetAsync("Add")
    </a>
  </div>
</div>

<div class="card">
  <div class="card-body">
    <div class="table-responsive">
      <table id="tblAnnouncements" class="table table-hover align-middle">
        <thead>
          <tr>
            <th>#</th>
            <th>@await T.GetAsync("Announcement.Title")</th>
            <th>@await T.GetAsync("Announcement.Audience")</th>
            <th>@await T.GetAsync("Announcement.DateRange")</th>
            <th>@await T.GetAsync("Status")</th>
            <th>@await T.GetAsync("Actions")</th>
          </tr>
        </thead>
        <tbody>
          @{ var rowNum = 1; }
          @foreach (var ann in Model.Items)
          {
            var title = ann.Translations.FirstOrDefault()?.Title ?? ann.AnnouncementCode;
            var audienceKey = ann.Audience switch
            {
              "admin"    => "Announcement.AudienceAdmin",
              "customer" => "Announcement.AudienceCustomer",
              _          => "Announcement.AudienceAll"
            };
            var badgeClass = ann.Status == StatusConstants.Active ? "bg-success" : "bg-secondary";
            var statusLabel = ann.Status switch
            {
              "active"   => await T.GetAsync("status.active"),
              "inactive" => await T.GetAsync("status.inactive"),
              _          => ann.Status
            };
            <tr>
              <td>@rowNum</td>
              <td><strong>@title</strong><br /><small class="text-muted">@ann.AnnouncementCode</small></td>
              <td><span class="badge bg-label-primary">@await T.GetAsync(audienceKey)</span></td>
              <td>
                <small>@ann.StartAt.ToUserLocalTime(Model.UserTimezone, AppConstants.DateTimeFormat)</small><br />
                <small class="text-muted">→ @ann.EndAt.ToUserLocalTime(Model.UserTimezone, AppConstants.DateTimeFormat)</small>
              </td>
              <td><span class="badge @badgeClass">@statusLabel</span></td>
              <td>
                <div class="dropdown">
                  <button type="button" class="btn btn-sm btn-outline-secondary dropdown-toggle"
                          data-bs-toggle="dropdown" aria-expanded="false">
                    <i class="ri ri-more-2-fill"></i>
                  </button>
                  <ul class="dropdown-menu dropdown-menu-end">
                    <li>
                      <a class="dropdown-item" asp-area="Admin" asp-page="/Announcements/Edit"
                         asp-route-announcementCode="@ann.AnnouncementCode">
                        <i class="ri ri-edit-line me-1"></i>@await T.GetAsync("Edit")
                      </a>
                    </li>
                    <li>
                      <button class="dropdown-item" type="button"
                              onclick="toggleStatus('@ann.AnnouncementCode')">
                        <i class="ri ri-toggle-line me-1"></i>@await T.GetAsync("ToggleStatus")
                      </button>
                    </li>
                    <li>
                      <button class="dropdown-item text-danger" type="button"
                              onclick="confirmDelete('@ann.AnnouncementCode',
                                                    '@Html.Raw(Model.MsgDeleteConfirmTitle)',
                                                    '@Html.Raw(Model.MsgDeleteConfirmText)',
                                                    '@Html.Raw(Model.MsgDeleteConfirmBtn)',
                                                    '@Html.Raw(Model.MsgCancelBtn)')">
                        <i class="ri ri-delete-bin-line me-1"></i>@Model.LabelDelete
                      </button>
                    </li>
                  </ul>
                </div>
              </td>
            </tr>
            rowNum++;
          }
        </tbody>
      </table>
    </div>
  </div>
</div>

<form id="formAjax" method="post">
  @Html.AntiForgeryToken()
</form>

@section VendorScripts {
  <script src="~/vendor/libs/sweetalert2/sweetalert2.dist.js"></script>
}

@section PageScripts {
<script>
  var msgToggleTitle   = '@lblToggleTitle';
  var msgToggleConfirm = '@lblToggleConfirm';
  var msgToggleYes     = '@lblToggleYes';
  var msgCancel        = '@lblCancel';
  var msgToggleFailed  = '@lblToggleFailed';
  var msgToggleError   = '@lblToggleError';
  var msgDeleteSuccess = '@Html.Raw(Model.MsgDeleteSuccess)';
  var msgDeleteError   = '@Html.Raw(Model.MsgDeleteError)';

  function toggleStatus(code) {
    Swal.fire({
      title: msgToggleTitle, text: msgToggleConfirm, icon: 'warning',
      showCancelButton: true, confirmButtonText: msgToggleYes, cancelButtonText: msgCancel
    }).then(function (result) {
      if (result.isConfirmed) {
        $.ajax({
          url: '?handler=ToggleStatus', type: 'POST',
          data: {
            announcementCode: code,
            __RequestVerificationToken: $('#formAjax input[name="__RequestVerificationToken"]').val()
          },
          success: function (data) {
            if (data.success) { location.reload(); }
            else { Swal.fire({ icon: 'error', text: msgToggleFailed }); }
          },
          error: function () { Swal.fire({ icon: 'error', text: msgToggleError }); }
        });
      }
    });
  }

  async function confirmDelete(code, title, text, confirmBtn, cancelBtn) {
    const result = await Swal.fire({
      icon: 'warning', title, text,
      showCancelButton: true, confirmButtonText: confirmBtn, cancelButtonText: cancelBtn,
      confirmButtonColor: '#dc3545'
    });
    if (!result.isConfirmed) return;
    $.post('?handler=SoftDelete', {
      announcementCode: code,
      __RequestVerificationToken: $('#formAjax input[name="__RequestVerificationToken"]').val()
    }, function (data) {
      if (data.success) {
        Swal.fire({ icon: 'success', title: msgDeleteSuccess, timer: 1500, showConfirmButton: false })
          .then(function () { location.reload(); });
      } else {
        Swal.fire({ icon: 'error', text: data.message || msgDeleteError });
      }
    }).fail(function () {
      Swal.fire({ icon: 'error', text: msgDeleteError });
    });
  }

  $(document).ready(function () {
    initDataTable('#tblAnnouncements', 5);
  });

  document.addEventListener("DOMContentLoaded", function () {
    var messageType = '@Model.AlertMessageType';
    if (messageType !== '') {
      Swal.fire({
        icon: messageType,
        title: @Html.Raw(Json.Serialize(Model.AlertMessageTitle)),
        text: @Html.Raw(Json.Serialize(Model.AlertMessageContent))
      });
    }
  });
</script>
}
