@page
@model MyApp.Areas.Admin.Pages.ProductSectionTypes.IndexModel
@{
  ViewData["title"] = await T.GetAsync("ProductSectionType.PageTitle");
}

@section VendorStyles {
  <link rel="stylesheet" href="~/vendor/libs/sweetalert2/sweetalert2.dist.css" />
}

@{
  var lblToggleTitle   = await T.GetAsync("ToggleStatusTitle");
  var lblToggleConfirm = await T.GetAsync("ToggleStatusConfirm");
  var lblToggleYes     = await T.GetAsync("ToggleStatusYes");
  var lblCancel        = await T.GetAsync("Cancel");
  var lblToggleFailed  = await T.GetAsync("ToggleFailed");
  var lblToggleError   = await T.GetAsync("ToggleError");
}

<div class="d-flex justify-content-between align-items-center py-3 mb-4">
  <h4 class="mb-0">@await T.GetAsync("ProductSectionType.PageTitle")</h4>
  <a asp-area="Admin" asp-page="/ProductSectionTypes/Create" class="btn btn-primary">
    <i class="ri ri-add-line me-1"></i> @await T.GetAsync("ProductSectionType.AddNew")
  </a>
</div>

<div class="card">
  <div class="card-header">
    <h5 class="mb-0">@await T.GetAsync("ProductSectionType.ListTitle")</h5>
  </div>
  <div class="card-body">
    <div class="table-responsive">
      <table id="tblProductSectionTypes" class="table table-hover align-middle">
        <thead>
          <tr>
            <th>#</th>
            <th>@await T.GetAsync("ProductSectionType.SectionCode")</th>
            <th>@await T.GetAsync("ProductSectionType.SectionName")</th>
            <th>@await T.GetAsync("ProductSectionType.SortOrder")</th>
            <th>@await T.GetAsync("Status")</th>
            <th>@await T.GetAsync("Actions")</th>
          </tr>
        </thead>
        <tbody>
          @{ var rowNum = 1; }
          @foreach (var stype in Model.Items)
          {
            <tr>
              <td>@rowNum</td>
              <td><strong>@stype.SectionCode</strong></td>
              <td>@(stype.Translations.FirstOrDefault()?.SectionName ?? stype.SectionCode)</td>
              <td>@stype.SortOrder</td>
              <td>
                @{
                  var badgeClass = stype.Status switch
                  {
                    "active"   => "bg-success",
                    "inactive" => "bg-secondary",
                    _          => "bg-warning"
                  };
                  var statusLabel = stype.Status switch
                  {
                    "active"   => await T.GetAsync("status.active"),
                    "inactive" => await T.GetAsync("status.inactive"),
                    _          => stype.Status
                  };
                }
                <span class="badge @badgeClass">@statusLabel</span>
              </td>
              <td>
                <div class="dropdown">
                  <button type="button" class="btn btn-sm btn-outline-secondary dropdown-toggle"
                          data-bs-toggle="dropdown" aria-expanded="false">
                    <i class="ri ri-more-2-fill"></i>
                  </button>
                  <ul class="dropdown-menu dropdown-menu-end">
                    <li>
                      <a class="dropdown-item" asp-area="Admin" asp-page="/ProductSectionTypes/Edit"
                         asp-route-sectionCode="@stype.SectionCode">
                        <i class="ri ri-edit-line me-1"></i>@await T.GetAsync("Edit")
                      </a>
                    </li>
                    <li>
                      <button class="dropdown-item" type="button"
                              onclick="toggleStatus('@stype.SectionCode')">
                        <i class="ri ri-toggle-line me-1"></i>@await T.GetAsync("ToggleStatus")
                      </button>
                    </li>
                    <li>
                      <button class="dropdown-item text-danger" type="button"
                              onclick="confirmDelete('@stype.SectionCode',
                                                    '@Html.Raw(Model.MsgDeleteConfirmTitle)',
                                                    '@Html.Raw(Model.MsgDeleteConfirmText)',
                                                    '@Html.Raw(Model.MsgDeleteConfirmBtn)',
                                                    '@Html.Raw(Model.MsgCancelBtn)')">
                        <i class="ri ri-delete-bin-line me-1"></i>@Model.LabelDelete
                      </button>
                    </li>
                  </ul>
                </div>
              </td>
            </tr>
            rowNum++;
          }
        </tbody>
      </table>
    </div>
  </div>
</div>

@* Hidden form supplies antiforgery token for AJAX calls *@
<form id="formAjax" method="post">
  @Html.AntiForgeryToken()
</form>

@section VendorScripts {
  <script src="~/vendor/libs/sweetalert2/sweetalert2.dist.js"></script>
}

@section PageScripts {
<script>
  var msgToggleTitle   = '@lblToggleTitle';
  var msgToggleConfirm = '@lblToggleConfirm';
  var msgToggleYes     = '@lblToggleYes';
  var msgCancel        = '@lblCancel';
  var msgToggleFailed  = '@lblToggleFailed';
  var msgToggleError   = '@lblToggleError';
  var msgDeleteSuccess = '@Html.Raw(Model.MsgDeleteSuccess)';
  var msgDeleteError   = '@Html.Raw(Model.MsgDeleteError)';

  function toggleStatus(sectionCode) {
    Swal.fire({
      title: msgToggleTitle,
      text: msgToggleConfirm,
      icon: 'warning',
      showCancelButton: true,
      confirmButtonText: msgToggleYes,
      cancelButtonText: msgCancel
    }).then(function (result) {
      if (result.isConfirmed) {
        $.ajax({
          url: '?handler=ToggleStatus',
          type: 'POST',
          data: {
            sectionCode: sectionCode,
            __RequestVerificationToken: $('#formAjax input[name="__RequestVerificationToken"]').val()
          },
          success: function (data) {
            if (data.success) {
              location.reload();
            } else {
              Swal.fire({ icon: 'error', text: msgToggleFailed });
            }
          },
          error: function () {
            Swal.fire({ icon: 'error', text: msgToggleError });
          }
        });
      }
    });
  }

  async function confirmDelete(sectionCode, title, text, confirmBtn, cancelBtn) {
    const result = await Swal.fire({
      icon: 'warning', title: title, text: text,
      showCancelButton: true, confirmButtonText: confirmBtn, cancelButtonText: cancelBtn,
      confirmButtonColor: '#dc3545'
    });
    if (!result.isConfirmed) return;
    $.post('?handler=SoftDelete&sectionCode=' + encodeURIComponent(sectionCode), {
      __RequestVerificationToken: $('#formAjax input[name="__RequestVerificationToken"]').val()
    }, function (data) {
      if (data.success) {
        Swal.fire({ icon: 'success', title: msgDeleteSuccess, timer: 1500, showConfirmButton: false })
          .then(function () { location.reload(); });
      } else {
        Swal.fire({ icon: 'error', text: data.message || msgDeleteError });
      }
    }).fail(function () {
      Swal.fire({ icon: 'error', text: msgDeleteError });
    });
  }

  $(document).ready(function () {
    initDataTable('#tblProductSectionTypes', 5);
  });

  document.addEventListener("DOMContentLoaded", function () {
    var messageType = '@Model.AlertMessageType';
    if (messageType !== '') {
      Swal.fire({
        icon: messageType,
        title: @Html.Raw(Json.Serialize(Model.AlertMessageTitle)),
        text: @Html.Raw(Json.Serialize(Model.AlertMessageContent))
      });
    }
  });
</script>
}
