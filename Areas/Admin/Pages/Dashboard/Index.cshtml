@page
@model MyApp.Areas.Admin.Pages.Dashboard.IndexModel
@using MyApp.Constants.MRMR
@{
    Layout = "~/Areas/Admin/Pages/Layouts/_MasterLayout.cshtml";
    ViewData["Title"] = "MRMR 2026 Dashboard";
    ViewData["ActiveMenu"] = "MRMR_DASHBOARD";
}

@* ── Overview stat cards ── *@
<div class="row">

    @* Total Registrations *@
    <div class="col s12 m6 l4">
        <div class="card blue darken-3 white-text">
            <div class="card-content">
                <div class="row valign-wrapper mb-0">
                    <div class="col s8">
                        <p class="mb-0" style="font-size:0.85rem; opacity:0.85;">Total Registrations</p>
                        <h4 class="mb-0 mt-1 fw-bold">@Model.Stats.TotalRegistrations</h4>
                        <p class="mb-0" style="font-size:0.8rem; opacity:0.75;">
                            +@Model.Stats.ThisMonthReg this month
                        </p>
                    </div>
                    <div class="col s4 right-align">
                        <i class="ri ri-team-line" style="font-size:3rem; opacity:0.6;"></i>
                    </div>
                </div>
            </div>
            <div class="card-action" style="border-top: 1px solid rgba(255,255,255,0.2); padding: 8px 24px;">
                <a href="/Admin/MRMR/Applications" class="white-text" style="font-size:0.8rem;">
                    View All <i class="ri ri-arrow-right-line"></i>
                </a>
            </div>
        </div>
    </div>

    @* Pending Payment Verifications *@
    <div class="col s12 m6 l4">
        <div class="card orange darken-2 white-text">
            <div class="card-content">
                <div class="row valign-wrapper mb-0">
                    <div class="col s8">
                        <p class="mb-0" style="font-size:0.85rem; opacity:0.85;">Pending Payment Verification</p>
                        <h4 class="mb-0 mt-1 fw-bold">@Model.Stats.PendingPayments</h4>
                        <p class="mb-0" style="font-size:0.8rem; opacity:0.75;">Awaiting review</p>
                    </div>
                    <div class="col s4 right-align">
                        <i class="ri ri-bank-card-line" style="font-size:3rem; opacity:0.6;"></i>
                    </div>
                </div>
            </div>
            <div class="card-action" style="border-top: 1px solid rgba(255,255,255,0.2); padding: 8px 24px;">
                <a href="/Admin/MRMR/Payments" class="white-text" style="font-size:0.8rem;">
                    Verify Now <i class="ri ri-arrow-right-line"></i>
                </a>
            </div>
        </div>
    </div>

    @* Submitted Applications *@
    <div class="col s12 m6 l4">
        <div class="card teal darken-1 white-text">
            <div class="card-content">
                <div class="row valign-wrapper mb-0">
                    <div class="col s8">
                        <p class="mb-0" style="font-size:0.85rem; opacity:0.85;">Submitted Applications</p>
                        <h4 class="mb-0 mt-1 fw-bold">@Model.Stats.SubmittedApps</h4>
                        <p class="mb-0" style="font-size:0.8rem; opacity:0.75;">Final submissions received</p>
                    </div>
                    <div class="col s4 right-align">
                        <i class="ri ri-checkbox-circle-line" style="font-size:3rem; opacity:0.6;"></i>
                    </div>
                </div>
            </div>
            <div class="card-action" style="border-top: 1px solid rgba(255,255,255,0.2); padding: 8px 24px;">
                <a href="/Admin/MRMR/Applications?status=SubmissionCompleted" class="white-text" style="font-size:0.8rem;">
                    View <i class="ri ri-arrow-right-line"></i>
                </a>
            </div>
        </div>
    </div>

    @* Under Evaluation *@
    <div class="col s12 m6 l4">
        <div class="card purple darken-1 white-text">
            <div class="card-content">
                <div class="row valign-wrapper mb-0">
                    <div class="col s8">
                        <p class="mb-0" style="font-size:0.85rem; opacity:0.85;">Under Evaluation</p>
                        <h4 class="mb-0 mt-1 fw-bold">@Model.Stats.UnderEvaluation</h4>
                        <p class="mb-0" style="font-size:0.8rem; opacity:0.75;">Being scored by judges</p>
                    </div>
                    <div class="col s4 right-align">
                        <i class="ri ri-search-eye-line" style="font-size:3rem; opacity:0.6;"></i>
                    </div>
                </div>
            </div>
            <div class="card-action" style="border-top: 1px solid rgba(255,255,255,0.2); padding: 8px 24px;">
                <a href="/Admin/MRMR/Applications?status=UnderEvaluation" class="white-text" style="font-size:0.8rem;">
                    View <i class="ri ri-arrow-right-line"></i>
                </a>
            </div>
        </div>
    </div>

    @* Pending Document Verification *@
    <div class="col s12 m6 l4">
        <div class="card blue-grey darken-1 white-text">
            <div class="card-content">
                <div class="row valign-wrapper mb-0">
                    <div class="col s8">
                        <p class="mb-0" style="font-size:0.85rem; opacity:0.85;">Pending Document Verification</p>
                        <h4 class="mb-0 mt-1 fw-bold">@Model.Stats.PendingDocuments</h4>
                        <p class="mb-0" style="font-size:0.8rem; opacity:0.75;">Documents awaiting review</p>
                    </div>
                    <div class="col s4 right-align">
                        <i class="ri ri-folder-unknow-line" style="font-size:3rem; opacity:0.6;"></i>
                    </div>
                </div>
            </div>
            <div class="card-action" style="border-top: 1px solid rgba(255,255,255,0.2); padding: 8px 24px;">
                <a href="/Admin/MRMR/Documents" class="white-text" style="font-size:0.8rem;">
                    Review <i class="ri ri-arrow-right-line"></i>
                </a>
            </div>
        </div>
    </div>

</div>

@* ── Two-column activity feed ── *@
<div class="row">

    @* Recent Registrations *@
    <div class="col s12 l6">
        <div class="card">
            <div class="card-content">
                <span class="card-title" style="font-size:1rem;">
                    <i class="ri ri-user-add-line me-1 blue-text"></i>Recent Registrations
                </span>
                @if (!Model.RecentRegistrations.Any())
                {
                    <p class="grey-text center-align">No registrations yet.</p>
                }
                else
                {
                    <table class="striped" style="font-size:0.85rem;">
                        <thead>
                            <tr>
                                <th>Application ID</th>
                                <th>Name</th>
                                <th>Type</th>
                                <th>Status</th>
                                <th>Date</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var app in Model.RecentRegistrations)
                            {
                                <tr>
                                    <td>
                                        <a href="/Admin/MRMR/Applications/Detail?applicationId=@app.ApplicationId"
                                           class="blue-text">@app.ApplicationId</a>
                                    </td>
                                    <td>@app.Registrant?.FullName</td>
                                    <td>
                                        <span class="badge @(app.ApplicationType == "Corporate" ? "blue" : "teal") white-text" style="float:none; font-size:0.75rem;">
                                            @app.ApplicationType
                                        </span>
                                    </td>
                                    <td>
                                        <span class="badge @StatusBadge(app.Status)" style="float:none; font-size:0.75rem;">
                                            @app.Status
                                        </span>
                                    </td>
                                    <td>@app.CreatedAt.ToString("dd MMM")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
            <div class="card-action">
                <a href="/Admin/MRMR/Applications" class="blue-text">View All Applications →</a>
            </div>
        </div>
    </div>

    @* Payments Awaiting Verification *@
    <div class="col s12 l6">
        <div class="card">
            <div class="card-content">
                <span class="card-title" style="font-size:1rem;">
                    <i class="ri ri-bank-card-line me-1 orange-text"></i>Payments Awaiting Verification
                </span>
                @if (!Model.PendingPayments.Any())
                {
                    <p class="grey-text center-align">No pending payments.</p>
                }
                else
                {
                    <table class="striped" style="font-size:0.85rem;">
                        <thead>
                            <tr>
                                <th>Invoice No</th>
                                <th>Applicant</th>
                                <th>Type</th>
                                <th>Amount (RM)</th>
                                <th>Date</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var pay in Model.PendingPayments)
                            {
                                <tr>
                                    <td>
                                        <a href="/Admin/MRMR/Payments/Detail?paymentId=@pay.Id"
                                           class="orange-text">@pay.InvoiceNo</a>
                                    </td>
                                    <td>@pay.Application?.Registrant?.FullName</td>
                                    <td>
                                        <span class="badge grey white-text" style="float:none; font-size:0.75rem;">
                                            @pay.PaymentType
                                        </span>
                                    </td>
                                    <td class="right-align">@pay.Amount.ToString("N2")</td>
                                    <td>@pay.CreatedAt.ToString("dd MMM")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
            <div class="card-action">
                <a href="/Admin/MRMR/Payments" class="orange-text">View Payment Queue →</a>
            </div>
        </div>
    </div>

</div>

@functions {
    private static string StatusBadge(string status) => status switch
    {
        nameof(ApplicationStatus.Registered)            => "blue lighten-3 blue-text text-darken-2",
        nameof(ApplicationStatus.NominationFeePending)  => "amber lighten-3 amber-text text-darken-3",
        nameof(ApplicationStatus.NominationFeeVerified) => "light-blue lighten-3 light-blue-text text-darken-2",
        nameof(ApplicationStatus.AwardFeePending)       => "amber lighten-3 amber-text text-darken-3",
        nameof(ApplicationStatus.AwardFeeVerified)      => "green lighten-3 green-text",
        nameof(ApplicationStatus.SubmissionInProgress)  => "green lighten-3 green-text",
        nameof(ApplicationStatus.SubmissionCompleted)   => "teal lighten-3 teal-text",
        nameof(ApplicationStatus.UnderEvaluation)       => "purple lighten-3 purple-text",
        nameof(ApplicationStatus.Approved)              => "green white-text",
        nameof(ApplicationStatus.Rejected)              => "red lighten-3 red-text",
        _ => "grey lighten-3 grey-text"
    };
}
