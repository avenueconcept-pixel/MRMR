@page
@model MyApp.Areas.Admin.Pages.Dashboard.IndexModel
@using System.Text.Json
@{
  ViewData["title"]       = await T.GetAsync("Dashboard.Title");
  var lblOrders           = await T.GetAsync("Orders");
  var lblNewCustomers     = await T.GetAsync("Dashboard.NewCustomers");
  var lblThisYear         = await T.GetAsync("Dashboard.ThisYear");
  var lblLastYear         = await T.GetAsync("Dashboard.LastYear");
  var lblSalesRM          = await T.GetAsync("Dashboard.SalesRM");
  var lblAxisRevenue      = await T.GetAsync("RevenueRM");
  var lblSuffixOrders     = await T.GetAsync("Dashboard.SuffixOrders");
  var lblSuffixCustomers  = await T.GetAsync("Dashboard.SuffixCustomers");
  var lblOnline           = await T.GetAsync("Dashboard.Online");
  var lblOffline          = await T.GetAsync("Dashboard.Offline");
}

  var lblOrders          = await T.GetAsync("Orders");
  var lblNewCustomers    = await T.GetAsync("Dashboard.NewCustomers");
  var lblThisYear        = await T.GetAsync("Dashboard.ThisYear");
  var lblLastYear        = await T.GetAsync("Dashboard.LastYear");
  var lblSalesRM         = await T.GetAsync("Dashboard.SalesRM");
  var lblAxisRevenue     = await T.GetAsync("RevenueRM");
  var lblSuffixOrders    = await T.GetAsync("Dashboard.SuffixOrders");
  var lblSuffixCustomers = await T.GetAsync("Dashboard.SuffixCustomers");
}

@section VendorStyles {
  <link rel="stylesheet" href="~/vendor/libs/apex-charts/apex-charts.dist.css" />
  <link rel="stylesheet" href="~/vendor/libs/datatables-bs5/datatables.bootstrap5.dist.css" />
}

@{
  string Trend(double pct) => pct >= 0 ? "text-success" : "text-danger";
  string Arrow(double pct) => pct >= 0 ? "&#8593;" : "&#8595;";
}

<h4 class="py-3 mb-4">@await T.GetAsync("Dashboard.PageTitle") <span class="text-muted fs-6 fw-normal">— @await T.GetAsync("Dashboard.WelcomeBack"), @Model.AdminName</span></h4>

@* ── Stat Cards ──────────────────────────────────────────── *@
<div class="row g-4 mb-4">

  <div class="col-sm-6 col-xl-3">
    <div class="card h-100">
      <div class="card-body">
        <p class="text-muted small text-uppercase fw-semibold mb-1">@await T.GetAsync("Dashboard.TotalCustomers")</p>
        <h3 class="mb-1">@Model.TotalCustomers.ToString("N0")</h3>
        <small class="@Trend(Model.CustomerGrowth)">@Html.Raw(Arrow(Model.CustomerGrowth)) @Math.Abs(Model.CustomerGrowth)%</small>
        <small class="text-muted"> @await T.GetAsync("Dashboard.VsLastMonth")</small>
        <div class="mt-2">
          <span class="badge bg-primary bg-opacity-10 text-primary">@Model.NewCustomersThisMonth @await T.GetAsync("Dashboard.NewThisMonth")</span>
        </div>
      </div>
    </div>
  </div>

  <div class="col-sm-6 col-xl-3">
    <div class="card h-100">
      <div class="card-body">
        <p class="text-muted small text-uppercase fw-semibold mb-1">@await T.GetAsync("Dashboard.TotalOrders")</p>
        <h3 class="mb-1">@Model.TotalOrders.ToString("N0")</h3>
        <small class="@Trend(Model.OrderGrowth)">@Html.Raw(Arrow(Model.OrderGrowth)) @Math.Abs(Model.OrderGrowth)%</small>
        <small class="text-muted"> @await T.GetAsync("Dashboard.VsLastMonth")</small>
        <div class="mt-2">
          <span class="badge bg-warning bg-opacity-10 text-warning">@Model.NewOrdersThisMonth @await T.GetAsync("Dashboard.NewThisMonth")</span>
        </div>
      </div>
    </div>
  </div>

  <div class="col-sm-6 col-xl-3">
    <div class="card h-100">
      <div class="card-body">
        <p class="text-muted small text-uppercase fw-semibold mb-1">@await T.GetAsync("Dashboard.RevenueThisMonth")</p>
        <h3 class="mb-1">RM @Model.RevenueThisMonth.ToString("N2")</h3>
        <small class="@Trend(Model.RevenueGrowth)">@Html.Raw(Arrow(Model.RevenueGrowth)) @Math.Abs(Model.RevenueGrowth)%</small>
        <small class="text-muted"> @await T.GetAsync("Dashboard.VsLastMonth")</small>
        <div class="mt-2">
          <span class="badge bg-success bg-opacity-10 text-success">@await T.GetAsync("Dashboard.MonthlyTarget")</span>
        </div>
      </div>
    </div>
  </div>

  <div class="col-sm-6 col-xl-3">
    <div class="card h-100">
      <div class="card-body">
        <p class="text-muted small text-uppercase fw-semibold mb-1">@await T.GetAsync("Dashboard.TotalRevenue")</p>
        <h3 class="mb-1">RM @Model.TotalRevenue.ToString("N2")</h3>
        <small class="@Trend(Model.TotalRevenueGrowth)">@Html.Raw(Arrow(Model.TotalRevenueGrowth)) @Math.Abs(Model.TotalRevenueGrowth)%</small>
        <small class="text-muted"> @await T.GetAsync("Dashboard.VsLastYear")</small>
        <div class="mt-2">
          <span class="badge bg-info bg-opacity-10 text-info">@await T.GetAsync("Dashboard.AllTime")</span>
        </div>
      </div>
    </div>
  </div>

</div>

@* ── Sales Analysis + Customer Growth ───────────────────── *@
<div class="row g-4 mb-4">

  <div class="col-xl-8">
    <div class="card h-100">
      <div class="card-header">
        <h5 class="mb-0">@await T.GetAsync("Dashboard.SalesAnalysis")</h5>
        <small class="text-muted">@await T.GetAsync("Dashboard.SalesAnalysisSubtitle")</small>
      </div>
      <div class="card-body">
        <div id="chartSales"></div>
      </div>
    </div>
  </div>

  <div class="col-xl-4">
    <div class="card h-100">
      <div class="card-header">
        <h5 class="mb-0">@await T.GetAsync("Dashboard.CustomerGrowth")</h5>
        <small class="text-muted">@await T.GetAsync("Dashboard.CustomerGrowthSubtitle")</small>
      </div>
      <div class="card-body">
        <div id="chartCustomers"></div>
      </div>
    </div>
  </div>

</div>

@* ── Sales Comparison ────────────────────────────────────── *@
<div class="row g-4 mb-4">
  <div class="col-12">
    <div class="card">
      <div class="card-header">
        <h5 class="mb-0">@await T.GetAsync("Dashboard.SalesComparison")</h5>
        <small class="text-muted">@await T.GetAsync("Dashboard.SalesComparisonSubtitle")</small>
      </div>
      <div class="card-body">
        <div id="chartComparison"></div>
      </div>
    </div>
  </div>
</div>

@* ── Top Products + Top Referrals ───────────────────────── *@
<div class="row g-4 mb-4">

  <div class="col-xl-6">
    <div class="card h-100">
      <div class="card-header">
        <h5 class="mb-0">@await T.GetAsync("Dashboard.TopProductSales")</h5>
        <small class="text-muted">@await T.GetAsync("Dashboard.TopProductSalesSubtitle")</small>
      </div>
      <div class="card-body">
        <div class="table-responsive">
          <table id="tblProducts" class="table table-hover">
            <thead>
              <tr>
                <th>@await T.GetAsync("No")</th>
                <th>@await T.GetAsync("Product")</th>
                <th>@await T.GetAsync("Category")</th>
                <th>@await T.GetAsync("UnitsSold")</th>
                <th>@await T.GetAsync("RevenueRM")</th>
              </tr>
            </thead>
            <tbody>
              @{ int pRank = 1; }
              @foreach (var p in Model.TopProducts)
              {
                <tr>
                  <td>@pRank++</td>
                  <td>@p.ProductName</td>
                  <td><span class="badge bg-secondary bg-opacity-10 text-secondary">@p.Category</span></td>
                  <td>@p.UnitsSold.ToString("N0")</td>
                  <td>@p.Revenue.ToString("N2")</td>
                </tr>
              }
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>

  <div class="col-xl-6">
    <div class="card h-100">
      <div class="card-header">
        <h5 class="mb-0">@await T.GetAsync("Dashboard.TopReferralCustomers")</h5>
        <small class="text-muted">@await T.GetAsync("Dashboard.TopReferralCustomersSubtitle")</small>
      </div>
      <div class="card-body">
        <div class="table-responsive">
          <table id="tblReferrals" class="table table-hover">
            <thead>
              <tr>
                <th>@await T.GetAsync("No")</th>
                <th>@await T.GetAsync("Customer")</th>
                <th>@await T.GetAsync("Email")</th>
                <th>@await T.GetAsync("Referrals")</th>
                <th>@await T.GetAsync("RevenueRM")</th>
              </tr>
            </thead>
            <tbody>
              @{ int rRank = 1; }
              @foreach (var r in Model.TopReferrals)
              {
                <tr>
                  <td>@rRank++</td>
                  <td>@r.CustomerName</td>
                  <td>@r.Email</td>
                  <td><span class="badge bg-primary">@r.ReferralCount</span></td>
                  <td>@r.Revenue.ToString("N2")</td>
                </tr>
              }
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>

</div>

@* ── Sales by Country ────────────────────────────────────── *@
<div class="row g-4 mb-4">

  <div class="col-xl-7">
    <div class="card h-100">
      <div class="card-header">
        <h5 class="mb-0">@await T.GetAsync("Dashboard.SalesByCountry")</h5>
        <small class="text-muted">@await T.GetAsync("Dashboard.SalesByCountrySubtitle")</small>
      </div>
      <div class="card-body">
        <div id="chartSalesByCountry"></div>
      </div>
    </div>
  </div>

  <div class="col-xl-5">
    <div class="card h-100">
      <div class="card-header">
        <h5 class="mb-0">@await T.GetAsync("Dashboard.CountryBreakdown")</h5>
        <small class="text-muted">@await T.GetAsync("Dashboard.CountryBreakdownSubtitle")</small>
      </div>
      <div class="card-body">
        <div class="table-responsive">
          <table class="table table-hover align-middle">
            <thead>
              <tr>
                <th>@await T.GetAsync("Country")</th>
                <th class="text-end">@await T.GetAsync("Dashboard.TotalSalesRM")</th>
                <th class="text-end">@await T.GetAsync("Orders")</th>
              </tr>
            </thead>
            <tbody>
              @foreach (var s in Model.SalesByCountry)
              {
                <tr>
                  <td>@s.CountryName</td>
                  <td class="text-end">@s.TotalSales.ToString("N2")</td>
                  <td class="text-end">@s.OrderCount.ToString("N0")</td>
                </tr>
              }
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>

</div>

@* ── Customer Distribution by Country ───────────────────── *@
<div class="row g-4 mb-4">

  <div class="col-xl-5">
    <div class="card h-100">
      <div class="card-header">
        <h5 class="mb-0">@await T.GetAsync("Dashboard.CustomerDistributionByCountry")</h5>
        <small class="text-muted">@await T.GetAsync("Dashboard.CustomerDistributionSubtitle")</small>
      </div>
      <div class="card-body d-flex align-items-center justify-content-center">
        <div id="chartCountryDonut" style="width:100%;max-width:380px;"></div>
      </div>
    </div>
  </div>

  <div class="col-xl-7">
    <div class="card h-100">
      <div class="card-header">
        <h5 class="mb-0">@await T.GetAsync("Dashboard.CustomersByCountry")</h5>
        <small class="text-muted">@await T.GetAsync("Dashboard.CustomersByCountrySubtitle")</small>
      </div>
      <div class="card-body">
        <div class="table-responsive">
          <table class="table table-hover align-middle">
            <thead>
              <tr>
                <th>@await T.GetAsync("Country")</th>
                <th class="text-end">@await T.GetAsync("Dashboard.TotalCustomers")</th>
                <th class="text-end">@await T.GetAsync("Dashboard.ColNewThisMonth")</th>
                <th class="text-end">@await T.GetAsync("Dashboard.PercentageOfTotal")</th>
              </tr>
            </thead>
            <tbody>
              @foreach (var c in Model.CustomersByCountry)
              {
                <tr>
                  <td>@c.CountryName</td>
                  <td class="text-end">@c.TotalCustomers.ToString("N0")</td>
                  <td class="text-end">@c.NewThisMonth.ToString("N0")</td>
                  <td class="text-end">@c.PercentageOfTotal.ToString("F1")%</td>
                </tr>
              }
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>

</div>

@* ── Summary Cards (real DB data) ───────────────────────── *@
<div class="row g-4 mb-4">
  <div class="col-sm-6 col-xl-3">
    <div class="card h-100">
      <div class="card-body d-flex align-items-center gap-3">
        <div class="avatar avatar-lg flex-shrink-0">
          <span class="avatar-initial rounded bg-label-primary"><i class="ri ri-user-settings-line ri-24px"></i></span>
        </div>
        <div>
          <h4 class="mb-0">@Model.AdminUserCount</h4>
          <small class="text-muted">@await T.GetAsync("Dashboard.AdminUsers")</small>
        </div>
      </div>
    </div>
  </div>
  <div class="col-sm-6 col-xl-3">
    <div class="card h-100">
      <div class="card-body d-flex align-items-center gap-3">
        <div class="avatar avatar-lg flex-shrink-0">
          <span class="avatar-initial rounded bg-label-success"><i class="ri ri-shield-user-line ri-24px"></i></span>
        </div>
        <div>
          <h4 class="mb-0">@Model.RoleCount</h4>
          <small class="text-muted">@await T.GetAsync("Dashboard.Roles")</small>
        </div>
      </div>
    </div>
  </div>
  <div class="col-sm-6 col-xl-3">
    <div class="card h-100">
      <div class="card-body d-flex align-items-center gap-3">
        <div class="avatar avatar-lg flex-shrink-0">
          <span class="avatar-initial rounded bg-label-warning"><i class="ri ri-flag-line ri-24px"></i></span>
        </div>
        <div>
          <h4 class="mb-0">@Model.CountryCount</h4>
          <small class="text-muted">@await T.GetAsync("Dashboard.Countries")</small>
        </div>
      </div>
    </div>
  </div>
  <div class="col-sm-6 col-xl-3">
    <div class="card h-100">
      <div class="card-body d-flex align-items-center gap-3">
        <div class="avatar avatar-lg flex-shrink-0">
          <span class="avatar-initial rounded bg-label-info"><i class="ri ri-translate-2 ri-24px"></i></span>
        </div>
        <div>
          <h4 class="mb-0">@Model.LanguageCount</h4>
          <small class="text-muted">@await T.GetAsync("Dashboard.Languages")</small>
        </div>
      </div>
    </div>
  </div>
</div>

@* ── Active Users by System ──────────────────────────────── *@
<div class="row g-4 mb-4">
  <div class="col-xl-6">
    <div class="card h-100">
      <div class="card-header">
        <h5 class="mb-0">@await T.GetAsync("Dashboard.ActiveUsers")</h5>
      </div>
      <div class="card-body">
        <div class="row g-3">
          @foreach (var kv in Model.ActiveCountBySystem)
          {
            <div class="col-sm-6">
              <div class="d-flex align-items-center gap-2 p-3 border rounded">
                <span class="badge bg-success rounded-pill fs-5">@kv.Value</span>
                <span class="text-capitalize">@kv.Key</span>
              </div>
            </div>
          }
          @if (!Model.ActiveCountBySystem.Any())
          {
            <div class="col-12 text-muted">—</div>
          }
        </div>
      </div>
    </div>
  </div>
  <div class="col-xl-6">
    <div class="card h-100">
      <div class="card-header">
        <h5 class="mb-0">@await T.GetAsync("Dashboard.TotalActive")</h5>
      </div>
      <div class="card-body d-flex align-items-center justify-content-center">
        <div class="text-center">
          <h1 id="totalActiveCount" class="display-4 fw-bold text-success mb-0">@Model.ActiveSessions.Count</h1>
          <p class="text-muted mb-0">@await T.GetAsync("Dashboard.ActiveUsers")</p>
        </div>
      </div>
    </div>
  </div>
</div>

@* ── Who Is Online ───────────────────────────────────────── *@
<div class="row g-4 mb-4">
  <div class="col-12">
    <div class="card">
      <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0">@await T.GetAsync("Dashboard.WhoIsOnline")</h5>
        <small class="text-muted">@await T.GetAsync("Dashboard.AutoRefresh60s")</small>
      </div>
      <div class="card-body">
        <div class="table-responsive">
          <table id="tblOnline" class="table table-hover align-middle">
            <thead>
              <tr>
                <th>#</th>
                <th>@await T.GetAsync("Dashboard.System")</th>
                <th>@await T.GetAsync("Username")</th>
                <th>@await T.GetAsync("FullName")</th>
                <th>@await T.GetAsync("Dashboard.CurrentPage")</th>
                <th>@await T.GetAsync("Dashboard.Browser")</th>
                <th>@await T.GetAsync("Dashboard.Os")</th>
                <th>@await T.GetAsync("Dashboard.Device")</th>
                <th>@await T.GetAsync("Dashboard.IpAddress")</th>
                <th>@await T.GetAsync("Dashboard.LastActive")</th>
              </tr>
            </thead>
            <tbody id="tbodyOnline">
              @{ int onlineRank = 1; }
              @foreach (var s in Model.ActiveSessions.Take(50))
              {
                <tr>
                  <td>@onlineRank++</td>
                  <td><span class="badge bg-label-primary text-capitalize">@s.SystemType</span></td>
                  <td>@s.Username</td>
                  <td>@(s.FullName ?? "-")</td>
                  <td><code>@(s.CurrentPage ?? "-")</code></td>
                  <td>@(s.Browser ?? "-")</td>
                  <td>@(s.Os ?? "-")</td>
                  <td>
                    @{
                      var deviceIcon = s.DeviceType == AppConstants.DeviceTypeMobile ? "ri-smartphone-line"
                                     : s.DeviceType == AppConstants.DeviceTypeTablet  ? "ri-tablet-line"
                                     : "ri-computer-line";
                    }
                    <i class="ri @deviceIcon" title="@s.DeviceType"></i>
                  </td>
                  <td>@(s.IpAddress ?? "-")</td>
                  <td>@s.LastActiveAt.ToUserLocalTime(Model.UserTimezone, AppConstants.DateTimeFormat)</td>
                </tr>
              }
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>

@* ── Recent Logins ───────────────────────────────────────── *@
<div class="row g-4 mb-4">
  <div class="col-12">
    <div class="card">
      <div class="card-header">
        <h5 class="mb-0">@await T.GetAsync("Dashboard.RecentLogins")</h5>
      </div>
      <div class="card-body">
        <div class="table-responsive">
          <table id="tblRecentLogins" class="table table-hover align-middle">
            <thead>
              <tr>
                <th>#</th>
                <th>@await T.GetAsync("Dashboard.System")</th>
                <th>@await T.GetAsync("Username")</th>
                <th>@await T.GetAsync("FullName")</th>
                <th>@await T.GetAsync("Dashboard.IpAddress")</th>
                <th>@await T.GetAsync("Dashboard.Browser")</th>
                <th>@await T.GetAsync("Dashboard.Os")</th>
                <th>@await T.GetAsync("Dashboard.Device")</th>
                <th>@await T.GetAsync("Dashboard.LoginAt")</th>
                <th>@await T.GetAsync("Dashboard.LogoutAt")</th>
                <th>@await T.GetAsync("Status")</th>
              </tr>
            </thead>
            <tbody>
              @{ int loginRank = 1; }
              @foreach (var s in Model.RecentLogins)
              {
                <tr>
                  <td>@loginRank++</td>
                  <td><span class="badge bg-label-primary text-capitalize">@s.SystemType</span></td>
                  <td>@s.Username</td>
                  <td>@(s.FullName ?? "-")</td>
                  <td>@(s.IpAddress ?? "-")</td>
                  <td>@(s.Browser ?? "-")</td>
                  <td>@(s.Os ?? "-")</td>
                  <td>
                    @{
                      var devIcon = s.DeviceType == AppConstants.DeviceTypeMobile ? "ri-smartphone-line"
                                  : s.DeviceType == AppConstants.DeviceTypeTablet  ? "ri-tablet-line"
                                  : "ri-computer-line";
                    }
                    <i class="ri @devIcon" title="@s.DeviceType"></i>
                  </td>
                  <td>@s.LoginAt.ToUserLocalTime(Model.UserTimezone, AppConstants.DateTimeFormat)</td>
                  <td>@(s.LogoutAt.HasValue ? s.LogoutAt.Value.ToUserLocalTime(Model.UserTimezone, AppConstants.DateTimeFormat) : "-")</td>
                  <td>
                    @if (s.IsActive)
                    {
                      <span class="badge bg-success">@lblOnline</span>
                    }
                    else
                    {
                      <span class="badge bg-secondary">@lblOffline</span>
                    }
                  </td>
                </tr>
              }
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>

@section VendorScripts {
  <script src="~/vendor/libs/apex-charts/apexcharts.dist.js"></script>
  <script src="~/vendor/libs/datatables-bs5/datatables-bootstrap5.dist.js"></script>
}

@section PageScripts {
<script>
  const monthLabels    = @Html.Raw(JsonSerializer.Serialize(Model.MonthLabels));
  const ordersData     = @Html.Raw(JsonSerializer.Serialize(Model.OrdersData));
  const customersData  = @Html.Raw(JsonSerializer.Serialize(Model.NewCustomersData));
  const cmpLabels      = @Html.Raw(JsonSerializer.Serialize(Model.ComparisonLabels));
  const thisYearData   = @Html.Raw(JsonSerializer.Serialize(Model.ThisYearRevenue));
  const lastYearData   = @Html.Raw(JsonSerializer.Serialize(Model.LastYearRevenue));

  // Sales Analysis — bar chart
  new ApexCharts(document.querySelector('#chartSales'), {
    series: [{ name: '@lblOrders', data: ordersData }],
    chart: { type: 'bar', height: 280, toolbar: { show: false } },
    colors: ['#7367f0'],
    plotOptions: { bar: { borderRadius: 4, columnWidth: '50%' } },
    dataLabels: { enabled: false },
    xaxis: { categories: monthLabels },
    yaxis: { title: { text: '@lblOrders' } },
    grid: { borderColor: '#f1f1f1' },
    tooltip: { y: { formatter: v => v.toLocaleString() + '@lblSuffixOrders' } }
  }).render();

  // Customer Growth — area chart
  new ApexCharts(document.querySelector('#chartCustomers'), {
    series: [{ name: '@lblNewCustomers', data: customersData }],
    chart: { type: 'area', height: 280, toolbar: { show: false } },
    colors: ['#28c76f'],
    fill: { type: 'gradient', gradient: { shadeIntensity: 1, opacityFrom: 0.4, opacityTo: 0.05 } },
    dataLabels: { enabled: false },
    stroke: { curve: 'smooth', width: 2 },
    xaxis: { categories: monthLabels },
    yaxis: { title: { text: '@lblNewCustomers' } },
    grid: { borderColor: '#f1f1f1' },
    tooltip: { y: { formatter: v => v + '@lblSuffixCustomers' } }
  }).render();

  // Sales Comparison — multi-line chart
  new ApexCharts(document.querySelector('#chartComparison'), {
    series: [
      { name: '@lblThisYear', data: thisYearData },
      { name: '@lblLastYear', data: lastYearData }
    ],
    chart: { type: 'line', height: 320, toolbar: { show: false } },
    colors: ['#7367f0', '#ff9f43'],
    stroke: { curve: 'smooth', width: [2, 2], dashArray: [0, 5] },
    dataLabels: { enabled: false },
    xaxis: { categories: cmpLabels },
    yaxis: { title: { text: '@lblAxisRevenue' }, labels: { formatter: v => 'RM ' + v.toLocaleString() } },
    legend: { position: 'top' },
    grid: { borderColor: '#f1f1f1' },
    tooltip: { y: { formatter: v => 'RM ' + v.toLocaleString() } }
  }).render();

  // DataTables
  $('#tblProducts').DataTable({ pageLength: 5, lengthChange: false, searching: false, info: false });
  $('#tblReferrals').DataTable({ pageLength: 5, lengthChange: false, searching: false, info: false });
  initDataTable('#tblRecentLogins', 10);

  // Sales by Country — horizontal bar chart
  const countryBarLabels = @Html.Raw(Model.ChartCountryLabels);
  const countryBarSales  = @Html.Raw(Model.ChartCountrySales);

  new ApexCharts(document.querySelector('#chartSalesByCountry'), {
    series: [{ name: '@lblSalesRM', data: countryBarSales }],
    chart: { type: 'bar', height: 300, toolbar: { show: false } },
    plotOptions: { bar: { horizontal: true, borderRadius: 4, barHeight: '55%' } },
    colors: ['rgba(0,150,136,0.75)'],
    dataLabels: { enabled: false },
    xaxis: { categories: countryBarLabels, labels: { formatter: v => 'RM ' + Number(v).toLocaleString() } },
    tooltip: { y: { formatter: v => 'RM ' + Number(v).toLocaleString('en-MY', { minimumFractionDigits: 2 }) } },
    grid: { borderColor: '#f1f1f1' }
  }).render();

  // Auto-refresh Who Is Online every 60 seconds
  setInterval(function () {
    $.get('?handler=GetActiveSessions', function (data) {
      if (!data.success) return;
      document.getElementById('totalActiveCount').textContent = data.totalActive;
      var tbody = document.getElementById('tbodyOnline');
      tbody.innerHTML = '';
      var rank = 1;
      data.sessions.forEach(function (s) {
        var devIcon = s.deviceType === '@AppConstants.DeviceTypeMobile' ? 'ri-smartphone-line'
                    : s.deviceType === '@AppConstants.DeviceTypeTablet'  ? 'ri-tablet-line'
                    : 'ri-computer-line';
        tbody.insertAdjacentHTML('beforeend',
          '<tr>' +
          '<td>' + rank++ + '</td>' +
          '<td><span class="badge bg-label-primary text-capitalize">' + s.systemType + '</span></td>' +
          '<td>' + s.username + '</td>' +
          '<td>' + (s.fullName || '-') + '</td>' +
          '<td><code>' + (s.currentPage || '-') + '</code></td>' +
          '<td>' + (s.browser || '-') + '</td>' +
          '<td>' + (s.os || '-') + '</td>' +
          '<td><i class="ri ' + devIcon + '" title="' + (s.deviceType || '') + '"></i></td>' +
          '<td>' + (s.ipAddress || '-') + '</td>' +
          '<td>' + s.lastActiveAt + '</td>' +
          '</tr>');
      });
    });
  }, 60000);

  // Customer Distribution by Country — donut chart
  const countryLabels = @Html.Raw(Model.ChartCustomerLabels);
  const countryCounts = @Html.Raw(Model.ChartCustomerCounts);
  const countryColors = ['#009688', '#2196F3', '#FF9800', '#9C27B0', '#F44336', '#4CAF50'];

  new ApexCharts(document.querySelector('#chartCountryDonut'), {
    series: countryCounts,
    labels: countryLabels,
    chart: { type: 'donut', height: 320 },
    colors: countryColors,
    legend: { position: 'bottom' },
    dataLabels: { enabled: true, formatter: (val) => val.toFixed(1) + '%' },
    tooltip: { y: { formatter: (v) => v.toLocaleString() + '@lblSuffixCustomers' } },
    plotOptions: { pie: { donut: { size: '65%' } } }
  }).render();
</script>
}
