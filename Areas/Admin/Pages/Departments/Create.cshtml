@page
@model MyApp.Areas.Admin.Pages.Departments.CreateModel
@{
  ViewData["title"] = await T.GetAsync("Dept.AddTitle");
}

@section VendorStyles {
  <link rel="stylesheet" href="~/vendor/libs/sweetalert2/sweetalert2.dist.css" />
}

<div class="d-flex justify-content-between align-items-center py-3 mb-4">
  <h4 class="mb-0">@await T.GetAsync("Dept.AddTitle")</h4>
  <a asp-area="Admin" asp-page="/Departments/Index" class="btn btn-outline-secondary">
    <i class="ri ri-arrow-left-line me-1"></i> @await T.GetAsync("BackToList")
  </a>
</div>

<div class="card">
  <div class="card-body">
    <form method="post" asp-page-handler="Create">

      <div class="row g-4">
        <div class="col-md-6">
          <label class="form-label" for="txtDeptName">
            @await T.GetAsync("DeptName") <span class="text-danger">*</span>
          </label>
          <input type="text" id="txtDeptName" name="txtDeptName" class="form-control"
                 maxlength="150" value="@Model.txtDeptName"
                 placeholder="@await T.GetAsync("DeptName.Placeholder")" />
        </div>
        <div class="col-md-6">
          <label class="form-label" for="ddlStatus">@await T.GetAsync("Status")</label>
          <select asp-for="ddlStatus" id="ddlStatus" class="form-select" asp-items="@Model.StatusOptions"></select>
        </div>
      </div>

      <div class="mt-4 d-flex gap-2">
        <button type="submit" class="btn btn-primary">@await T.GetAsync("Save")</button>
        <a asp-area="Admin" asp-page="/Departments/Index" class="btn btn-outline-secondary">@await T.GetAsync("Cancel")</a>
      </div>

    </form>
  </div>
</div>

@section VendorScripts {
  <script src="~/vendor/libs/sweetalert2/sweetalert2.dist.js"></script>
}

@section PageScripts {
<script>
  document.addEventListener("DOMContentLoaded", function () {
    var messageType = '@Model.AlertMessageType';
    if (messageType !== '') {
      Swal.fire({
        icon: messageType,
        title: @Html.Raw(Json.Serialize(Model.AlertMessageTitle)),
        text: @Html.Raw(Json.Serialize(Model.AlertMessageContent))
      });
    }
  });
</script>
}
