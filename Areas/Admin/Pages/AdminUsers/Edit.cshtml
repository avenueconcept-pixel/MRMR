@page "{id:int}"
@model MyApp.Areas.Admin.Pages.AdminUsers.EditModel
@{
  ViewData["title"] = await T.GetAsync("AdminUser.EditTitle");
}

@section VendorStyles {
  <link rel="stylesheet" href="~/vendor/libs/sweetalert2/sweetalert2.dist.css" />
}

<div class="d-flex justify-content-between align-items-center py-3 mb-4">
  <h4 class="mb-0">@await T.GetAsync("AdminUser.EditTitle") — <span class="text-muted">@Model.Username</span></h4>
  <a asp-area="Admin" asp-page="/AdminUsers/Index" class="btn btn-outline-secondary">
    <i class="ri ri-arrow-left-line me-1"></i> @await T.GetAsync("BackToList")
  </a>
</div>

<div class="card">
  <div class="card-body">
    <form method="post" asp-page-handler="Update" enctype="multipart/form-data">

      @* Profile Image *@
      <div class="mb-4">
        <label class="form-label">@await T.GetAsync("ProfileImage")</label>
        <div class="d-flex align-items-center gap-3">
          @{
            var currentAvatarSrc = string.IsNullOrEmpty(Model.ProfileImage)
                ? "/images/default-avatar.png"
                : $"/uploads/admin-profiles/{Model.ProfileImage}";
          }
          <img id="imgPreview" src="@currentAvatarSrc"
               style="width:80px;height:80px;object-fit:cover;border-radius:50%;border:2px solid #dee2e6;" />
          <div>
            <div class="form-text mb-1">@await T.GetAsync("AdminUser.CurrentImage")</div>
            <input type="file" id="fileProfileImage" name="fileProfileImage"
                   accept=".jpg,.jpeg,.png" class="form-control" style="max-width:320px;"
                   data-crop="true"
                   data-crop-ratio="1"
                   data-crop-output-width="300"
                   data-crop-output-height="300"
                   data-crop-preview="#imgPreview" />
            <div class="form-text">@await T.GetAsync("AdminUser.ProfileImageHint")</div>
          </div>
        </div>
      </div>

      <div class="row g-4">
        <div class="col-md-6">
          <label class="form-label">@await T.GetAsync("Username")</label>
          <input type="text" class="form-control" value="@Model.Username" readonly />
        </div>
        <div class="col-md-6">
          <label class="form-label" for="txtFullName">
            @await T.GetAsync("FullName") <span class="text-danger">*</span>
          </label>
          <input type="text" id="txtFullName" name="txtFullName" class="form-control"
                 maxlength="200" value="@Model.txtFullName"
                 placeholder="@await T.GetAsync("AdminUser.FullNamePlaceholder")" />
        </div>
        <div class="col-md-6">
          <label class="form-label" for="txtEmail">
            @await T.GetAsync("Email") <span class="text-danger">*</span>
          </label>
          <input type="text" id="txtEmail" name="txtEmail" class="form-control"
                 maxlength="200" value="@Model.txtEmail"
                 placeholder="@await T.GetAsync("AdminUser.EmailPlaceholder")" />
        </div>
        <div class="col-md-6">
          <label class="form-label" for="ddlRoleId">
            @await T.GetAsync("Role") <span class="text-danger">*</span>
          </label>
          <select asp-for="ddlRoleId" class="form-select" asp-items="@Model.RoleOptions">
            <option value="0">— @await T.GetAsync("SelectRole") —</option>
          </select>
        </div>
        <div class="col-md-6">
          <label class="form-label" for="ddlDeptId">@await T.GetAsync("Department")</label>
          <select asp-for="ddlDeptId" class="form-select" asp-items="@Model.DeptOptions">
            <option value="">— @await T.GetAsync("SelectDepartment") —</option>
          </select>
        </div>
        <div class="col-md-6">
          <label class="form-label" for="ddlCountryCode">
            @await T.GetAsync("Country") <span class="text-danger">*</span>
          </label>
          <select asp-for="ddlCountryCode" class="form-select" asp-items="@Model.CountryOptions"></select>
        </div>
        <div class="col-md-6">
          <label class="form-label" for="ddlRegionId">@await T.GetAsync("Region")</label>
          <select asp-for="ddlRegionId" class="form-select" asp-items="@Model.RegionOptions">
            <option value="">— @await T.GetAsync("SelectRegion") —</option>
          </select>
        </div>
        <div class="col-md-3">
          <label class="form-label" for="txtMobileCountryCode">@await T.GetAsync("AdminUser.MobileCountryCode")</label>
          <input type="text" id="txtMobileCountryCode" name="txtMobileCountryCode" class="form-control"
                 maxlength="10" value="@Model.txtMobileCountryCode" placeholder="+60" />
        </div>
        <div class="col-md-3">
          <label class="form-label" for="txtMobileNo">@await T.GetAsync("MobileNo")</label>
          <input type="text" id="txtMobileNo" name="txtMobileNo" class="form-control"
                 maxlength="20" value="@Model.txtMobileNo"
                 placeholder="@await T.GetAsync("AdminUser.MobileNoPlaceholder")" />
        </div>
        <div class="col-md-6">
          <label class="form-label" for="ddlStatus">@await T.GetAsync("Status")</label>
          <select asp-for="ddlStatus" class="form-select" asp-items="@Model.StatusOptions"></select>
        </div>
        <div class="col-12">
          <div class="form-check">
            <input asp-for="chkIsForceChangePassword" class="form-check-input" />
            <label class="form-check-label" for="chkIsForceChangePassword">
              @await T.GetAsync("AdminUser.ForceChangePassword")
            </label>
          </div>
        </div>
      </div>

      <div class="mt-4 d-flex gap-2">
        <button type="submit" class="btn btn-primary">@await T.GetAsync("Btn.SaveChanges")</button>
        <a asp-area="Admin" asp-page="/AdminUsers/Index" class="btn btn-outline-secondary">
          @await T.GetAsync("Btn.Cancel")
        </a>
        <a href="#" id="btnDelete" class="btn btn-outline-danger ms-auto" data-id="@Model.Id">
          <i class="ri ri-delete-bin-line me-1"></i>@Model.LabelDelete
        </a>
      </div>

    </form>

    <hr class="my-4" />
    <div class="row g-3">
      <div class="col-md-6">
        <label class="form-label text-muted small">@await T.GetAsync("CreatedBy")</label>
        <p class="mb-0">@Model.CreatedBy</p>
      </div>
      <div class="col-md-6">
        <label class="form-label text-muted small">@await T.GetAsync("CreatedAt")</label>
        <p class="mb-0">@Model.CreatedAt.ToUserLocalTime(Model.UserTimezone, AppConstants.DateTimeFormat)</p>
      </div>
      <div class="col-md-6">
        <label class="form-label text-muted small">@await T.GetAsync("UpdatedBy")</label>
        <p class="mb-0">@Model.UpdatedBy</p>
      </div>
      <div class="col-md-6">
        <label class="form-label text-muted small">@await T.GetAsync("UpdatedAt")</label>
        <p class="mb-0">@Model.UpdatedAt.ToUserLocalTime(Model.UserTimezone, AppConstants.DateTimeFormat)</p>
      </div>
      @if (Model.LastLoginAt.HasValue)
      {
        <div class="col-md-6">
          <label class="form-label text-muted small">@await T.GetAsync("AdminUser.LastLoginAt")</label>
          <p class="mb-0">@Model.LastLoginAt.Value.ToUserLocalTime(Model.UserTimezone, AppConstants.DateTimeFormat)</p>
        </div>
        <div class="col-md-6">
          <label class="form-label text-muted small">@await T.GetAsync("AdminUser.LastLoginLang")</label>
          <p class="mb-0">@(string.IsNullOrEmpty(Model.LastLoginLang) ? "-" : Model.LastLoginLang)</p>
        </div>
      }
    </div>
  </div>
</div>

@* Hidden form supplies antiforgery token for AJAX calls *@
<form id="formAjax" method="post">
  @Html.AntiForgeryToken()
</form>

@section VendorScripts {
  <script src="~/vendor/libs/sweetalert2/sweetalert2.dist.js"></script>
}

@section PageScripts {
<script>
  var pageMsg = {
    deleteConfirmTitle: '@Html.Raw(Model.MsgDeleteConfirmTitle)',
    deleteConfirmText:  '@Html.Raw(Model.MsgDeleteConfirmText)',
    deleteConfirmBtn:   '@Html.Raw(Model.MsgDeleteConfirmBtn)',
    cancelBtn:          '@Html.Raw(Model.MsgCancelBtn)',
    deleteSuccess:      '@Html.Raw(Model.MsgDeleteSuccess)',
    deleteError:        '@Html.Raw(Model.MsgDeleteError)'
  };

  document.getElementById('btnDelete').addEventListener('click', function (e) {
    e.preventDefault();
    var id = this.getAttribute('data-id');
    Swal.fire({
      title: pageMsg.deleteConfirmTitle,
      text:  pageMsg.deleteConfirmText,
      icon:  'warning',
      showCancelButton: true,
      confirmButtonText: pageMsg.deleteConfirmBtn,
      cancelButtonText:  pageMsg.cancelBtn,
      confirmButtonColor: '#dc3545'
    }).then(function (result) {
      if (result.isConfirmed) {
        $.post('?handler=SoftDelete&id=' + id, {
          __RequestVerificationToken: $('#formAjax input[name="__RequestVerificationToken"]').val()
        }, function (data) {
          if (data.success) {
            Swal.fire({ icon: 'success', title: pageMsg.deleteSuccess, timer: 1500, showConfirmButton: false })
              .then(function () { window.location.href = '@Url.Page(Routes.AdminAdminUsers)'; });
          } else {
            Swal.fire({ icon: 'error', text: data.message || pageMsg.deleteError });
          }
        }).fail(function () {
          Swal.fire({ icon: 'error', text: pageMsg.deleteError });
        });
      }
    });
  });

  document.addEventListener("DOMContentLoaded", function () {
    var messageType = '@Model.AlertMessageType';
    if (messageType !== '') {
      Swal.fire({
        icon:  messageType,
        title: @Html.Raw(Json.Serialize(Model.AlertMessageTitle)),
        text:  @Html.Raw(Json.Serialize(Model.AlertMessageContent))
      });
    }
  });
</script>
}
