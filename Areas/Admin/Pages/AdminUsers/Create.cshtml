@page
@model MyApp.Areas.Admin.Pages.AdminUsers.CreateModel
@{
  ViewData["title"] = await T.GetAsync("AdminUser.AddTitle");
  var msgPasswordMismatch = await T.GetAsync("AdminUser.PasswordMismatch");
  var msgFileTooLarge     = await T.GetAsync("AdminUser.FileTooLarge");
  var msgInvalidFileType  = await T.GetAsync("AdminUser.InvalidFileType");
}

@section VendorStyles {
  <link rel="stylesheet" href="~/vendor/libs/sweetalert2/sweetalert2.dist.css" />
}

<div class="d-flex justify-content-between align-items-center py-3 mb-4">
  <h4 class="mb-0">@await T.GetAsync("AdminUser.AddTitle")</h4>
  <a asp-area="Admin" asp-page="/AdminUsers/Index" class="btn btn-outline-secondary">
    <i class="ri ri-arrow-left-line me-1"></i> @await T.GetAsync("BackToList")
  </a>
</div>

<div class="card">
  <div class="card-body">
    <form method="post" asp-page-handler="Create" enctype="multipart/form-data">

      @* Profile Image *@
      <div class="mb-4">
        <label class="form-label">@await T.GetAsync("ProfileImage")</label>
        <div class="d-flex align-items-center gap-3">
          <img id="imgPreview" src="/images/default-avatar.png"
               style="width:80px;height:80px;object-fit:cover;border-radius:50%;border:2px solid #dee2e6;" />
          <div>
            <input type="file" id="fileProfileImage" name="fileProfileImage"
                   accept=".jpg,.jpeg,.png" class="form-control" style="max-width:320px;"
                   data-crop="true"
                   data-crop-ratio="1"
                   data-crop-output-width="300"
                   data-crop-output-height="300"
                   data-crop-preview="#imgPreview" />
            <div class="form-text">@await T.GetAsync("AdminUser.ProfileImageHint")</div>
          </div>
        </div>
      </div>

      <div class="row g-4">
        <div class="col-md-6">
          <label class="form-label" for="txtFullName">
            @await T.GetAsync("FullName") <span class="text-danger">*</span>
          </label>
          <input type="text" id="txtFullName" name="txtFullName" class="form-control"
                 maxlength="200" value="@Model.txtFullName"
                 placeholder="@await T.GetAsync("AdminUser.FullNamePlaceholder")" />
        </div>
        <div class="col-md-6">
          <label class="form-label" for="txtUsername">
            @await T.GetAsync("Username") <span class="text-danger">*</span>
          </label>
          <input type="text" id="txtUsername" name="txtUsername" class="form-control"
                 maxlength="100" value="@Model.txtUsername"
                 placeholder="@await T.GetAsync("AdminUser.UsernamePlaceholder")" />
        </div>
        <div class="col-md-6">
          <label class="form-label" for="txtEmail">
            @await T.GetAsync("Email") <span class="text-danger">*</span>
          </label>
          <input type="text" id="txtEmail" name="txtEmail" class="form-control"
                 maxlength="200" value="@Model.txtEmail"
                 placeholder="@await T.GetAsync("AdminUser.EmailPlaceholder")" />
        </div>
        <div class="col-md-6">
          <label class="form-label" for="ddlRoleId">
            @await T.GetAsync("Role") <span class="text-danger">*</span>
          </label>
          <select asp-for="ddlRoleId" class="form-select" asp-items="@Model.RoleOptions">
            <option value="0">— @await T.GetAsync("SelectRole") —</option>
          </select>
        </div>
        <div class="col-md-6">
          <label class="form-label" for="txtPassword">
            @await T.GetAsync("Password") <span class="text-danger">*</span>
          </label>
          <div class="input-group">
            <input type="password" id="txtPassword" name="txtPassword" class="form-control"
                   placeholder="············" />
            <button class="btn btn-outline-secondary" type="button" id="btnTogglePwd" tabindex="-1">
              <i id="iconTogglePwd" class="ri ri-eye-off-line"></i>
            </button>
          </div>
        </div>
        <div class="col-md-6">
          <label class="form-label" for="txtConfirmPassword">
            @await T.GetAsync("ConfirmPassword") <span class="text-danger">*</span>
          </label>
          <div class="input-group">
            <input type="password" id="txtConfirmPassword" name="txtConfirmPassword" class="form-control"
                   placeholder="············" />
            <button class="btn btn-outline-secondary" type="button" id="btnToggleConfirmPwd" tabindex="-1">
              <i id="iconToggleConfirmPwd" class="ri ri-eye-off-line"></i>
            </button>
          </div>
        </div>
        <div class="col-md-6">
          <label class="form-label" for="ddlDeptId">@await T.GetAsync("Department")</label>
          <select asp-for="ddlDeptId" class="form-select" asp-items="@Model.DeptOptions">
            <option value="">— @await T.GetAsync("SelectDepartment") —</option>
          </select>
        </div>
        <div class="col-md-6">
          <label class="form-label" for="ddlCountryCode">
            @await T.GetAsync("Country") <span class="text-danger">*</span>
          </label>
          <select asp-for="ddlCountryCode" class="form-select" asp-items="@Model.CountryOptions"></select>
        </div>
        <div class="col-md-6">
          <label class="form-label" for="ddlRegionId">@await T.GetAsync("Region")</label>
          <select asp-for="ddlRegionId" class="form-select" asp-items="@Model.RegionOptions">
            <option value="">— @await T.GetAsync("SelectRegion") —</option>
          </select>
        </div>
        <div class="col-md-3">
          <label class="form-label" for="txtMobileCountryCode">@await T.GetAsync("AdminUser.MobileCountryCode")</label>
          <input type="text" id="txtMobileCountryCode" name="txtMobileCountryCode" class="form-control"
                 maxlength="10" value="@Model.txtMobileCountryCode" placeholder="+60" />
        </div>
        <div class="col-md-3">
          <label class="form-label" for="txtMobileNo">@await T.GetAsync("MobileNo")</label>
          <input type="text" id="txtMobileNo" name="txtMobileNo" class="form-control"
                 maxlength="20" value="@Model.txtMobileNo"
                 placeholder="@await T.GetAsync("AdminUser.MobileNoPlaceholder")" />
        </div>
        <div class="col-md-6">
          <label class="form-label" for="ddlStatus">@await T.GetAsync("Status")</label>
          <select asp-for="ddlStatus" class="form-select" asp-items="@Model.StatusOptions"></select>
        </div>
        <div class="col-12">
          <div class="form-check">
            <input asp-for="chkIsForceChangePassword" class="form-check-input" />
            <label class="form-check-label" for="chkIsForceChangePassword">
              @await T.GetAsync("AdminUser.ForceChangePassword")
            </label>
          </div>
        </div>
      </div>

      <div class="mt-4 d-flex gap-2">
        <button type="submit" class="btn btn-primary">@await T.GetAsync("Btn.Save")</button>
        <a asp-area="Admin" asp-page="/AdminUsers/Index" class="btn btn-outline-secondary">
          @await T.GetAsync("Btn.Cancel")
        </a>
      </div>

    </form>
  </div>
</div>

@section VendorScripts {
  <script src="~/vendor/libs/sweetalert2/sweetalert2.dist.js"></script>
}

@section PageScripts {
<script>
  document.getElementById('fileProfileImage').addEventListener('change', function () {
    var file = this.files[0];
    if (!file) return;
    var allowedTypes = ['image/jpeg', 'image/jpg', 'image/png'];
    if (!allowedTypes.includes(file.type)) {
      Swal.fire({ icon: 'error', text: '@Html.Raw(msgInvalidFileType)' });
      this.value = '';
      return;
    }
    if (file.size > 2 * 1024 * 1024) {
      Swal.fire({ icon: 'error', text: '@Html.Raw(msgFileTooLarge)' });
      this.value = '';
      return;
    }
    var reader = new FileReader();
    reader.onload = function (e) {
      document.getElementById('imgPreview').src = e.target.result;
    };
    reader.readAsDataURL(file);
  });

  document.getElementById('btnTogglePwd').addEventListener('click', function () {
    var input = document.getElementById('txtPassword');
    var icon  = document.getElementById('iconTogglePwd');
    if (input.type === 'password') { input.type = 'text';     icon.classList.replace('ri-eye-off-line', 'ri-eye-line'); }
    else                           { input.type = 'password'; icon.classList.replace('ri-eye-line', 'ri-eye-off-line'); }
  });

  document.getElementById('btnToggleConfirmPwd').addEventListener('click', function () {
    var input = document.getElementById('txtConfirmPassword');
    var icon  = document.getElementById('iconToggleConfirmPwd');
    if (input.type === 'password') { input.type = 'text';     icon.classList.replace('ri-eye-off-line', 'ri-eye-line'); }
    else                           { input.type = 'password'; icon.classList.replace('ri-eye-line', 'ri-eye-off-line'); }
  });

  document.querySelector('form').addEventListener('submit', function (e) {
    var pwd  = document.getElementById('txtPassword').value;
    var cpwd = document.getElementById('txtConfirmPassword').value;
    if (pwd !== cpwd) {
      e.preventDefault();
      Swal.fire({ icon: 'error', text: '@Html.Raw(msgPasswordMismatch)' });
    }
  });

  document.addEventListener("DOMContentLoaded", function () {
    var messageType = '@Model.AlertMessageType';
    if (messageType !== '') {
      Swal.fire({
        icon:  messageType,
        title: @Html.Raw(Json.Serialize(Model.AlertMessageTitle)),
        text:  @Html.Raw(Json.Serialize(Model.AlertMessageContent))
      });
    }
  });
</script>
}
