@page
@model MyApp.Areas.Admin.Pages.Account.ChangePasswordModel
@{
  ViewData["title"] = await T.GetAsync("ChangePwd.Title");
}

@section VendorStyles {
  <link rel="stylesheet" href="~/vendor/libs/sweetalert2/sweetalert2.dist.css" />
}

<div class="d-flex justify-content-between align-items-center py-3 mb-4">
  <h4 class="mb-0">@await T.GetAsync("ChangePwd.Title")</h4>
  <a asp-area="Admin" asp-page="/Dashboard/Index" class="btn btn-outline-secondary">
    <i class="ri ri-arrow-left-line me-1"></i>@await T.GetAsync("Btn.Cancel")
  </a>
</div>

<div class="row justify-content-center">
  <div class="col-md-6">
    <div class="card">
      <div class="card-header">
        <h5 class="mb-0">@await T.GetAsync("ChangePwd.Title")</h5>
      </div>
      <div class="card-body">
        <form id="formChangePassword" method="post">
          @Html.AntiForgeryToken()

          @* Current Password *@
          <div class="mb-4">
            <div class="input-group">
              <div class="form-floating form-floating-outline flex-grow-1">
                <input type="password" id="txtCurrentPassword" class="form-control"
                       name="txtCurrentPassword" placeholder="············" />
                <label for="txtCurrentPassword">@await T.GetAsync("CurrentPassword")</label>
              </div>
              <button class="btn btn-outline-secondary" type="button" id="btnToggleCurrentPwd" tabindex="-1">
                <i id="iconToggleCurrentPwd" class="ri ri-eye-off-line"></i>
              </button>
            </div>
            <div id="errCurrentPassword" class="text-danger small mt-1" style="display:none;"></div>
          </div>

          @* New Password *@
          <div class="mb-4">
            <div class="input-group">
              <div class="form-floating form-floating-outline flex-grow-1">
                <input type="password" id="txtNewPassword" class="form-control"
                       name="txtNewPassword" placeholder="············" />
                <label for="txtNewPassword">@await T.GetAsync("NewPassword")</label>
              </div>
              <button class="btn btn-outline-secondary" type="button" id="btnToggleNewPwd" tabindex="-1">
                <i id="iconToggleNewPwd" class="ri ri-eye-off-line"></i>
              </button>
            </div>
            <div id="errNewPassword" class="text-danger small mt-1" style="display:none;"></div>
            <small class="text-muted">@await T.GetAsync("Pwd.StrengthHint")</small>
          </div>

          @* Confirm Password *@
          <div class="mb-5">
            <div class="input-group">
              <div class="form-floating form-floating-outline flex-grow-1">
                <input type="password" id="txtConfirmPassword" class="form-control"
                       name="txtConfirmPassword" placeholder="············" />
                <label for="txtConfirmPassword">@await T.GetAsync("ConfirmPassword")</label>
              </div>
              <button class="btn btn-outline-secondary" type="button" id="btnToggleConfirmPwd" tabindex="-1">
                <i id="iconToggleConfirmPwd" class="ri ri-eye-off-line"></i>
              </button>
            </div>
            <div id="errConfirmPassword" class="text-danger small mt-1" style="display:none;"></div>
          </div>

          <div class="d-flex gap-3">
            <button class="btn btn-primary" type="submit">
              @await T.GetAsync("Btn.ChangePassword")
            </button>
            <a asp-area="Admin" asp-page="/Dashboard/Index" class="btn btn-outline-secondary">
              @await T.GetAsync("Btn.Cancel")
            </a>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>

@* Hidden antiforgery form for AJAX calls *@
<form id="formAjax" method="post">@Html.AntiForgeryToken()</form>

@section VendorScripts {
  <script src="~/vendor/libs/sweetalert2/sweetalert2.dist.js"></script>
}

@section PageScripts {
<script>
  var pageMsg = {
    errorTitle:     '@Html.Raw(Model.MsgErrorTitle)',
    successTitle:   '@Html.Raw(Model.MsgSuccessTitle)',
    pwdMismatch:    '@Html.Raw(Model.MsgPasswordMismatch)',
    pwdWeak:        '@Html.Raw(Model.MsgPasswordWeak)',
    pwdSameCurrent: '@Html.Raw(Model.MsgSameAsCurrentPassword)'
  };

  // Password toggles
  [
    ['btnToggleCurrentPwd', 'txtCurrentPassword', 'iconToggleCurrentPwd'],
    ['btnToggleNewPwd',     'txtNewPassword',     'iconToggleNewPwd'],
    ['btnToggleConfirmPwd', 'txtConfirmPassword', 'iconToggleConfirmPwd']
  ].forEach(function (trio) {
    document.getElementById(trio[0]).addEventListener('click', function () {
      var input = document.getElementById(trio[1]);
      var icon  = document.getElementById(trio[2]);
      if (input.type === 'password') {
        input.type = 'text';
        icon.classList.replace('ri-eye-off-line', 'ri-eye-line');
      } else {
        input.type = 'password';
        icon.classList.replace('ri-eye-line', 'ri-eye-off-line');
      }
    });
  });

  // Client-side validation
  function isPasswordStrong(pwd) {
    return pwd.length >= 8 && /[A-Z]/.test(pwd) && /[a-z]/.test(pwd) && /[0-9]/.test(pwd);
  }

  function showFieldError(inputId, errorId, msg) {
    document.getElementById(inputId).classList.add('is-invalid');
    var err = document.getElementById(errorId);
    err.textContent = msg;
    err.style.display = 'block';
  }

  function clearFieldErrors() {
    ['txtCurrentPassword', 'txtNewPassword', 'txtConfirmPassword'].forEach(function (id) {
      document.getElementById(id).classList.remove('is-invalid');
    });
    ['errCurrentPassword', 'errNewPassword', 'errConfirmPassword'].forEach(function (id) {
      var el = document.getElementById(id);
      el.textContent = '';
      el.style.display = 'none';
    });
  }

  document.getElementById('formChangePassword').addEventListener('submit', function (e) {
    clearFieldErrors();
    var currentPwd = document.getElementById('txtCurrentPassword').value;
    var newPwd     = document.getElementById('txtNewPassword').value;
    var confirmPwd = document.getElementById('txtConfirmPassword').value;
    var valid      = true;

    if (!currentPwd) {
      showFieldError('txtCurrentPassword', 'errCurrentPassword', pageMsg.pwdWeak);
      valid = false;
    }

    if (!isPasswordStrong(newPwd)) {
      showFieldError('txtNewPassword', 'errNewPassword', pageMsg.pwdWeak);
      valid = false;
    }

    if (newPwd !== confirmPwd) {
      showFieldError('txtConfirmPassword', 'errConfirmPassword', pageMsg.pwdMismatch);
      valid = false;
    }

    if (!valid) e.preventDefault();
  });

  // Server-side error alert
  document.addEventListener('DOMContentLoaded', function () {
    var messageType = '@Model.AlertMessageType';
    if (messageType !== '') {
      Swal.fire({
        icon:  messageType,
        title: @Html.Raw(Json.Serialize(Model.AlertMessageTitle)),
        text:  @Html.Raw(Json.Serialize(Model.AlertMessageContent))
      });
    }
  });
</script>
}
