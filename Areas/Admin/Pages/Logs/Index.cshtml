@page
@model MyApp.Areas.Admin.Pages.Logs.IndexModel
@using MyApp.Constants
@{
  ViewData["title"] = await T.GetAsync("Logs.PageTitle");
}

<h4 class="py-4 mb-2">@await T.GetAsync("Logs.PageTitle")</h4>

@* ── Filter Bar ────────────────────────────────────────── *@
<div class="card mb-4">
  <div class="card-body">
    <form method="post" asp-page-handler="Filter">
      @Html.AntiForgeryToken()
      <div class="row g-3 align-items-end">
        <div class="col-md-3">
          <label class="form-label">@await T.GetAsync("Logs.LogLevel")</label>
          <select asp-for="FilterLogLevel" asp-items="Model.LogLevelOptions" class="form-select">
            <option value="">@await T.GetAsync("Logs.AllLevels")</option>
          </select>
        </div>
        <div class="col-md-3">
          <label class="form-label">@await T.GetAsync("Logs.DateFrom")</label>
          <input type="date" asp-for="FilterDateFrom" class="form-control" value="@Model.FilterDateFrom" />
        </div>
        <div class="col-md-3">
          <label class="form-label">@await T.GetAsync("Logs.DateTo")</label>
          <input type="date" asp-for="FilterDateTo" class="form-control" value="@Model.FilterDateTo" />
        </div>
        <div class="col-md-3 d-flex gap-2">
          <button type="submit" class="btn btn-primary">
            <i class="ri ri-search-line me-1"></i>@await T.GetAsync("Search")
          </button>
          <a asp-page="/Logs/Index" class="btn btn-outline-secondary">
            @await T.GetAsync("Clear")
          </a>
        </div>
      </div>
    </form>
  </div>
</div>

@* ── Logs Table ────────────────────────────────────────── *@
<div class="card">
  <div class="card-header d-flex align-items-center justify-content-between">
    <h5 class="mb-0">@await T.GetAsync("Logs.RecentErrors")</h5>
  </div>
  <div class="card-body">
    <div class="table-responsive">
      <table id="tblLogs" class="table table-striped table-hover">
        <thead>
          <tr>
            <th>@await T.GetAsync("Exception")</th>
            <th>@await T.GetAsync("Time")</th>
            <th>@await T.GetAsync("Level")</th>
            <th>@await T.GetAsync("Source")</th>
            <th>@await T.GetAsync("Message")</th>
          </tr>
        </thead>
        <tbody>
          @foreach (var log in Model.Logs)
          {
            <tr>
              <td>
                @if (!string.IsNullOrEmpty(log.Exception))
                {
                  <button type="button" class="btn btn-sm btn-outline-danger btn-view-exception"
                          data-exception="@log.Exception">
                    @await T.GetAsync("View")
                  </button>
                }
              </td>
              <td class="text-nowrap">
                @log.CreatedAt.ToUserLocalTime(Model.UserTimezone, AppConstants.DateTimeFormat)
              </td>
              <td>
                @{
                  var badgeClass = log.LogLevel switch
                  {
                    "Critical"    => "bg-dark",
                    "Error"       => "bg-danger",
                    "Warning"     => "bg-warning text-dark",
                    "Information" => "bg-info text-dark",
                    _             => "bg-secondary"
                  };
                }
                <span class="badge @badgeClass">@log.LogLevel</span>
              </td>
              <td class="text-nowrap">
                @{
                  var parts         = log.Category.Split('.');
                  var shortCategory = parts.LastOrDefault() ?? log.Category;
                }
                <span title="@log.Category">@shortCategory</span>
              </td>
              <td>@log.Message</td>
            </tr>
          }
        </tbody>
      </table>
    </div>
  </div>
</div>

@* ── Exception Modal ───────────────────────────────────── *@
<div class="modal fade" id="modalException" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-xl">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">@await T.GetAsync("Logs.ExceptionDetails")</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <pre id="exceptionText" class="bg-light p-3 rounded"
             style="max-height:500px;overflow-y:auto;white-space:pre-wrap;word-break:break-all;font-size:0.8rem;"></pre>
      </div>
    </div>
  </div>
</div>

@section PageScripts {
<script>
  $(document).ready(function () {
    initDataTable('#tblLogs', 0, [[1, 'desc']]);

    $(document).on('click', '.btn-view-exception', function () {
      document.getElementById('exceptionText').textContent = this.getAttribute('data-exception');
      new bootstrap.Modal(document.getElementById('modalException')).show();
    });
  });
</script>
}
