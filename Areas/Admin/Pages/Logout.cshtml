@page
@model MyApp.Areas.Admin.Pages.LogoutModel
@{
}



<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
		document.addEventListener("DOMContentLoaded", function () {
		var messageType = '@Model.AlertMessageType';
		var messageTitle = '@Model.AlertMessageTitle';
			var messageContent = '@Model.AlertMessageContent';


		if (messageType != "" ) {
				Swal.fire({
			icon: messageType,
			title: @Html.Raw(Json.Serialize(Model.AlertMessageTitle)),
				text: @Html.Raw(Json.Serialize(Model.AlertMessageContent))

			 }).then(() => {
		// Optional: trigger a reload or redirect

				});
			}
		});
</script>



