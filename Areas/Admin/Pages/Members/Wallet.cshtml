@page
@model MyApp.Areas.Admin.Pages.Members.WalletModel
@{
  ViewData["title"] = await T.GetAsync("Menu.Wallets");
  var memberSearchUrl = Url.Page("/Members/Index", "SearchMembers", new { area = "Admin" });
  var displayRate = Model.ExchangeRate != 0 ? Model.ExchangeRate : 1m;
  var cashDisplay     = Model.CashBalance / displayRate;
  var purchaseDisplay = Model.PurchaseBalance / displayRate;
}

@section VendorStyles {
  <link rel="stylesheet" href="~/vendor/libs/sweetalert2/sweetalert2.dist.css" />
  <link rel="stylesheet" href="~/vendor/libs/select2/select2.dist.css" />
}

<div class="d-flex justify-content-between align-items-center py-3 mb-4">
  <div>
    <h4 class="mb-0">@await T.GetAsync("Menu.Wallets")</h4>
    <small class="text-muted">@Model.MemberUsername — @Model.MemberFullName</small>
  </div>
  <div>
    <a asp-area="Admin" asp-page="/Members/Edit" asp-route-id="@Model.MemberId"
       class="btn btn-outline-secondary me-2">
      <i class="ri ri-edit-line me-1"></i>@await T.GetAsync("Edit")
    </a>
    <a asp-area="Admin" asp-page="/Members/Manage" asp-route-id="@Model.MemberId"
       class="btn btn-outline-secondary me-2">
      <i class="ri ri-settings-line me-1"></i>@await T.GetAsync("Members.Title.Manage")
    </a>
    <a asp-area="Admin" asp-page="/Members/Index" class="btn btn-outline-secondary">
      <i class="ri ri-arrow-left-line me-1"></i>@await T.GetAsync("Btn.Back")
    </a>
  </div>
</div>

@* Hidden antiforgery for AJAX *@
<form id="formAjax" method="post">@Html.AntiForgeryToken()</form>

@* ── Balance Summary ── *@
<div class="row g-4 mb-4">
  <div class="col-md-6">
    <div class="card h-100 border-0 shadow-sm">
      <div class="card-body">
        <h6 class="text-muted mb-1">@await T.GetAsync("Wallet.CashWallet")</h6>
        <h3 class="mb-0">@Model.CashBalance.ToString("F2") USD</h3>
        @if (Model.CurrencyCode != "USD" && Model.CurrencyCode != string.Empty)
        {
          <small class="text-muted">
            ≈ @Model.CurrencySymbol @cashDisplay.ToString("F2") @Model.CurrencyCode
            <span class="ms-1">(1 @Model.CurrencyCode = @displayRate.ToString("F6") USD)</span>
          </small>
        }
      </div>
    </div>
  </div>
  <div class="col-md-6">
    <div class="card h-100 border-0 shadow-sm">
      <div class="card-body">
        <h6 class="text-muted mb-1">@await T.GetAsync("Wallet.PurchaseWallet")</h6>
        <h3 class="mb-0">@Model.PurchaseBalance.ToString("F2") USD</h3>
        @if (Model.CurrencyCode != "USD" && Model.CurrencyCode != string.Empty)
        {
          <small class="text-muted">
            ≈ @Model.CurrencySymbol @purchaseDisplay.ToString("F2") @Model.CurrencyCode
            <span class="ms-1">(1 @Model.CurrencyCode = @displayRate.ToString("F6") USD)</span>
          </small>
        }
      </div>
    </div>
  </div>
</div>

@* ── Tabs ── *@
<ul class="nav nav-tabs mb-4" id="walletTabs">
  <li class="nav-item">
    <a class="nav-link" id="tab-cash-link" href="#tab-cash" data-bs-toggle="tab">
      @await T.GetAsync("Wallet.CashWallet")
    </a>
  </li>
  <li class="nav-item">
    <a class="nav-link" id="tab-purchase-link" href="#tab-purchase" data-bs-toggle="tab">
      @await T.GetAsync("Wallet.PurchaseWallet")
    </a>
  </li>
</ul>

<div class="tab-content">

  @* ══ Cash Wallet Tab ══ *@
  <div class="tab-pane" id="tab-cash">

    @* Manual Adjustment *@
    <div class="card mb-4">
      <div class="card-header"><h6 class="mb-0">@await T.GetAsync("Wallet.Adjustment")</h6></div>
      <div class="card-body">
        <div class="row g-3 align-items-end">
          <div class="col-md-3">
            <label class="form-label">@await T.GetAsync("Wallet.Direction")</label>
            <select id="ddlAdjDirCash" class="form-select">
              <option value="in">@await T.GetAsync("Wallet.Direction.In")</option>
              <option value="out">@await T.GetAsync("Wallet.Direction.Out")</option>
            </select>
          </div>
          <div class="col-md-3">
            <label class="form-label">@await T.GetAsync("Wallet.AmountUsd")</label>
            <input type="number" id="txtAdjAmountCash" class="form-control"
                   step="0.01" min="0.01" placeholder="0.00" />
          </div>
          <div class="col-md-4">
            <label class="form-label">@await T.GetAsync("Wallet.Remark")</label>
            <input type="text" id="txtAdjRemarkCash" class="form-control"
                   placeholder="@await T.GetAsync("Wallet.Remark")" maxlength="200" />
          </div>
          <div class="col-auto">
            <button type="button" class="btn btn-primary"
                    onclick="saveAdjustment('cash', 'ddlAdjDirCash', 'txtAdjAmountCash', 'txtAdjRemarkCash')">
              <i class="ri ri-save-line me-1"></i>@await T.GetAsync("Btn.Save")
            </button>
          </div>
        </div>
      </div>
    </div>

    @* Cash Transaction History *@
    <div class="card">
      <div class="card-header"><h6 class="mb-0">@await T.GetAsync("Wallet.CashWallet")</h6></div>
      <div class="card-body">
        <div class="table-responsive">
          <table class="table table-sm table-hover align-middle">
            <thead>
              <tr>
                <th>@await T.GetAsync("Wallet.TxnType")</th>
                <th>@await T.GetAsync("Wallet.Direction")</th>
                <th>@await T.GetAsync("Wallet.AmountUsd")</th>
                <th>@await T.GetAsync("Wallet.DisplayAmount")</th>
                <th>@await T.GetAsync("Wallet.ExchangeRate")</th>
                <th>@await T.GetAsync("Wallet.Balance")</th>
                <th>@await T.GetAsync("Wallet.ReferenceId")</th>
                <th>@await T.GetAsync("Wallet.Remark")</th>
                <th>@await T.GetAsync("CreatedAt")</th>
              </tr>
            </thead>
            <tbody>
              @foreach (var txn in Model.CashTransactions)
              {
                var dirBadge = txn.Direction == "in" ? "bg-success" : "bg-danger";
                var dirLabel = txn.Direction == "in" ? "IN" : "OUT";
                <tr>
                  <td><span class="badge bg-secondary">@txn.TxnType</span></td>
                  <td><span class="badge @dirBadge">@dirLabel</span></td>
                  <td>@txn.AmountUsd.ToString("F2")</td>
                  <td>@txn.DisplayCurrency @txn.DisplayAmount.ToString("F2")</td>
                  <td>@txn.ExchangeRate.ToString("F6")</td>
                  <td>@txn.BalanceAfter.ToString("F2")</td>
                  <td><small class="text-muted">@txn.ReferenceId</small></td>
                  <td><small>@txn.Remark</small></td>
                  <td><small>@txn.CreatedAt.ToUserLocalTime(Model.UserTimezone, AppConstants.DateTimeFormat)</small></td>
                </tr>
              }
              @if (!Model.CashTransactions.Any())
              {
                <tr><td colspan="9" class="text-center text-muted py-3">—</td></tr>
              }
            </tbody>
          </table>
        </div>

        @if (Model.CashTotalPages > 1)
        {
          <nav class="mt-3">
            <ul class="pagination pagination-sm justify-content-center mb-0">
              @for (var p = 1; p <= Model.CashTotalPages; p++)
              {
                <li class="page-item @(p == Model.CashPage ? "active" : "")">
                  <a class="page-link"
                     asp-area="Admin" asp-page="/Members/Wallet"
                     asp-route-id="@Model.MemberId"
                     asp-route-cashPage="@p"
                     asp-route-purchasePage="@Model.PurchasePage"
                     asp-route-tab="cash">@p</a>
                </li>
              }
            </ul>
          </nav>
        }
      </div>
    </div>
  </div>

  @* ══ Purchase Wallet Tab ══ *@
  <div class="tab-pane" id="tab-purchase">

    @* Manual Adjustment *@
    <div class="card mb-4">
      <div class="card-header"><h6 class="mb-0">@await T.GetAsync("Wallet.Adjustment")</h6></div>
      <div class="card-body">
        <div class="row g-3 align-items-end">
          <div class="col-md-3">
            <label class="form-label">@await T.GetAsync("Wallet.Direction")</label>
            <select id="ddlAdjDirPurchase" class="form-select">
              <option value="in">@await T.GetAsync("Wallet.Direction.In")</option>
              <option value="out">@await T.GetAsync("Wallet.Direction.Out")</option>
            </select>
          </div>
          <div class="col-md-3">
            <label class="form-label">@await T.GetAsync("Wallet.AmountUsd")</label>
            <input type="number" id="txtAdjAmountPurchase" class="form-control"
                   step="0.01" min="0.01" placeholder="0.00" />
          </div>
          <div class="col-md-4">
            <label class="form-label">@await T.GetAsync("Wallet.Remark")</label>
            <input type="text" id="txtAdjRemarkPurchase" class="form-control"
                   placeholder="@await T.GetAsync("Wallet.Remark")" maxlength="200" />
          </div>
          <div class="col-auto">
            <button type="button" class="btn btn-primary"
                    onclick="saveAdjustment('purchase', 'ddlAdjDirPurchase', 'txtAdjAmountPurchase', 'txtAdjRemarkPurchase')">
              <i class="ri ri-save-line me-1"></i>@await T.GetAsync("Btn.Save")
            </button>
          </div>
        </div>
      </div>
    </div>

    @* Transfer *@
    <div class="card mb-4">
      <div class="card-header"><h6 class="mb-0">@await T.GetAsync("Wallet.Transfer")</h6></div>
      <div class="card-body">
        <div class="row g-3 align-items-end">
          <div class="col-md-5">
            <label class="form-label">@await T.GetAsync("Members.Manage.ChangeSponsor")</label>
            <input type="hidden" id="hdnTransferToMemberId" value="" />
            <select id="selectTransferTarget" class="form-select" style="width:100%">
              <option value="">@await T.GetAsync("Members.SearchPlaceholder")</option>
            </select>
          </div>
          <div class="col-md-3">
            <label class="form-label">@await T.GetAsync("Wallet.AmountUsd")</label>
            <input type="number" id="txtTransferAmount" class="form-control"
                   step="0.01" min="0.01" placeholder="0.00" />
          </div>
          <div class="col-md-3">
            <label class="form-label">@await T.GetAsync("Wallet.Remark")</label>
            <input type="text" id="txtTransferRemark" class="form-control"
                   placeholder="@await T.GetAsync("Wallet.Remark")" maxlength="200" />
          </div>
          <div class="col-auto">
            <button type="button" class="btn btn-warning" id="btnTransfer">
              <i class="ri ri-exchange-funds-line me-1"></i>@await T.GetAsync("Wallet.Transfer")
            </button>
          </div>
        </div>
      </div>
    </div>

    @* Purchase Transaction History *@
    <div class="card">
      <div class="card-header"><h6 class="mb-0">@await T.GetAsync("Wallet.PurchaseWallet")</h6></div>
      <div class="card-body">
        <div class="table-responsive">
          <table class="table table-sm table-hover align-middle">
            <thead>
              <tr>
                <th>@await T.GetAsync("Wallet.TxnType")</th>
                <th>@await T.GetAsync("Wallet.Direction")</th>
                <th>@await T.GetAsync("Wallet.AmountUsd")</th>
                <th>@await T.GetAsync("Wallet.DisplayAmount")</th>
                <th>@await T.GetAsync("Wallet.ExchangeRate")</th>
                <th>@await T.GetAsync("Wallet.Balance")</th>
                <th>@await T.GetAsync("Wallet.ReferenceId")</th>
                <th>@await T.GetAsync("Wallet.Remark")</th>
                <th>@await T.GetAsync("CreatedAt")</th>
              </tr>
            </thead>
            <tbody>
              @foreach (var txn in Model.PurchaseTransactions)
              {
                var dirBadge = txn.Direction == "in" ? "bg-success" : "bg-danger";
                var dirLabel = txn.Direction == "in" ? "IN" : "OUT";
                <tr>
                  <td><span class="badge bg-secondary">@txn.TxnType</span></td>
                  <td><span class="badge @dirBadge">@dirLabel</span></td>
                  <td>@txn.AmountUsd.ToString("F2")</td>
                  <td>@txn.DisplayCurrency @txn.DisplayAmount.ToString("F2")</td>
                  <td>@txn.ExchangeRate.ToString("F6")</td>
                  <td>@txn.BalanceAfter.ToString("F2")</td>
                  <td><small class="text-muted">@txn.ReferenceId</small></td>
                  <td><small>@txn.Remark</small></td>
                  <td><small>@txn.CreatedAt.ToUserLocalTime(Model.UserTimezone, AppConstants.DateTimeFormat)</small></td>
                </tr>
              }
              @if (!Model.PurchaseTransactions.Any())
              {
                <tr><td colspan="9" class="text-center text-muted py-3">—</td></tr>
              }
            </tbody>
          </table>
        </div>

        @if (Model.PurchaseTotalPages > 1)
        {
          <nav class="mt-3">
            <ul class="pagination pagination-sm justify-content-center mb-0">
              @for (var p = 1; p <= Model.PurchaseTotalPages; p++)
              {
                <li class="page-item @(p == Model.PurchasePage ? "active" : "")">
                  <a class="page-link"
                     asp-area="Admin" asp-page="/Members/Wallet"
                     asp-route-id="@Model.MemberId"
                     asp-route-cashPage="@Model.CashPage"
                     asp-route-purchasePage="@p"
                     asp-route-tab="purchase">@p</a>
                </li>
              }
            </ul>
          </nav>
        }
      </div>
    </div>
  </div>

</div>

@section VendorScripts {
  <script src="~/vendor/libs/sweetalert2/sweetalert2.dist.js"></script>
  <script src="~/vendor/libs/select2/select2.dist.js"></script>
}

@section PageScripts {
<script>
  var memberId = @Model.MemberId;
  var antiForgeryToken = $('#formAjax input[name="__RequestVerificationToken"]').val();
  var pageMsg = {
    updateSuccess: '@Html.Raw(Model.MsgUpdateSuccess)',
    saveError:     '@Html.Raw(Model.MsgSaveError)'
  };

  // Activate correct tab on load
  $(function () {
    var activeTab = '@Model.Tab';
    $('#tab-' + activeTab + '-link').tab('show');
  });

  function saveAdjustment(walletType, dirId, amountId, remarkId) {
    var direction = document.getElementById(dirId).value;
    var amount    = document.getElementById(amountId).value;
    var remark    = document.getElementById(remarkId).value;
    if (!amount || parseFloat(amount) <= 0) {
      Swal.fire({ icon: 'warning', text: 'Amount must be greater than zero.' });
      return;
    }
    $.post('?handler=Adjustment&id=' + memberId, {
      ddlAdjWalletType: walletType,
      ddlAdjDirection:  direction,
      txtAmountUsd:     amount,
      txtRemark:        remark,
      __RequestVerificationToken: antiForgeryToken
    }, function (res) {
      if (res.success) {
        Swal.fire({ icon: 'success', title: pageMsg.updateSuccess, timer: 1500, showConfirmButton: false })
          .then(function () { location.reload(); });
      } else {
        Swal.fire({ icon: 'error', text: res.message || pageMsg.saveError });
      }
    }).fail(function () {
      Swal.fire({ icon: 'error', text: pageMsg.saveError });
    });
  }

  // Select2 — Transfer target member
  $('#selectTransferTarget').select2({
    placeholder: '@await T.GetAsync("Members.SearchPlaceholder")',
    allowClear: true,
    minimumInputLength: 1,
    ajax: {
      url: '@memberSearchUrl',
      dataType: 'json',
      delay: 300,
      data: function (params) { return { term: params.term }; },
      processResults: function (data) { return { results: data }; }
    }
  }).on('select2:select', function (e) {
    document.getElementById('hdnTransferToMemberId').value = e.params.data.id;
  }).on('select2:unselect', function () {
    document.getElementById('hdnTransferToMemberId').value = '';
  });

  document.getElementById('btnTransfer').addEventListener('click', function () {
    var toId   = document.getElementById('hdnTransferToMemberId').value;
    var amount = document.getElementById('txtTransferAmount').value;
    var remark = document.getElementById('txtTransferRemark').value;
    if (!toId || !amount || parseFloat(amount) <= 0) {
      Swal.fire({ icon: 'warning', text: 'Please select a target member and enter a valid amount.' });
      return;
    }
    $.post('?handler=Transfer&id=' + memberId, {
      ToMemberId:       toId,
      txtTransferAmount: amount,
      txtTransferRemark: remark,
      __RequestVerificationToken: antiForgeryToken
    }, function (res) {
      if (res.success) {
        Swal.fire({ icon: 'success', title: pageMsg.updateSuccess, timer: 1500, showConfirmButton: false })
          .then(function () { location.reload(); });
      } else {
        Swal.fire({ icon: 'error', text: res.message || pageMsg.saveError });
      }
    }).fail(function () {
      Swal.fire({ icon: 'error', text: pageMsg.saveError });
    });
  });
</script>
}
