@page
@model MyApp.Areas.Admin.Pages.Members.EditModel
@{
  ViewData["title"] = await T.GetAsync("Members.Title.Edit");
  var avatarSrc = string.IsNullOrEmpty(Model.ProfileImage)
      ? "/images/default-avatar.png"
      : $"/uploads/member-profiles/{Model.ProfileImage}";
  var activatedBadge = Model.IsActivated ? "bg-success" : "bg-warning text-dark";
  var activatedLabel = Model.IsActivated
      ? await T.GetAsync("Members.Filter.Activated")
      : await T.GetAsync("Members.Filter.NotActivated");
  var statusBadge = Model.Status == StatusConstants.Active ? "bg-success" : "bg-secondary";
  var statusLabel = Model.Status == StatusConstants.Active
      ? await T.GetAsync("status.active")
      : await T.GetAsync("status.inactive");
}

@section VendorStyles {
  <link rel="stylesheet" href="~/vendor/libs/sweetalert2/sweetalert2.dist.css" />
  <link href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.2/cropper.min.css" rel="stylesheet" />
}

<div class="d-flex justify-content-between align-items-center py-3 mb-4">
  <h4 class="mb-0">@await T.GetAsync("Members.Title.Edit")</h4>
  <div>
    <a asp-area="Admin" asp-page="/Members/Manage" asp-route-id="@Model.MemberId"
       class="btn btn-outline-info me-2">
      <i class="ri ri-settings-3-line me-1"></i>@await T.GetAsync("Members.Title.Manage")
    </a>
    <a asp-area="Admin" asp-page="/Members/Index" class="btn btn-outline-secondary">
      <i class="ri ri-arrow-left-line me-1"></i>@await T.GetAsync("Btn.Back")
    </a>
  </div>
</div>

@* Read-only summary *@
<div class="card mb-4">
  <div class="card-body">
    <div class="d-flex align-items-center gap-4">
      <img src="@avatarSrc" style="width:72px;height:72px;object-fit:cover;border-radius:50%;" alt="" />
      <div>
        <h5 class="mb-1">@Model.Username</h5>
        <div class="d-flex gap-2 flex-wrap">
          <span class="badge @activatedBadge">@activatedLabel</span>
          <span class="badge @statusBadge">@statusLabel</span>
        </div>
        <small class="text-muted">
          @await T.GetAsync("Members.Sponsor"): @Model.SponsorUsername &nbsp;|&nbsp;
          @await T.GetAsync("Members.BinaryParent"): @Model.BinaryParentUsername (@(Model.BinaryPosition ?? "-")) &nbsp;|&nbsp;
          @await T.GetAsync("Members.CurrentRank"): @(Model.CurrentRankCode ?? "-") &nbsp;|&nbsp;
          @await T.GetAsync("Members.HighestRank"): @(Model.HighestRankCode ?? "-")
        </small>
      </div>
    </div>
  </div>
</div>

@* Profile edit form *@
<div class="card mb-4">
  <div class="card-header d-flex justify-content-between align-items-center">
    <h5 class="mb-0">@await T.GetAsync("Members.Tab.Personal")</h5>
    <a href="#" id="btnDelete" class="btn btn-outline-danger btn-sm ms-auto"
       data-id="@Model.MemberId">
      <i class="ri ri-delete-bin-line me-1"></i>@Model.LabelDelete
    </a>
  </div>
  <div class="card-body">
    <form method="post" asp-page-handler="Update" asp-route-id="@Model.MemberId" enctype="multipart/form-data">
      @Html.AntiForgeryToken()
      <div class="row g-3">
        <div class="col-md-6">
          <label class="form-label">@await T.GetAsync("Members.FullName") <span class="text-danger">*</span></label>
          <input type="text" name="txtFullName" class="form-control"
                 value="@Model.txtFullName" placeholder="@await T.GetAsync("Members.FullName")" />
        </div>
        <div class="col-md-3">
          <label class="form-label">@await T.GetAsync("Members.IdType") <span class="text-danger">*</span></label>
          <select name="ddlIdType" class="form-select" asp-items="@Model.ddlIdTypes">
            <option value="">--</option>
          </select>
        </div>
        <div class="col-md-3">
          <label class="form-label">@await T.GetAsync("Members.IdNo") <span class="text-danger">*</span></label>
          <input type="text" name="txtIdNo" class="form-control"
                 value="@Model.txtIdNo" placeholder="@await T.GetAsync("Members.IdNo")" />
        </div>
        <div class="col-md-6">
          <label class="form-label">@await T.GetAsync("Members.Email") <span class="text-danger">*</span></label>
          <input type="email" name="txtEmail" class="form-control"
                 value="@Model.txtEmail" placeholder="@await T.GetAsync("Members.Email")" />
        </div>
        <div class="col-md-6">
          <label class="form-label">@await T.GetAsync("Members.Phone") <span class="text-danger">*</span></label>
          <div class="input-group">
            <input type="text" name="txtPhoneCountryCode" class="form-control" style="max-width:90px"
                   value="@Model.txtPhoneCountryCode" placeholder="+60" />
            <input type="text" name="txtPhoneNumber" class="form-control"
                   value="@Model.txtPhoneNumber" placeholder="@await T.GetAsync("Members.Phone")" />
          </div>
        </div>
        <div class="col-md-6">
          <label class="form-label">@await T.GetAsync("Members.Country") <span class="text-danger">*</span></label>
          <select name="ddlCountryCode" class="form-select" asp-items="@Model.ddlCountry">
            <option value="">-- @await T.GetAsync("Members.Country") --</option>
          </select>
        </div>
        <div class="col-12">
          <label class="form-label">@await T.GetAsync("Members.AddressLine1") <span class="text-danger">*</span></label>
          <input type="text" name="txtAddressLine1" class="form-control"
                 value="@Model.txtAddressLine1" placeholder="@await T.GetAsync("Members.AddressLine1")" />
        </div>
        <div class="col-12">
          <label class="form-label">@await T.GetAsync("Members.AddressLine2")</label>
          <input type="text" name="txtAddressLine2" class="form-control"
                 value="@Model.txtAddressLine2" placeholder="@await T.GetAsync("Members.AddressLine2")" />
        </div>
        <div class="col-md-4">
          <label class="form-label">@await T.GetAsync("Members.City") <span class="text-danger">*</span></label>
          <input type="text" name="txtCity" class="form-control"
                 value="@Model.txtCity" placeholder="@await T.GetAsync("Members.City")" />
        </div>
        <div class="col-md-4">
          <label class="form-label">@await T.GetAsync("Members.State") <span class="text-danger">*</span></label>
          <input type="text" name="txtState" class="form-control"
                 value="@Model.txtState" placeholder="@await T.GetAsync("Members.State")" />
        </div>
        <div class="col-md-4">
          <label class="form-label">@await T.GetAsync("Members.Postcode") <span class="text-danger">*</span></label>
          <input type="text" name="txtPostcode" class="form-control"
                 value="@Model.txtPostcode" placeholder="@await T.GetAsync("Members.Postcode")" />
        </div>

        @* Bank *@
        <div class="col-12"><hr class="my-2" /><h6>@await T.GetAsync("Members.Tab.Bank")</h6></div>
        <div class="col-md-4">
          <label class="form-label">@await T.GetAsync("Members.BankName")</label>
          <input type="text" name="txtBankName" class="form-control"
                 value="@Model.txtBankName" placeholder="@await T.GetAsync("Members.BankName")" />
        </div>
        <div class="col-md-4">
          <label class="form-label">@await T.GetAsync("Members.BankAccountName")</label>
          <input type="text" name="txtBankAccountName" class="form-control"
                 value="@Model.txtBankAccountName" placeholder="@await T.GetAsync("Members.BankAccountName")" />
        </div>
        <div class="col-md-4">
          <label class="form-label">@await T.GetAsync("Members.BankAccountNo")</label>
          <input type="text" name="txtBankAccountNo" class="form-control"
                 value="@Model.txtBankAccountNo" placeholder="@await T.GetAsync("Members.BankAccountNo")" />
        </div>

        <div class="col-12 mt-2">
          <button type="submit" class="btn btn-primary">
            <i class="ri ri-save-line me-1"></i>@await T.GetAsync("Btn.Save")
          </button>
        </div>
      </div>
    </form>

    <hr class="my-4" />

    @* Profile image upload *@
    <h6 class="mb-3">@await T.GetAsync("Members.ProfileImage")</h6>
    <div class="d-flex align-items-start gap-3 mb-3">
      <img id="currentAvatar" src="@avatarSrc" style="width:80px;height:80px;object-fit:cover;border-radius:50%;" alt="" />
      <div>
        <form method="post" asp-page-handler="UploadImage" asp-route-id="@Model.MemberId"
              enctype="multipart/form-data" id="formUploadImage">
          @Html.AntiForgeryToken()
          <input type="file" id="fileProfileImageEdit" name="fileProfileImage"
                 class="form-control mb-2" accept=".jpg,.jpeg,.png" style="max-width:300px;" />
          <div id="cropContainerEdit" style="display:none; max-width:300px;" class="mb-2">
            <img id="cropPreviewEdit" src="" style="max-width:100%;" />
          </div>
          <button type="button" id="btnUploadImage" class="btn btn-sm btn-outline-primary" style="display:none;">
            <i class="ri ri-upload-line me-1"></i>@await T.GetAsync("Btn.Upload")
          </button>
        </form>
      </div>
    </div>

    @* Audit *@
    <hr class="my-4" />
    <div class="row g-3">
      <div class="col-md-6">
        <label class="form-label text-muted small">@await T.GetAsync("CreatedBy")</label>
        <p class="mb-0">@Model.CreatedBy</p>
      </div>
      <div class="col-md-6">
        <label class="form-label text-muted small">@await T.GetAsync("CreatedAt")</label>
        <p class="mb-0">@Model.CreatedAt.ToUserLocalTime(Model.UserTimezone, AppConstants.DateTimeFormat)</p>
      </div>
      <div class="col-md-6">
        <label class="form-label text-muted small">@await T.GetAsync("UpdatedBy")</label>
        <p class="mb-0">@Model.UpdatedBy</p>
      </div>
      <div class="col-md-6">
        <label class="form-label text-muted small">@await T.GetAsync("UpdatedAt")</label>
        <p class="mb-0">@Model.UpdatedAt.ToUserLocalTime(Model.UserTimezone, AppConstants.DateTimeFormat)</p>
      </div>
    </div>
  </div>
</div>

@* Hidden antiforgery form for delete AJAX *@
<form id="formAjax" method="post">
  @Html.AntiForgeryToken()
</form>

@section VendorScripts {
  <script src="~/vendor/libs/sweetalert2/sweetalert2.dist.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.2/cropper.min.js"></script>
}

@section PageScripts {
<script>
  var pageMsg = {
    deleteConfirmTitle: '@Html.Raw(Model.MsgDeleteConfirmTitle)',
    deleteConfirmText:  '@Html.Raw(Model.MsgDeleteConfirmText)',
    deleteConfirmBtn:   '@Html.Raw(Model.MsgDeleteConfirmBtn)',
    cancelBtn:          '@Html.Raw(Model.MsgCancelBtn)',
    deleteSuccess:      '@Html.Raw(Model.MsgDeleteSuccess)',
    deleteError:        '@Html.Raw(Model.MsgDeleteError)'
  };

  document.addEventListener("DOMContentLoaded", function () {
    var messageType = '@Model.AlertMessageType';
    if (messageType !== '') {
      Swal.fire({
        icon: messageType,
        title: @Html.Raw(Json.Serialize(Model.AlertMessageTitle)),
        text: @Html.Raw(Json.Serialize(Model.AlertMessageContent))
      });
    }
  });

  // Soft delete
  document.getElementById('btnDelete').addEventListener('click', function (e) {
    e.preventDefault();
    var memberId = this.getAttribute('data-id');
    Swal.fire({
      title: pageMsg.deleteConfirmTitle,
      text:  pageMsg.deleteConfirmText,
      icon:  'warning',
      showCancelButton: true,
      confirmButtonText: pageMsg.deleteConfirmBtn,
      cancelButtonText:  pageMsg.cancelBtn,
      confirmButtonColor: '#dc3545'
    }).then(function (result) {
      if (result.isConfirmed) {
        $.post('?handler=SoftDelete&id=' + memberId, {
          __RequestVerificationToken: $('#formAjax input[name="__RequestVerificationToken"]').val()
        }, function (data) {
          if (data.success) {
            Swal.fire({ icon: 'success', title: pageMsg.deleteSuccess, timer: 1500, showConfirmButton: false })
              .then(function () { window.location.href = '@Url.Page("/Members/Index", new { area = "Admin" })'; });
          } else {
            Swal.fire({ icon: 'error', text: data.message || pageMsg.deleteError });
          }
        }).fail(function () {
          Swal.fire({ icon: 'error', text: pageMsg.deleteError });
        });
      }
    });
  });

  // Profile image crop + upload
  var cropperEdit;
  document.getElementById('fileProfileImageEdit').addEventListener('change', function (e) {
    var file = e.target.files[0];
    if (!file) return;
    var reader = new FileReader();
    reader.onload = function (ev) {
      var container = document.getElementById('cropContainerEdit');
      var img       = document.getElementById('cropPreviewEdit');
      img.src = ev.target.result;
      container.style.display = 'block';
      document.getElementById('btnUploadImage').style.display = 'inline-block';
      if (cropperEdit) cropperEdit.destroy();
      cropperEdit = new Cropper(img, { aspectRatio: 1, viewMode: 1, autoCropArea: 1 });
    };
    reader.readAsDataURL(file);
  });

  document.getElementById('btnUploadImage').addEventListener('click', function () {
    if (!cropperEdit) return;
    cropperEdit.getCroppedCanvas({ width: 400, height: 400 }).toBlob(function (blob) {
      var formData = new FormData(document.getElementById('formUploadImage'));
      formData.set('fileProfileImage', blob, 'profile.jpg');
      $.ajax({
        url: document.getElementById('formUploadImage').action,
        type: 'POST',
        data: formData,
        processData: false,
        contentType: false,
        success: function (data) {
          if (data.success) {
            document.getElementById('currentAvatar').src = '/uploads/member-profiles/' + data.filename + '?t=' + Date.now();
            document.getElementById('cropContainerEdit').style.display = 'none';
            document.getElementById('btnUploadImage').style.display = 'none';
            Swal.fire({ icon: 'success', title: data.message, timer: 1500, showConfirmButton: false });
          } else {
            Swal.fire({ icon: 'error', text: data.message });
          }
        }
      });
    }, 'image/jpeg');
  });
</script>
}
