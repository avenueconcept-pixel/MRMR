@page
@model MyApp.Areas.Admin.Pages.Menus.IndexModel
@{
  ViewData["title"] = await T.GetAsync("Menu.PageTitle");

  // Build tree from ParentId relationships (DB uses L1→L2→L3, not L0→L1→L2)
  var roots         = Model.AllMenus.Where(m => m.ParentId == null).OrderBy(m => m.SortOrder).ToList();
  var rootIdSet     = roots.Select(r => r.Id).ToHashSet();
  var children      = Model.AllMenus
      .Where(m => m.ParentId.HasValue && rootIdSet.Contains(m.ParentId.Value))
      .OrderBy(m => m.SortOrder).ToList();
  var childIdSet    = children.Select(c => c.Id).ToHashSet();
  var grandchildren = Model.AllMenus
      .Where(m => m.ParentId.HasValue && childIdSet.Contains(m.ParentId.Value))
      .OrderBy(m => m.SortOrder).ToList();
}

@section VendorStyles {
  <link rel="stylesheet" href="~/vendor/libs/sweetalert2/sweetalert2.dist.css" />
}

@* Hidden form supplies antiforgery token for AJAX calls *@
<form id="formAjax" method="post">
  @Html.AntiForgeryToken()
</form>

<div class="d-flex justify-content-between align-items-center py-3 mb-4">
  <h4 class="mb-0">@await T.GetAsync("Menu.PageTitle")</h4>
  <div class="d-flex gap-2">
    <button id="btnSaveOrder" class="btn btn-success d-none" onclick="saveSortOrder()">
      <i class="ri ri-save-line me-1"></i>@Model.LblSaveOrder
    </button>
    <a asp-area="Admin" asp-page="/Menus/Create" class="btn btn-primary">
      <i class="ri ri-add-line me-1"></i>@await T.GetAsync("Menu.AddMenu")
    </a>
  </div>
</div>

<div class="alert alert-info alert-dismissible fade show py-2 mb-3" role="alert">
  <i class="ri ri-drag-move-line me-1"></i>@await T.GetAsync("Menu.DragHint")
  <button type="button" class="btn-close py-2" data-bs-dismiss="alert"></button>
</div>

<div class="card">
  <div class="card-body p-0">
    <div id="menuTree">

      @* Root-level items (ParentId = null) *@
      <ul class="sortable-list list-unstyled mb-0" data-level="1" data-parent-id="">
        @foreach (var root in roots)
        {
          var rootChildren = children.Where(c => c.ParentId == root.Id).ToList();
          <li class="menu-row menu-parent @(root.Status == StatusConstants.Deleted ? "opacity-50" : "")"
              data-id="@root.Id" data-level="1" data-parent-id="">
            <div class="d-flex align-items-center px-3 py-2 border-bottom">
              <span class="drag-handle me-2 text-muted" style="cursor:grab;">
                <i class="ri ri-drag-move-line"></i>
              </span>
              @if (!string.IsNullOrEmpty(root.MenuIcon))
              {
                <i class="ri @root.MenuIcon me-2 text-primary"></i>
              }
              <span class="fw-semibold flex-grow-1">@root.MenuName</span>
              @if (!string.IsNullOrEmpty(root.MenuUrl))
              {
                <span class="text-muted small me-2 font-monospace">@root.MenuUrl</span>
              }
              @await Html.PartialAsync("_MenuStatusBadge", root.Status)
              @await Html.PartialAsync("_MenuActions", new ViewDataDictionary(ViewData)
              {
                { "menu",  root  },
                { "model", Model }
              })
            </div>
            <ul class="sortable-list list-unstyled mb-0 ps-4"
                data-level="2" data-parent-id="@root.Id">
              @foreach (var child in rootChildren)
              {
                var myGrandchildren = grandchildren.Where(gc => gc.ParentId == child.Id).ToList();
                <li class="menu-row menu-child @(child.Status == StatusConstants.Deleted ? "opacity-50" : "")"
                    data-id="@child.Id" data-level="2" data-parent-id="@root.Id">
                  <div class="d-flex align-items-center px-3 py-2 border-bottom">
                    <span class="drag-handle me-2 text-muted" style="cursor:grab;">
                      <i class="ri ri-drag-move-line"></i>
                    </span>
                    @if (!string.IsNullOrEmpty(child.MenuIcon))
                    {
                      <i class="ri @child.MenuIcon me-2 text-secondary"></i>
                    }
                    <span class="flex-grow-1 small">@child.MenuName</span>
                    @if (!string.IsNullOrEmpty(child.MenuUrl))
                    {
                      <span class="text-muted small me-2 font-monospace">@child.MenuUrl</span>
                    }
                    @await Html.PartialAsync("_MenuStatusBadge", child.Status)
                    @await Html.PartialAsync("_MenuActions", new ViewDataDictionary(ViewData)
                    {
                      { "menu",  child },
                      { "model", Model }
                    })
                  </div>
                  @if (myGrandchildren.Any())
                  {
                    <ul class="sortable-list list-unstyled mb-0 ps-5"
                        data-level="3" data-parent-id="@child.Id">
                      @foreach (var gc in myGrandchildren)
                      {
                        <li class="menu-row menu-leaf @(gc.Status == StatusConstants.Deleted ? "opacity-50" : "")"
                            data-id="@gc.Id" data-level="3" data-parent-id="@child.Id">
                          <div class="d-flex align-items-center px-3 py-2 border-bottom">
                            <span class="drag-handle me-2 text-muted" style="cursor:grab;">
                              <i class="ri ri-drag-move-line"></i>
                            </span>
                            @if (!string.IsNullOrEmpty(gc.MenuIcon))
                            {
                              <i class="ri @gc.MenuIcon me-2 text-info"></i>
                            }
                            <span class="flex-grow-1 small">@gc.MenuName</span>
                            @if (!string.IsNullOrEmpty(gc.MenuUrl))
                            {
                              <span class="text-muted small me-2 font-monospace">@gc.MenuUrl</span>
                            }
                            @await Html.PartialAsync("_MenuStatusBadge", gc.Status)
                            @await Html.PartialAsync("_MenuActions", new ViewDataDictionary(ViewData)
                            {
                              { "menu",  gc    },
                              { "model", Model }
                            })
                          </div>
                        </li>
                      }
                    </ul>
                  }
                </li>
              }
            </ul>
          </li>
        }
      </ul>

    </div>
  </div>
</div>

@section VendorScripts {
  <script src="~/vendor/libs/sweetalert2/sweetalert2.dist.js"></script>
  <script src="~/vendor/libs/sortablejs/Sortable.min.js"></script>
}

@section PageScripts {
<script>
  var pageMsg = {
    deleteConfirmTitle: '@Html.Raw(Model.MsgDeleteConfirmTitle)',
    deleteConfirmText:  '@Html.Raw(Model.MsgDeleteConfirmText)',
    deleteConfirmBtn:   '@Html.Raw(Model.MsgDeleteConfirmBtn)',
    cancelBtn:          '@Html.Raw(Model.MsgCancelBtn)',
    deleteSuccess:      '@Html.Raw(Model.MsgDeleteSuccess)',
    deleteError:        '@Html.Raw(Model.MsgDeleteError)',
    sortSuccess:        '@Html.Raw(Model.MsgSortSuccess)',
    sortError:          '@Html.Raw(Model.MsgSortError)',
    lblDelete:          '@Html.Raw(Model.LblDelete)',
    lblCancel:          '@Html.Raw(Model.MsgCancelBtn)'
  };

  document.addEventListener("DOMContentLoaded", function () {
    var messageType = '@Model.AlertMessageType';
    if (messageType !== '') {
      Swal.fire({
        icon: messageType,
        title: @Html.Raw(Json.Serialize(Model.AlertMessageTitle)),
        text: @Html.Raw(Json.Serialize(Model.AlertMessageContent))
      });
    }
  });
</script>
<script src="~/js/admin-menus.js"></script>
}
