@page
@model MyApp.Areas.Admin.Pages.SystemSettings.Branding.IndexModel
@{
  ViewData["title"] = await T.GetAsync("SystemSettings.Branding.Title");
}

@section VendorStyles {
  <link rel="stylesheet" href="~/vendor/libs/sweetalert2/sweetalert2.dist.css" />
  <link rel="stylesheet" href="~/vendor/libs/quill/editor.dist.css" />
}

<div class="d-flex justify-content-between align-items-center py-3 mb-4">
  <div>
    <h4 class="mb-1">@await T.GetAsync("SystemSettings.Branding.Title")</h4>
    <small class="text-muted">@await T.GetAsync("SystemSettings.Branding.Subtitle")</small>
  </div>
</div>

<form method="post" asp-page-handler="Save" enctype="multipart/form-data">

  <div class="row g-4">

    @* ── Logo section ── *@
    <div class="col-lg-6">
      <div class="card h-100">
        <div class="card-body">
          <h5 class="card-title mb-4">@await T.GetAsync("SystemSettings.Branding.LogoSection")</h5>

          @if (!string.IsNullOrEmpty(Model.CurrentLogoPath))
          {
            <div class="mb-3 text-center">
              <p class="form-label text-muted small">@await T.GetAsync("SystemSettings.Branding.CurrentLogo")</p>
              <img id="imgLogoPreview" src="/uploads/branding/@Model.CurrentLogoPath"
                   style="height:120px;max-width:100%;object-fit:contain;border:1px solid #dee2e6;border-radius:8px;padding:8px;" />
            </div>
          }
          else
          {
            <div class="mb-3 text-center text-muted small">
              <i class="ri ri-image-line" style="font-size:3rem;"></i>
              <p>@await T.GetAsync("SystemSettings.Branding.NoLogo")</p>
              <img id="imgLogoPreview" src="" style="display:none;height:120px;max-width:100%;object-fit:contain;" />
            </div>
          }

          <div class="mb-3">
            <label class="form-label" for="fileLogoImage">
              @await T.GetAsync("SystemSettings.Branding.UploadLogo")
            </label>
            <input type="file" id="fileLogoImage" name="fileLogoImage"
                   class="form-control" accept=".jpg,.jpeg,.png"
                   data-crop="true"
                   data-crop-ratio="free"
                   data-crop-output-width="800"
                   data-crop-preview="#imgLogoPreview" />
            <div class="form-text">@await T.GetAsync("SystemSettings.Branding.LogoHint")</div>
          </div>
        </div>
      </div>
    </div>

    @* ── Favicon section ── *@
    <div class="col-lg-6">
      <div class="card h-100">
        <div class="card-body">
          <h5 class="card-title mb-4">@await T.GetAsync("SystemSettings.Branding.FaviconSection")</h5>

          @if (!string.IsNullOrEmpty(Model.CurrentFaviconPath))
          {
            <div class="mb-3 text-center">
              <p class="form-label text-muted small">@await T.GetAsync("SystemSettings.Branding.CurrentFavicon")</p>
              <img id="imgFaviconPreview" src="/uploads/branding/@Model.CurrentFaviconPath"
                   style="width:64px;height:64px;object-fit:contain;border:1px solid #dee2e6;border-radius:8px;padding:4px;" />
            </div>
          }
          else
          {
            <div class="mb-3 text-center text-muted small">
              <i class="ri ri-image-2-line" style="font-size:3rem;"></i>
              <p>@await T.GetAsync("SystemSettings.Branding.NoFavicon")</p>
              <img id="imgFaviconPreview" src="" style="display:none;width:64px;height:64px;object-fit:contain;" />
            </div>
          }

          <div class="mb-3">
            <label class="form-label" for="fileFaviconImage">
              @await T.GetAsync("SystemSettings.Branding.UploadFavicon")
            </label>
            <input type="file" id="fileFaviconImage" name="fileFaviconImage"
                   class="form-control" accept=".jpg,.jpeg,.png"
                   data-crop="true"
                   data-crop-ratio="1"
                   data-crop-output-width="64"
                   data-crop-output-height="64"
                   data-crop-preview="#imgFaviconPreview" />
            <div class="form-text">@await T.GetAsync("SystemSettings.Branding.FaviconHint")</div>
          </div>
        </div>
      </div>
    </div>

    @* ── System Names section ── *@
    <div class="col-12">
      <div class="card">
        <div class="card-body">
          <h5 class="card-title mb-4">@await T.GetAsync("SystemSettings.Branding.SystemNamesSection")</h5>

          <div class="row g-4">
            <div class="col-md-6">
              <label class="form-label" for="txtAdminSystemName">
                @await T.GetAsync("SystemSettings.Branding.AdminSystemName") <span class="text-danger">*</span>
              </label>
              <div class="form-floating form-floating-outline">
                <input type="text" id="txtAdminSystemName" name="txtAdminSystemName"
                       class="form-control" maxlength="100"
                       value="@Model.txtAdminSystemName"
                       placeholder="@await T.GetAsync("SystemSettings.Branding.AdminSystemName")" />
                <label for="txtAdminSystemName">@await T.GetAsync("SystemSettings.Branding.AdminSystemName")</label>
              </div>
            </div>

            <div class="col-md-6">
              <label class="form-label" for="txtCustomerSystemName">
                @await T.GetAsync("SystemSettings.Branding.CustomerSystemName") <span class="text-danger">*</span>
              </label>
              <div class="form-floating form-floating-outline">
                <input type="text" id="txtCustomerSystemName" name="txtCustomerSystemName"
                       class="form-control" maxlength="100"
                       value="@Model.txtCustomerSystemName"
                       placeholder="@await T.GetAsync("SystemSettings.Branding.CustomerSystemName")" />
                <label for="txtCustomerSystemName">@await T.GetAsync("SystemSettings.Branding.CustomerSystemName")</label>
              </div>
            </div>
          </div>

        </div>
      </div>
    </div>

  </div>

  @* ── Footer section ── *@
  <div class="col-12 mt-4">
    <div class="card">
      <div class="card-body">
        <h5 class="card-title mb-1">@await T.GetAsync("SystemSettings.Branding.FooterSection")</h5>
        <p class="text-muted small mb-4">@await T.GetAsync("SystemSettings.Branding.FooterHint")</p>

        <input type="hidden" name="txtAdminFooter"    id="hdnAdminFooter"    value="@Model.txtAdminFooter" />
        <input type="hidden" name="txtCustomerFooter" id="hdnCustomerFooter" value="@Model.txtCustomerFooter" />

        <ul class="nav nav-tabs mb-3" role="tablist">
          <li class="nav-item" role="presentation">
            <button class="nav-link active" data-bs-toggle="tab"
                    data-bs-target="#pane-admin-footer" type="button" role="tab">
              @await T.GetAsync("SystemSettings.Branding.AdminFooter")
            </button>
          </li>
          <li class="nav-item" role="presentation">
            <button class="nav-link" data-bs-toggle="tab"
                    data-bs-target="#pane-customer-footer" type="button" role="tab">
              @await T.GetAsync("SystemSettings.Branding.CustomerFooter")
            </button>
          </li>
        </ul>

        <div class="tab-content">
          <div class="tab-pane fade show active" id="pane-admin-footer" role="tabpanel">
            <div id="editorAdminFooter" style="height:150px;"></div>
          </div>
          <div class="tab-pane fade" id="pane-customer-footer" role="tabpanel">
            <div id="editorCustomerFooter" style="height:150px;"></div>
          </div>
        </div>

      </div>
    </div>
  </div>

  @* ── Save button ── *@
  <div class="d-flex justify-content-end mt-4">
    <button type="submit" class="btn btn-primary">
      <i class="ri ri-save-line me-1"></i>@await T.GetAsync("Btn.Save")
    </button>
  </div>

</form>

@section VendorScripts {
  <script src="~/vendor/libs/sweetalert2/sweetalert2.dist.js"></script>
  <script src="~/vendor/libs/quill/quill.dist.js"></script>
}

@section PageScripts {
<script>
  document.addEventListener("DOMContentLoaded", function () {
    var messageType = '@Model.AlertMessageType';
    if (messageType !== '') {
      Swal.fire({
        icon:  messageType,
        title: @Html.Raw(Json.Serialize(Model.AlertMessageTitle  ?? string.Empty)),
        text:  @Html.Raw(Json.Serialize(Model.AlertMessageContent ?? string.Empty))
      });
    }

    var editors = {};
    editors['admin']    = new Quill('#editorAdminFooter',    { theme: 'snow' });
    editors['customer'] = new Quill('#editorCustomerFooter', { theme: 'snow' });

    var adminVal = document.getElementById('hdnAdminFooter').value;
    if (adminVal) editors['admin'].clipboard.dangerouslyPasteHTML(adminVal);

    var customerVal = document.getElementById('hdnCustomerFooter').value;
    if (customerVal) editors['customer'].clipboard.dangerouslyPasteHTML(customerVal);

    document.querySelector('form').addEventListener('submit', function () {
      document.getElementById('hdnAdminFooter').value    = editors['admin'].root.innerHTML;
      document.getElementById('hdnCustomerFooter').value = editors['customer'].root.innerHTML;
    });
  });
</script>
}
