@page
@model MyApp.Areas.Admin.Pages.Wallets.AdjustmentsModel
@{
  ViewData["title"] = await T.GetAsync("Wallets.Adjustments.Title");
}

<div class="d-flex justify-content-between align-items-center py-3 mb-4">
  <h4 class="mb-0">@await T.GetAsync("Wallets.Adjustments.Title")</h4>
</div>

@* ── Filters ── *@
<div class="card mb-4">
  <div class="card-body">
    <form method="get" asp-area="Admin" asp-page="/Wallets/Adjustments">
      <div class="row g-2 align-items-end">
        <div class="col-md-2">
          <label class="form-label">@await T.GetAsync("Members.Username")</label>
          <input type="text" asp-for="FilterMemberUsername" class="form-control"
                 placeholder="@await T.GetAsync("Members.Username")" />
        </div>
        <div class="col-md-2">
          <label class="form-label">@await T.GetAsync("Wallets.Filter.WalletType")</label>
          <select asp-for="FilterWalletType" asp-items="@Model.ddlWalletType" class="form-select"></select>
        </div>
        <div class="col-md-2">
          <label class="form-label">@await T.GetAsync("Wallets.Filter.StaffUsername")</label>
          <input type="text" asp-for="FilterCreatedBy" class="form-control"
                 placeholder="@await T.GetAsync("Wallets.Filter.StaffUsername")" />
        </div>
        <div class="col-md-2">
          <label class="form-label">@await T.GetAsync("Filter.StartDate")</label>
          <input type="date" asp-for="FilterStartDate" class="form-control" />
        </div>
        <div class="col-md-2">
          <label class="form-label">@await T.GetAsync("Filter.EndDate")</label>
          <input type="date" asp-for="FilterEndDate" class="form-control" />
        </div>
        <div class="col-auto">
          <button type="submit" class="btn btn-primary">
            <i class="ri ri-search-line me-1"></i>@await T.GetAsync("Btn.Search")
          </button>
          <a asp-area="Admin" asp-page="/Wallets/Adjustments" class="btn btn-outline-secondary ms-1">
            @await T.GetAsync("Btn.Clear")
          </a>
        </div>
      </div>
    </form>
  </div>
</div>

<div class="card">
  <div class="card-body">
    <div class="table-responsive">
      <table class="table table-hover align-middle table-sm">
        <thead>
          <tr>
            <th>@await T.GetAsync("CreatedAt")</th>
            <th>@await T.GetAsync("Members.Username")</th>
            <th>@await T.GetAsync("Members.FullName")</th>
            <th>@await T.GetAsync("Wallets.Col.WalletType")</th>
            <th>@await T.GetAsync("Wallets.Direction")</th>
            <th class="text-end">@await T.GetAsync("Wallets.AmountUsd")</th>
            <th class="text-end">@await T.GetAsync("Wallets.DisplayAmount")</th>
            <th class="text-end">@await T.GetAsync("Wallets.Col.BalanceAfter")</th>
            <th>@await T.GetAsync("Wallets.Remark")</th>
            <th>@await T.GetAsync("Wallets.Col.PerformedBy")</th>
          </tr>
        </thead>
        <tbody>
          @foreach (var item in Model.Items)
          {
            string dirBadge    = item.Direction == WalletDirectionConstants.In ? "bg-success" : "bg-danger";
            string walletBadge = item.WalletType == WalletTypeConstants.Cash ? "bg-primary" : "bg-info";
            <tr>
              <td><small>@item.CreatedAt.ToUserLocalTime(Model.UserTimezone, AppConstants.DateTimeFormat)</small></td>
              <td>
                <a asp-area="Admin" asp-page="/Members/Wallet" asp-route-id="@item.MemberId">
                  @item.MemberUsername
                </a>
              </td>
              <td>@item.MemberFullName</td>
              <td><span class="badge @walletBadge">@item.WalletType</span></td>
              <td><span class="badge @dirBadge">@item.Direction.ToUpper()</span></td>
              <td class="text-end">@item.AmountUsd.ToString("N2")</td>
              <td class="text-end">@item.DisplayAmount.ToString("N2") <small class="text-muted">@item.DisplayCurrency</small></td>
              <td class="text-end">@item.BalanceAfter.ToString("N2")</td>
              <td><small>@(item.Remark ?? "—")</small></td>
              <td><small class="text-muted">@item.CreatedBy</small></td>
            </tr>
          }
          @if (!Model.Items.Any())
          {
            <tr><td colspan="10" class="text-center text-muted py-4">—</td></tr>
          }
        </tbody>
      </table>
    </div>

    @* ── Pagination ── *@
    @if (Model.TotalPages > 1)
    {
      <nav class="mt-3">
        <ul class="pagination pagination-sm justify-content-center mb-0">
          @for (var p = 1; p <= Model.TotalPages; p++)
          {
            <li class="page-item @(p == Model.CurrentPage ? "active" : "")">
              <a class="page-link"
                 asp-area="Admin" asp-page="/Wallets/Adjustments"
                 asp-route-currentPage="@p"
                 asp-route-filterMemberUsername="@Model.FilterMemberUsername"
                 asp-route-filterWalletType="@Model.FilterWalletType"
                 asp-route-filterCreatedBy="@Model.FilterCreatedBy"
                 asp-route-filterStartDate="@Model.FilterStartDate"
                 asp-route-filterEndDate="@Model.FilterEndDate">@p</a>
            </li>
          }
        </ul>
      </nav>
      <p class="text-muted small text-center mt-2">
        @await T.GetAsync("Pagination.Showing") @((Model.CurrentPage - 1) * Model.PageSize + 1)–@(Math.Min(Model.CurrentPage * Model.PageSize, Model.TotalCount)) @await T.GetAsync("Pagination.Of") @Model.TotalCount
      </p>
    }
  </div>
</div>
