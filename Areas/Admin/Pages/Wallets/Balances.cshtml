@page
@model MyApp.Areas.Admin.Pages.Wallets.BalancesModel
@{
  ViewData["title"] = await T.GetAsync("Wallets.Balances.Title");
}

<div class="d-flex justify-content-between align-items-center py-3 mb-4">
  <h4 class="mb-0">@await T.GetAsync("Wallets.Balances.Title")</h4>
</div>

@* ── Filters ── *@
<div class="card mb-4">
  <div class="card-body">
    <form method="get" asp-area="Admin" asp-page="/Wallets/Balances">
      <div class="row g-2 align-items-end">
        <div class="col-md-3">
          <label class="form-label">@await T.GetAsync("Members.Username")</label>
          <input type="text" asp-for="FilterUsername" class="form-control"
                 placeholder="@await T.GetAsync("Members.Username")" />
        </div>
        <div class="col-md-3">
          <label class="form-label">@await T.GetAsync("Country")</label>
          <select asp-for="FilterCountryCode" asp-items="@Model.ddlCountry" class="form-select"></select>
        </div>
        <div class="col-auto">
          <button type="submit" class="btn btn-primary">
            <i class="ri ri-search-line me-1"></i>@await T.GetAsync("Btn.Search")
          </button>
          <a asp-area="Admin" asp-page="/Wallets/Balances" class="btn btn-outline-secondary ms-1">
            @await T.GetAsync("Btn.Clear")
          </a>
        </div>
      </div>
    </form>
  </div>
</div>

<div class="card">
  <div class="card-body">
    <div class="table-responsive">
      <table id="tblMemberBalances" class="table table-hover align-middle">
        <thead>
          <tr>
            <th>@await T.GetAsync("Members.Username")</th>
            <th>@await T.GetAsync("Members.FullName")</th>
            <th>@await T.GetAsync("Country")</th>
            <th>@await T.GetAsync("Wallets.Filter.CurrencyCode")</th>
            <th class="text-end">@await T.GetAsync("Wallets.Type.Cash")</th>
            <th class="text-end">@await T.GetAsync("Wallets.Type.Purchase")</th>
            <th class="text-end">@await T.GetAsync("Wallets.Col.TotalBalance")</th>
            <th>@await T.GetAsync("UpdatedAt")</th>
          </tr>
        </thead>
        <tbody>
          @foreach (var item in Model.Items)
          {
            <tr>
              <td>
                <a asp-area="Admin" asp-page="/Members/Wallet" asp-route-id="@item.MemberId">
                  @item.Username
                </a>
              </td>
              <td>@item.FullName</td>
              <td>@item.CountryCode</td>
              <td><span class="badge bg-label-secondary">@item.CurrencyCode</span></td>
              <td class="text-end">@item.CashBalance.ToString("F2")</td>
              <td class="text-end">@item.PurchaseBalance.ToString("F2")</td>
              <td class="text-end fw-semibold">@((item.CashBalance + item.PurchaseBalance).ToString("F2"))</td>
              <td><small class="text-muted">@item.UpdatedAt.ToUserLocalTime(Model.UserTimezone, AppConstants.DateTimeFormat)</small></td>
            </tr>
          }
          @if (!Model.Items.Any())
          {
            <tr><td colspan="8" class="text-center text-muted py-4">—</td></tr>
          }
        </tbody>
      </table>
    </div>
  </div>
</div>

@section PageScripts {
<script>
  $(document).ready(function () {
    $('#tblMemberBalances').DataTable({
      pageLength: 25,
      order: [[4, 'desc']]
    });
  });
</script>
}
