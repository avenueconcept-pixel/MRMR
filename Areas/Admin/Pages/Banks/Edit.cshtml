@page "{bankCode}"
@model MyApp.Areas.Admin.Pages.Banks.EditModel
@{
  ViewData["title"] = await T.GetAsync("Bank.EditTitle");
}

@section VendorStyles {
  <link rel="stylesheet" href="~/vendor/libs/sweetalert2/sweetalert2.dist.css" />
}

<div class="d-flex justify-content-between align-items-center py-3 mb-4">
  <h4 class="mb-0">@await T.GetAsync("Bank.EditTitle") — <span class="text-muted">@Model.BankCode</span></h4>
  <a asp-area="Admin" asp-page="/Banks/Index" class="btn btn-outline-secondary">
    <i class="ri ri-arrow-left-line me-1"></i> @await T.GetAsync("BackToList")
  </a>
</div>

<div class="card">
  <div class="card-body">
    <form method="post" asp-page-handler="Update">

      <div class="row g-4">
        <div class="col-md-6">
          <label class="form-label">@await T.GetAsync("BankCode")</label>
          <input type="text" class="form-control" value="@Model.BankCode" readonly />
        </div>
        <div class="col-md-6">
          <label class="form-label" for="ddlCountryCode">
            @await T.GetAsync("Country") <span class="text-danger">*</span>
          </label>
          <select asp-for="ddlCountryCode" class="form-select" asp-items="@Model.CountryOptions"></select>
        </div>
        <div class="col-md-6">
          <label class="form-label" for="txtSwiftCode">@await T.GetAsync("SwiftCode")</label>
          <input type="text" id="txtSwiftCode" name="txtSwiftCode" class="form-control"
                 maxlength="20" value="@Model.txtSwiftCode"
                 placeholder="@await T.GetAsync("Bank.SwiftCodePlaceholder")" />
        </div>
        <div class="col-md-6">
          <label class="form-label" for="txtLocalCode">@await T.GetAsync("LocalCode")</label>
          <input type="text" id="txtLocalCode" name="txtLocalCode" class="form-control"
                 maxlength="20" value="@Model.txtLocalCode"
                 placeholder="@await T.GetAsync("Bank.LocalCodePlaceholder")" />
        </div>
        <div class="col-md-6">
          <label class="form-label" for="txtWebsite">@await T.GetAsync("Website")</label>
          <input type="text" id="txtWebsite" name="txtWebsite" class="form-control"
                 maxlength="200" value="@Model.txtWebsite"
                 placeholder="@await T.GetAsync("Bank.WebsitePlaceholder")" />
        </div>
        <div class="col-md-6">
          <label class="form-label" for="txtLogo">@await T.GetAsync("Logo")</label>
          <input type="text" id="txtLogo" name="txtLogo" class="form-control"
                 maxlength="200" value="@Model.txtLogo"
                 placeholder="@await T.GetAsync("Bank.LogoPlaceholder")" />
        </div>
        <div class="col-md-6">
          <label class="form-label" for="ddlStatus">@await T.GetAsync("Status")</label>
          <select asp-for="ddlStatus" class="form-select" asp-items="@Model.StatusOptions"></select>
        </div>
      </div>

      <hr class="my-4" />
      <h6 class="mb-3">@await T.GetAsync("Bank.NameTranslations")</h6>

      <div class="row g-4">
        @for (int i = 0; i < Model.TranslationInputs.Count; i++)
        {
          var nameInput  = Model.TranslationInputs[i];
          var shortInput = Model.ShortNameInputs.Count > i ? Model.ShortNameInputs[i] : null;
          <div class="col-md-12">
            <div class="row g-3">
              <div class="col-md-6">
                <label class="form-label" for="txtName_@nameInput.LanguageCode">
                  @await T.GetAsync("BankName") (@nameInput.Label)
                </label>
                <input type="text" id="txtName_@nameInput.LanguageCode" name="txtName_@nameInput.LanguageCode"
                       class="form-control" value="@nameInput.Value" placeholder="@nameInput.Placeholder" />
              </div>
              <div class="col-md-6">
                <label class="form-label" for="txtShortName_@nameInput.LanguageCode">
                  @await T.GetAsync("ShortName") (@nameInput.Label)
                </label>
                <input type="text" id="txtShortName_@nameInput.LanguageCode" name="txtShortName_@nameInput.LanguageCode"
                       class="form-control" value="@shortInput?.Value"
                       placeholder="@(shortInput?.Placeholder ?? string.Empty)" />
              </div>
            </div>
          </div>
        }
      </div>

      <div class="mt-4 d-flex gap-2">
        <button type="submit" class="btn btn-primary">@await T.GetAsync("SaveChanges")</button>
        <a asp-area="Admin" asp-page="/Banks/Index" class="btn btn-outline-secondary">@await T.GetAsync("Cancel")</a>
        <a href="#" id="btnDelete" class="btn btn-outline-danger ms-auto" data-code="@Model.BankCode">
          <i class="ri ri-delete-bin-line me-1"></i>@Model.LabelDelete
        </a>
      </div>

    </form>

    <hr class="my-4" />
    <div class="row g-3">
      <div class="col-md-6">
        <label class="form-label text-muted small">@await T.GetAsync("CreatedBy")</label>
        <p class="mb-0">@Model.CreatedBy</p>
      </div>
      <div class="col-md-6">
        <label class="form-label text-muted small">@await T.GetAsync("CreatedAt")</label>
        <p class="mb-0">@Model.CreatedAt.ToUserLocalTime(Model.UserTimezone, AppConstants.DateTimeFormat)</p>
      </div>
      <div class="col-md-6">
        <label class="form-label text-muted small">@await T.GetAsync("UpdatedBy")</label>
        <p class="mb-0">@Model.UpdatedBy</p>
      </div>
      <div class="col-md-6">
        <label class="form-label text-muted small">@await T.GetAsync("UpdatedAt")</label>
        <p class="mb-0">@Model.UpdatedAt.ToUserLocalTime(Model.UserTimezone, AppConstants.DateTimeFormat)</p>
      </div>
    </div>
  </div>
</div>

@* Hidden form supplies antiforgery token for AJAX calls *@
<form id="formAjax" method="post">
  @Html.AntiForgeryToken()
</form>

@section VendorScripts {
  <script src="~/vendor/libs/sweetalert2/sweetalert2.dist.js"></script>
}

@section PageScripts {
<script>
  var pageMsg = {
    deleteConfirmTitle: '@Html.Raw(Model.MsgDeleteConfirmTitle)',
    deleteConfirmText:  '@Html.Raw(Model.MsgDeleteConfirmText)',
    deleteConfirmBtn:   '@Html.Raw(Model.MsgDeleteConfirmBtn)',
    cancelBtn:          '@Html.Raw(Model.MsgCancelBtn)',
    deleteSuccess:      '@Html.Raw(Model.MsgDeleteSuccess)',
    deleteError:        '@Html.Raw(Model.MsgDeleteError)'
  };

  document.getElementById('btnDelete').addEventListener('click', function (e) {
    e.preventDefault();
    var code = this.getAttribute('data-code');
    Swal.fire({
      title: pageMsg.deleteConfirmTitle,
      text: pageMsg.deleteConfirmText,
      icon: 'warning',
      showCancelButton: true,
      confirmButtonText: pageMsg.deleteConfirmBtn,
      cancelButtonText: pageMsg.cancelBtn
    }).then(function (result) {
      if (result.isConfirmed) {
        $.post('?handler=SoftDelete&bankCode=' + encodeURIComponent(code), {
          __RequestVerificationToken: $('#formAjax input[name="__RequestVerificationToken"]').val()
        }, function (data) {
          if (data.success) {
            Swal.fire({ icon: 'success', title: pageMsg.deleteSuccess, timer: 1500, showConfirmButton: false })
              .then(function () { window.location.href = '@Url.Page(Routes.AdminBank)'; });
          } else {
            Swal.fire({ icon: 'error', text: data.message || pageMsg.deleteError });
          }
        }).fail(function () {
          Swal.fire({ icon: 'error', text: pageMsg.deleteError });
        });
      }
    });
  });

  document.addEventListener("DOMContentLoaded", function () {
    var messageType = '@Model.AlertMessageType';
    if (messageType !== '') {
      Swal.fire({
        icon: messageType,
        title: @Html.Raw(Json.Serialize(Model.AlertMessageTitle)),
        text: @Html.Raw(Json.Serialize(Model.AlertMessageContent))
      });
    }
  });
</script>
}
