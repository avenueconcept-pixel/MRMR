@page
@model MyApp.Areas.Admin.Pages.EmailTemplates.CreateModel
@{
  ViewData["title"] = await T.GetAsync("EmailTemplate.CreateTitle");
}

@section VendorStyles {
  <link rel="stylesheet" href="~/vendor/libs/sweetalert2/sweetalert2.dist.css" />
  <link rel="stylesheet" href="~/vendor/libs/quill/editor.css" />
}

<div class="d-flex justify-content-between align-items-center py-3 mb-4">
  <h4 class="mb-0">@await T.GetAsync("EmailTemplate.CreateTitle")</h4>
  <a asp-area="Admin" asp-page="/EmailTemplates/Index" class="btn btn-outline-secondary">
    <i class="ri ri-arrow-left-line me-1"></i>@await T.GetAsync("BackToList")
  </a>
</div>

<div class="card">
  <div class="card-body">
    <form method="post" asp-page-handler="Create">

      <div class="row g-3">

        @* Template Key *@
        <div class="col-md-6">
          <label class="form-label">
            @await T.GetAsync("EmailTemplate.TemplateKey") <span class="text-danger">*</span>
          </label>
          <input type="text" class="form-control" name="txtTemplateKey"
                 value="@Model.txtTemplateKey" list="templateKeyList" autocomplete="off"
                 placeholder="@await T.GetAsync("EmailTemplate.TemplateKeyHint")" />
          <datalist id="templateKeyList">
            @foreach (var key in Model.ExistingKeys)
            {
              <option value="@key" />
            }
          </datalist>
          <div class="form-text">@await T.GetAsync("EmailTemplate.TemplateKeyHint")</div>
        </div>

        @* Language *@
        <div class="col-md-6">
          <label class="form-label">
            @await T.GetAsync("Language") <span class="text-danger">*</span>
          </label>
          <select asp-for="ddlLanguageCode" class="form-select" asp-items="Model.LanguageOptions">
            <option value="">-- @await T.GetAsync("Language") --</option>
          </select>
        </div>

        @* Subject *@
        <div class="col-12">
          <label class="form-label">
            @await T.GetAsync("EmailTemplate.Subject") <span class="text-danger">*</span>
          </label>
          <input type="text" class="form-control" name="txtSubject" value="@Model.txtSubject" />
        </div>

        @* Body HTML — Quill editor *@
        <div class="col-12">
          <label class="form-label">
            @await T.GetAsync("EmailTemplate.BodyHtml") <span class="text-danger">*</span>
          </label>
          <div id="quillEditor" style="min-height: 300px;">@Html.Raw(Model.txtBodyHtml)</div>
          <input type="hidden" name="txtBodyHtml" id="txtBodyHtml" value="@Model.txtBodyHtml" />
        </div>

        @* Buttons *@
        <div class="col-12 d-flex gap-2">
          <button type="submit" class="btn btn-primary">
            <i class="ri ri-save-line me-1"></i>@await T.GetAsync("Save")
          </button>
          <a asp-area="Admin" asp-page="/EmailTemplates/Index" class="btn btn-outline-secondary">
            @await T.GetAsync("Cancel")
          </a>
        </div>

      </div>
    </form>
  </div>
</div>

@section VendorScripts {
  <script src="~/vendor/libs/sweetalert2/sweetalert2.dist.js"></script>
  <script src="~/vendor/libs/quill/quill.js"></script>
}

@section PageScripts {
<script>
  var quill = new Quill('#quillEditor', {
    theme: 'snow',
    modules: {
      toolbar: [
        [{ 'header': [1, 2, 3, false] }],
        ['bold', 'italic', 'underline', 'strike'],
        [{ 'color': [] }, { 'background': [] }],
        [{ 'list': 'ordered' }, { 'list': 'bullet' }],
        ['link'],
        ['clean']
      ]
    }
  });

  document.querySelector('form').addEventListener('submit', function () {
    document.getElementById('txtBodyHtml').value = quill.root.innerHTML;
  });

  document.addEventListener("DOMContentLoaded", function () {
    var messageType = '@Model.AlertMessageType';
    if (messageType !== '') {
      Swal.fire({
        icon: messageType,
        title: @Html.Raw(Json.Serialize(Model.AlertMessageTitle)),
        text: @Html.Raw(Json.Serialize(Model.AlertMessageContent))
      });
    }
  });
</script>
}
