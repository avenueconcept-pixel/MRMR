@page "{id:int}"
@model MyApp.Areas.Admin.Pages.EmailTemplates.EditModel
@{
  ViewData["title"] = await T.GetAsync("EmailTemplate.EditTitle");
}

@section VendorStyles {
  <link rel="stylesheet" href="~/vendor/libs/sweetalert2/sweetalert2.dist.css" />
  <link rel="stylesheet" href="~/vendor/libs/quill/editor.dist.css" />
}

<div class="d-flex justify-content-between align-items-center py-3 mb-4">
  <h4 class="mb-0">@await T.GetAsync("EmailTemplate.EditTitle") — <span class="text-muted">@Model.TemplateKey (@Model.LanguageCode)</span></h4>
  <a asp-area="Admin" asp-page="/EmailTemplates/Index" class="btn btn-outline-secondary">
    <i class="ri ri-arrow-left-line me-1"></i>@await T.GetAsync("BackToList")
  </a>
</div>

<div class="card">
  <div class="card-body">
    <form method="post" asp-page-handler="Update" asp-route-id="@Model.TemplateId">

      <div class="row g-3">

        @* Template Key — read-only *@
        <div class="col-md-6">
          <label class="form-label">@await T.GetAsync("EmailTemplate.TemplateKey")</label>
          <input type="text" class="form-control" value="@Model.TemplateKey" readonly />
        </div>

        @* Language Code — read-only *@
        <div class="col-md-6">
          <label class="form-label">@await T.GetAsync("Language")</label>
          <input type="text" class="form-control" value="@Model.LanguageCode" readonly />
        </div>

        @* Subject *@
        <div class="col-12">
          <label class="form-label">
            @await T.GetAsync("EmailTemplate.Subject") <span class="text-danger">*</span>
          </label>
          <input type="text" class="form-control" name="txtSubject" value="@Model.txtSubject" />
        </div>

        @* Body HTML — Quill *@
        <div class="col-12">
          <label class="form-label">
            @await T.GetAsync("EmailTemplate.BodyHtml") <span class="text-danger">*</span>
          </label>
          <div id="quillEditor" style="min-height: 300px;">@Html.Raw(Model.txtBodyHtml)</div>
          <input type="hidden" name="txtBodyHtml" id="txtBodyHtml" value="@Model.txtBodyHtml" />
        </div>

        @* Buttons *@
        <div class="col-12 d-flex gap-2">
          <button type="submit" class="btn btn-primary">
            <i class="ri ri-save-line me-1"></i>@await T.GetAsync("SaveChanges")
          </button>
          <a asp-area="Admin" asp-page="/EmailTemplates/Index" class="btn btn-outline-secondary">
            @await T.GetAsync("Cancel")
          </a>
          <a href="#" id="btnDelete" class="btn btn-outline-danger ms-auto"
             data-id="@Model.TemplateId">
            <i class="ri ri-delete-bin-line me-1"></i>@Model.LabelDelete
          </a>
        </div>

      </div>
    </form>

    <hr class="my-4" />
    <div class="row g-3">
      <div class="col-md-6">
        <label class="form-label text-muted small">@await T.GetAsync("CreatedBy")</label>
        <p class="mb-0">@Model.CreatedBy</p>
      </div>
      <div class="col-md-6">
        <label class="form-label text-muted small">@await T.GetAsync("CreatedAt")</label>
        <p class="mb-0">@Model.CreatedAt.ToUserLocalTime(Model.UserTimezone, AppConstants.DateTimeFormat)</p>
      </div>
      <div class="col-md-6">
        <label class="form-label text-muted small">@await T.GetAsync("UpdatedBy")</label>
        <p class="mb-0">@Model.UpdatedBy</p>
      </div>
      <div class="col-md-6">
        <label class="form-label text-muted small">@await T.GetAsync("UpdatedAt")</label>
        <p class="mb-0">@Model.UpdatedAt.ToUserLocalTime(Model.UserTimezone, AppConstants.DateTimeFormat)</p>
      </div>
    </div>
  </div>
</div>

@* Hidden form for AJAX antiforgery token *@
<form id="formAjax" method="post">
  @Html.AntiForgeryToken()
</form>

@section VendorScripts {
  <script src="~/vendor/libs/sweetalert2/sweetalert2.dist.js"></script>
  <script src="~/vendor/libs/quill/quill.dist.js"></script>
}

@section PageScripts {
<script>
  var pageMsg = {
    deleteConfirmTitle: '@Html.Raw(Model.MsgDeleteConfirmTitle)',
    deleteConfirmText:  '@Html.Raw(Model.MsgDeleteConfirmText)',
    deleteConfirmBtn:   '@Html.Raw(Model.MsgDeleteConfirmBtn)',
    cancelBtn:          '@Html.Raw(Model.MsgCancelBtn)',
    deleteSuccess:      '@Html.Raw(Model.MsgDeleteSuccess)',
    deleteError:        '@Html.Raw(Model.MsgDeleteError)'
  };

  var quill = new Quill('#quillEditor', {
    theme: 'snow',
    modules: {
      toolbar: [
        [{ 'header': [1, 2, 3, false] }],
        ['bold', 'italic', 'underline', 'strike'],
        [{ 'color': [] }, { 'background': [] }],
        [{ 'list': 'ordered' }, { 'list': 'bullet' }],
        ['link'],
        ['clean']
      ]
    }
  });

  document.querySelector('form').addEventListener('submit', function () {
    document.getElementById('txtBodyHtml').value = quill.root.innerHTML;
  });

  document.getElementById('btnDelete').addEventListener('click', function (e) {
    e.preventDefault();
    var id = this.getAttribute('data-id');
    Swal.fire({
      title: pageMsg.deleteConfirmTitle,
      text:  pageMsg.deleteConfirmText,
      icon:  'warning',
      showCancelButton:  true,
      confirmButtonText: pageMsg.deleteConfirmBtn,
      cancelButtonText:  pageMsg.cancelBtn,
      confirmButtonColor: '#dc3545'
    }).then(function (result) {
      if (!result.isConfirmed) return;
      $.post('?handler=SoftDelete&id=' + id, {
        __RequestVerificationToken: $('#formAjax input[name="__RequestVerificationToken"]').val()
      }, function (data) {
        if (data.success) {
          Swal.fire({ icon: 'success', title: pageMsg.deleteSuccess, timer: 1500, showConfirmButton: false })
            .then(function () { window.location.href = '@Url.Page(Routes.AdminEmailTemplate)'; });
        } else {
          Swal.fire({ icon: 'error', text: data.message || pageMsg.deleteError });
        }
      }).fail(function () {
        Swal.fire({ icon: 'error', text: pageMsg.deleteError });
      });
    });
  });

  document.addEventListener("DOMContentLoaded", function () {
    var messageType = '@Model.AlertMessageType';
    if (messageType !== '') {
      Swal.fire({
        icon: messageType,
        title: @Html.Raw(Json.Serialize(Model.AlertMessageTitle)),
        text: @Html.Raw(Json.Serialize(Model.AlertMessageContent))
      });
    }
  });
</script>
}
