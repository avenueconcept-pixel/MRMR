@page
@model MyApp.Areas.Admin.Pages.MRMR.Documents.IndexModel
@using MyApp.Constants.MRMR
@{
    ViewData["Title"]      = $"Documents — {Model.Application?.ApplicationId}";
    ViewData["ActiveMenu"] = "MRMR_APPLICATIONS";
    var app = Model.Application!;
}

<div class="row">
    <div class="col s12">
        <a asp-area="Admin" asp-page="/MRMR/Applications/Detail" asp-route-id="@app.Id"
           class="btn-flat grey-text waves-effect mb-2">
            <i class="ri ri-arrow-left-line me-1"></i>Back to @app.ApplicationId
        </a>

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="card-panel green lighten-4 mb-2">
                <i class="ri ri-checkbox-circle-line me-1 green-text"></i>@TempData["SuccessMessage"]
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="card-panel red lighten-4 mb-2">
                <i class="ri ri-error-warning-line me-1 red-text"></i>@TempData["ErrorMessage"]
            </div>
        }

        <h5 class="mb-3">
            <i class="ri ri-folder-line me-1"></i>Document Verification — @app.ApplicationId
            <small class="grey-text">(@app.ApplicationType)</small>
        </h5>

        @{
            var verified = Model.Documents.Count(d => d.VerificationStatus == nameof(DocumentVerificationStatus.Verified));
            var rejected = Model.Documents.Count(d => d.VerificationStatus == nameof(DocumentVerificationStatus.Rejected));
            var pending  = Model.Documents.Count(d => d.VerificationStatus == nameof(DocumentVerificationStatus.Pending));
        }

        @if (!Model.Documents.Any())
        {
            <div class="card">
                <div class="card-content center-align py-4">
                    <i class="ri ri-inbox-line grey-text" style="font-size:3rem;"></i>
                    <p class="grey-text">No documents uploaded for this application.</p>
                </div>
            </div>
        }
        else
        {
            <div class="mb-3">
                <span class="chip green white-text"><i class="ri ri-checkbox-circle-line me-1"></i>Verified: @verified</span>
                <span class="chip red white-text ms-1"><i class="ri ri-close-circle-line me-1"></i>Rejected: @rejected</span>
                <span class="chip orange white-text ms-1"><i class="ri ri-time-line me-1"></i>Pending: @pending</span>
            </div>

            @foreach (var doc in Model.Documents)
            {
                var badgeClass = doc.VerificationStatus switch
                {
                    nameof(DocumentVerificationStatus.Verified) => "green white-text",
                    nameof(DocumentVerificationStatus.Rejected) => "red white-text",
                    _                                           => "orange white-text"
                };
                var ext   = System.IO.Path.GetExtension(doc.FilePath).ToLowerInvariant();
                var isPdf = ext == ".pdf";

                <div class="card">
                    <div class="card-content">
                        <div class="row valign-wrapper mb-0">

                            @* Doc info *@
                            <div class="col s12 m5">
                                <p class="mb-0">
                                    <strong>@doc.DocumentType.Replace("_", " ").ToUpperInvariant()</strong>
                                    @if (doc.IsRequired)
                                    {
                                        <span class="badge red white-text ms-1" style="float:none; font-size:0.7rem;">Required</span>
                                    }
                                </p>
                                <p class="grey-text mb-0" style="font-size:0.85rem;">@doc.OriginalFilename</p>
                                <p class="grey-text mb-0" style="font-size:0.8rem;">
                                    Uploaded: @doc.UploadedAt.ToString("dd MMM yyyy HH:mm")
                                    @if (doc.FileSizeBytes.HasValue)
                                    {
                                        <span class="ms-2">(@((doc.FileSizeBytes.Value / 1024.0).ToString("N0")) KB)</span>
                                    }
                                </p>
                                @if (!string.IsNullOrEmpty(doc.AdminRemarks))
                                {
                                    <p class="red-text mb-0" style="font-size:0.85rem;">
                                        <i class="ri ri-error-warning-line me-1"></i>@doc.AdminRemarks
                                    </p>
                                }
                            </div>

                            @* Preview *@
                            <div class="col s12 m3 center-align">
                                @if (isPdf)
                                {
                                    <a href="/@doc.FilePath" target="_blank"
                                       class="btn-small blue darken-3 waves-effect waves-light">
                                        <i class="ri ri-file-pdf-line me-1"></i>Open PDF
                                    </a>
                                }
                                else
                                {
                                    <a href="/@doc.FilePath" target="_blank">
                                        <img src="/@doc.FilePath" alt="@doc.DocumentType"
                                             style="max-height:80px; max-width:120px; border:1px solid #ddd; border-radius:4px; object-fit:cover;" />
                                    </a>
                                }
                            </div>

                            @* Status + actions *@
                            <div class="col s12 m4 right-align">
                                <span class="badge @badgeClass mb-2" style="float:none; display:inline-block;">
                                    @doc.VerificationStatus
                                </span>
                                @if (doc.VerifiedAt.HasValue)
                                {
                                    <p class="grey-text mb-1" style="font-size:0.8rem;">
                                        @doc.VerifiedAt.Value.ToString("dd MMM yyyy HH:mm")
                                    </p>
                                }

                                @* Verify button *@
                                @if (doc.VerificationStatus != nameof(DocumentVerificationStatus.Verified))
                                {
                                    <form method="post" asp-page-handler="Verify"
                                          id="verifyForm_@doc.Id" style="display:inline;">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="ApplicationId" value="@app.Id" />
                                        <input type="hidden" name="DocumentId"    value="@doc.Id" />
                                        <button type="button"
                                                class="btn-small green darken-2 waves-effect waves-light"
                                                onclick="confirmVerify(@doc.Id)">
                                            <i class="ri ri-checkbox-circle-line me-1"></i>Verify
                                        </button>
                                    </form>
                                }

                                @* Reject button *@
                                @if (doc.VerificationStatus != nameof(DocumentVerificationStatus.Rejected))
                                {
                                    <button type="button"
                                            class="btn-small red darken-2 waves-effect waves-light ms-1"
                                            onclick="openRejectModal(@doc.Id)">
                                        <i class="ri ri-close-circle-line me-1"></i>Reject
                                    </button>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>

@* Reject modal *@
<div id="rejectModal" class="modal">
    <div class="modal-content">
        <h5>Reject Document</h5>
        <p class="grey-text">Enter the reason for rejection. This will be shown to the applicant.</p>
        <form method="post" asp-page-handler="Reject" id="rejectForm">
            @Html.AntiForgeryToken()
            <input type="hidden" name="ApplicationId" value="@app.Id" />
            <input type="hidden" name="DocumentId"    id="rejectDocumentId" value="" />
            <div class="input-field">
                <textarea id="txtRejectRemarks" name="RejectRemarks"
                          class="materialize-textarea" rows="3"></textarea>
                <label for="txtRejectRemarks">Rejection Remarks *</label>
            </div>
        </form>
    </div>
    <div class="modal-footer">
        <a href="#!" class="modal-close btn-flat waves-effect grey-text">Cancel</a>
        <button type="button" onclick="submitReject()"
                class="btn red darken-2 waves-effect waves-light ms-2">
            <i class="ri ri-close-circle-line me-1"></i>Confirm Reject
        </button>
    </div>
</div>

@section PageScripts {
<script>
var rejectModal;
document.addEventListener('DOMContentLoaded', function () {
    rejectModal = M.Modal.init(document.getElementById('rejectModal'));
});

function confirmVerify(docId) {
    Swal.fire({
        title:              'Verify Document?',
        text:               'Mark this document as verified.',
        icon:               'question',
        showCancelButton:   true,
        confirmButtonText:  'Yes, Verify',
        cancelButtonText:   'Cancel',
        confirmButtonColor: '#388e3c'
    }).then(function (result) {
        if (result.isConfirmed) {
            document.getElementById('verifyForm_' + docId).submit();
        }
    });
}

function openRejectModal(docId) {
    document.getElementById('rejectDocumentId').value = docId;
    document.getElementById('txtRejectRemarks').value = '';
    M.updateTextFields();
    rejectModal.open();
}

function submitReject() {
    var remarks = document.getElementById('txtRejectRemarks').value.trim();
    if (!remarks) {
        M.toast({ html: 'Remarks are required.', classes: 'red' });
        return;
    }
    document.getElementById('rejectForm').submit();
}
</script>
}
