@page
@model MyApp.Areas.Admin.Pages.MRMR.Documents.IndexModel
@using MyApp.Constants.MRMR
@{
    ViewData["Title"]      = "Document Verification";
    ViewData["ActiveMenu"] = "MRMR_DOCUMENTS";
}

<div class="d-flex justify-content-between align-items-center py-3 mb-4">
    <h4 class="mb-0"><i class="ri ri-folder-check-line me-1"></i>Document Verification</h4>
</div>

@* Filter bar *@
<div class="card mb-3">
    <div class="card-body py-2">
        <form method="get" class="row align-items-end g-2">
            <div class="col-12 col-md-3">
                <label class="form-label">Verification Status</label>
                <select name="FilterStatus" class="form-select">
                    @if (string.IsNullOrEmpty(Model.FilterStatus))
                    {
                        <option value="" selected>All Statuses</option>
                    }
                    else
                    {
                        <option value="">All Statuses</option>
                    }
                    @foreach (var stype in Model.AllStatuses)
                    {
                        if (Model.FilterStatus == stype)
                        {
                            <option value="@stype" selected>@stype</option>
                        }
                        else
                        {
                            <option value="@stype">@stype</option>
                        }
                    }
                </select>
            </div>
            <div class="col-12 col-md-4">
                <label class="form-label">Search</label>
                <input type="text" name="Search" value="@Model.Search"
                       class="form-control" placeholder="Application ID, applicant name, doc type..." />
            </div>
            <div class="col-12 col-md-auto">
                <button type="submit" class="btn btn-primary">
                    <i class="ri ri-search-line me-1"></i>Search
                </button>
                <a asp-page="/MRMR/Documents/Index" class="btn btn-outline-secondary ms-1">Clear</a>
            </div>
        </form>
    </div>
</div>

@* Summary badges *@
@{
    var totalCount    = Model.Documents.Count;
    var pendingCount  = Model.Documents.Count(d => d.VerificationStatus == nameof(DocumentVerificationStatus.Pending));
    var verifiedCount = Model.Documents.Count(d => d.VerificationStatus == nameof(DocumentVerificationStatus.Verified));
    var rejectedCount = Model.Documents.Count(d => d.VerificationStatus == nameof(DocumentVerificationStatus.Rejected));
}
<div class="mb-3">
    <span class="badge bg-secondary"><i class="ri ri-file-list-line me-1"></i>Total: @totalCount</span>
    <span class="badge bg-warning text-dark ms-1"><i class="ri ri-time-line me-1"></i>Pending: @pendingCount</span>
    <span class="badge bg-success ms-1"><i class="ri ri-checkbox-circle-line me-1"></i>Verified: @verifiedCount</span>
    <span class="badge bg-danger ms-1"><i class="ri ri-close-circle-line me-1"></i>Rejected: @rejectedCount</span>
</div>

@if (!Model.Documents.Any())
{
    <div class="card">
        <div class="card-body text-center py-4">
            <i class="ri ri-inbox-line text-muted" style="font-size:3rem;"></i>
            <p class="text-muted mt-2 mb-0">No documents found.</p>
        </div>
    </div>
}
else
{
    <div class="card">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>Application</th>
                        <th>Applicant</th>
                        <th>Document Type</th>
                        <th>Filename</th>
                        <th>Uploaded</th>
                        <th>Status</th>
                        <th class="text-end">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var doc in Model.Documents)
                    {
                        var badgeClass = doc.VerificationStatus switch
                        {
                            nameof(DocumentVerificationStatus.Verified) => "bg-success",
                            nameof(DocumentVerificationStatus.Rejected) => "bg-danger",
                            _                                           => "bg-warning text-dark"
                        };
                        <tr>
                            <td>
                                <a asp-area="Admin"
                                   asp-page="/MRMR/Applications/Detail"
                                   asp-route-id="@doc.ApplicationId"
                                   class="text-decoration-none fw-semibold">
                                    @doc.Application?.ApplicationId
                                </a>
                            </td>
                            <td>@doc.Application?.Registrant?.FullName</td>
                            <td>@doc.DocumentType.Replace("_", " ")</td>
                            <td class="text-muted" style="font-size:0.85rem;">@doc.OriginalFilename</td>
                            <td style="font-size:0.85rem;">@doc.UploadedAt.ToString("dd MMM yyyy")</td>
                            <td><span class="badge @badgeClass">@doc.VerificationStatus</span></td>
                            <td class="text-end">
                                <a asp-area="Admin"
                                   asp-page="/MRMR/Documents/Detail"
                                   asp-route-applicationId="@doc.ApplicationId"
                                   class="btn btn-sm btn-outline-primary">
                                    <i class="ri ri-eye-line me-1"></i>Review
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
