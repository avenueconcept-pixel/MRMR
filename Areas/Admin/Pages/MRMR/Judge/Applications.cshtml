@page
@model MyApp.Areas.Admin.Pages.MRMR.Judge.ApplicationsModel
@using MyApp.Constants.MRMR
@{
    ViewData["Title"]      = $"Evaluate — {Model.Category?.Name}";
    ViewData["ActiveMenu"] = "JUDGE_DASHBOARD";
    var submitted  = Model.Evaluations.Values.Count(e => e?.Status == nameof(EvaluationStatus.Submitted));
    var draft      = Model.Evaluations.Values.Count(e => e?.Status == nameof(EvaluationStatus.Draft));
    var notStarted = Model.Applications.Count - submitted - draft;
}

<div class="d-flex justify-content-between align-items-center py-3 mb-4">
    <h4 class="mb-0">
        <i class="ri ri-trophy-line me-1"></i>@Model.Category?.Name
        <small class="text-muted fs-6">(@Model.Category?.CategoryType)</small>
    </h4>
    <a asp-page="Dashboard" class="btn btn-outline-secondary">
        <i class="ri ri-arrow-left-line me-1"></i>Back to Dashboard
    </a>
</div>

<div class="mb-3">
    <span class="badge bg-success"><i class="ri ri-checkbox-circle-line me-1"></i>Submitted: @submitted</span>
    <span class="badge bg-warning text-dark ms-1"><i class="ri ri-edit-line me-1"></i>Draft: @draft</span>
    <span class="badge bg-secondary ms-1"><i class="ri ri-time-line me-1"></i>Not Started: @notStarted</span>
</div>

@if (!Model.Applications.Any())
{
    <div class="card">
        <div class="card-body text-center py-4">
            <i class="ri ri-inbox-line text-muted" style="font-size:3rem;"></i>
            <p class="text-muted">No submitted applications in this category yet.</p>
        </div>
    </div>
}
else
{
    <div class="card">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover table-striped align-middle">
                    <thead>
                        <tr>
                            <th>Application ID</th>
                            <th>Applicant</th>
                            <th>Submitted</th>
                            <th>Evaluation Status</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var app in Model.Applications)
                        {
                            var eval       = Model.Evaluations.GetValueOrDefault(app.Id);
                            var evalStatus = eval?.Status ?? nameof(EvaluationStatus.NotStarted);
                            var badgeClass = evalStatus switch
                            {
                                nameof(EvaluationStatus.Submitted) => "bg-success",
                                nameof(EvaluationStatus.Draft)     => "bg-warning text-dark",
                                _                                  => "bg-secondary"
                            };
                            var btnLabel = evalStatus switch
                            {
                                nameof(EvaluationStatus.Submitted) => "View",
                                nameof(EvaluationStatus.Draft)     => "Continue",
                                _                                  => "Start"
                            };
                            var btnClass = evalStatus == nameof(EvaluationStatus.Submitted)
                                ? "btn btn-sm btn-secondary"
                                : "btn btn-sm btn-primary";

                            <tr>
                                <td><strong>@app.ApplicationId</strong></td>
                                <td>
                                    @app.Registrant.FullName
                                    @if (app.ApplicationType == "Corporate" && !string.IsNullOrEmpty(app.Registrant.CompanyName))
                                    {
                                        <br /><small class="text-muted">@app.Registrant.CompanyName</small>
                                    }
                                </td>
                                <td>@(app.SubmittedAt?.ToString("dd MMM yyyy") ?? "-")</td>
                                <td>
                                    <span class="badge @badgeClass">@evalStatus</span>
                                    @if (eval?.SubmittedAt != null)
                                    {
                                        <br /><small class="text-muted">@eval.SubmittedAt.Value.ToString("dd MMM yyyy")</small>
                                    }
                                </td>
                                <td>
                                    <a asp-page="Evaluate"
                                       asp-route-applicationId="@app.Id"
                                       asp-route-categoryId="@Model.CategoryId"
                                       class="@btnClass">
                                        <i class="ri ri-edit-line me-1"></i>@btnLabel
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}
