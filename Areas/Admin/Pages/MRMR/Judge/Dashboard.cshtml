@page
@model MyApp.Areas.Admin.Pages.MRMR.Judge.DashboardModel
@{
    ViewData["Title"]      = "Judge Dashboard";
    ViewData["ActiveMenu"] = "JUDGE_DASHBOARD";
}

<div class="d-flex justify-content-between align-items-center py-3 mb-4">
    <h4 class="mb-0"><i class="ri ri-user-star-line me-1"></i>Welcome, @Model.CurrentUsername</h4>
</div>

<p class="text-muted mb-4">Your assigned award categories are listed below.</p>

@if (!Model.Assignments.Any())
{
    <div class="card">
        <div class="card-body text-center py-4">
            <i class="ri ri-trophy-line text-muted" style="font-size:3rem;"></i>
            <p class="text-muted">You have no category assignments yet. Please contact the administrator.</p>
        </div>
    </div>
}
else
{
    <div class="row">
        @foreach (var a in Model.Assignments)
        {
            var count = Model.AppCounts.GetValueOrDefault(a.AwardCategoryId, 0);
            <div class="col-12 col-md-6 col-lg-4">
                <div class="card mb-3">
                    <div class="card-body">
                        <h5 class="card-title">
                            <i class="ri ri-trophy-line me-1 text-primary"></i>
                            @a.AwardCategory.Name
                        </h5>
                        <p class="text-muted mb-1">
                            Type: @a.AwardCategory.CategoryType
                        </p>
                        <p class="mb-0">
                            <span style="font-size:2rem; font-weight:700;" class="text-primary">
                                @count
                            </span>
                            <span class="text-muted"> application(s) to evaluate</span>
                        </p>
                    </div>
                    <div class="card-footer">
                        <a asp-page="Applications"
                           asp-route-categoryId="@a.AwardCategoryId"
                           class="btn btn-sm btn-primary w-100">
                            <i class="ri ri-arrow-right-line me-1"></i>Start Evaluation
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
}
