@page
@model MyApp.Areas.Admin.Pages.MRMR.Judge.DashboardModel
@{
    ViewData["Title"]      = "Judge Dashboard";
    ViewData["ActiveMenu"] = "JUDGE_DASHBOARD";
}

<div class="row">
    <div class="col s12">
        <h5 class="mb-1">
            <i class="ri ri-user-star-line me-1"></i>Welcome, @Model.CurrentUsername
        </h5>
        <p class="grey-text mb-4">Your assigned award categories are listed below.</p>

        @if (!Model.Assignments.Any())
        {
            <div class="card">
                <div class="card-content center-align py-4">
                    <i class="ri ri-trophy-line grey-text" style="font-size:3rem;"></i>
                    <p class="grey-text">You have no category assignments yet. Please contact the administrator.</p>
                </div>
            </div>
        }
        else
        {
            <div class="row">
                @foreach (var a in Model.Assignments)
                {
                    var count = Model.AppCounts.GetValueOrDefault(a.AwardCategoryId, 0);
                    <div class="col s12 m6 l4">
                        <div class="card hoverable">
                            <div class="card-content">
                                <span class="card-title" style="font-size:1rem;">
                                    <i class="ri ri-trophy-line me-1 blue-text text-darken-3"></i>
                                    @a.AwardCategory.Name
                                </span>
                                <p class="grey-text mb-1">
                                    Type: @a.AwardCategory.CategoryType
                                </p>
                                <p class="mb-0">
                                    <span style="font-size:2rem; font-weight:700;" class="blue-text text-darken-3">
                                        @count
                                    </span>
                                    <span class="grey-text"> application(s) to evaluate</span>
                                </p>
                            </div>
                            <div class="card-action">
                                <a asp-page="Applications"
                                   asp-route-categoryId="@a.AwardCategoryId"
                                   class="blue-text text-darken-3">
                                    <i class="ri ri-arrow-right-line me-1"></i>Start Evaluation
                                </a>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>
