@page
@model MyApp.Areas.Admin.Pages.MRMR.Judges.IndexModel
@using MyApp.Constants
@{
    ViewData["Title"]      = "Judge Management";
    ViewData["ActiveMenu"] = "MRMR_JUDGES";
}

<div class="d-flex justify-content-between align-items-center py-3 mb-4">
    <h4 class="mb-0"><i class="ri ri-user-star-line me-1"></i>Judge Management</h4>
    <a asp-page="Create" class="btn btn-primary">
        <i class="ri ri-add-line me-1"></i>Add Judge
    </a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success mb-3">
        <i class="ri ri-checkbox-circle-line me-1"></i>@TempData["SuccessMessage"]
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger mb-3">
        <i class="ri ri-error-warning-line me-1"></i>@TempData["ErrorMessage"]
    </div>
}

@if (!Model.Judges.Any())
{
    <div class="card">
        <div class="card-body text-center py-4">
            <i class="ri ri-user-star-line text-muted" style="font-size:3rem;"></i>
            <p class="text-muted">No judges yet. Add the first judge.</p>
        </div>
    </div>
}
else
{
    <div class="card">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover table-striped align-middle">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Username</th>
                            <th>Email</th>
                            <th>Status</th>
                            <th>Assigned Categories</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var judge in Model.Judges)
                        {
                            var assignments = Model.Assignments.GetValueOrDefault(judge.Id, []);
                            <tr>
                                <td><strong>@judge.FullName</strong></td>
                                <td>@judge.Username</td>
                                <td>@judge.Email</td>
                                <td>
                                    @if (judge.Status == StatusConstants.Active)
                                    {
                                        <span class="badge bg-success">@judge.Status</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">@judge.Status</span>
                                    }
                                </td>
                                <td>
                                    @if (!assignments.Any())
                                    {
                                        <span class="text-muted">None</span>
                                    }
                                    else
                                    {
                                        @foreach (var a in assignments)
                                        {
                                            <span class="badge bg-secondary me-1 mb-1" style="font-size:0.75rem;">
                                                @a.AwardCategory.Name
                                                <form method="post" asp-page-handler="RemoveAssignment"
                                                      id="removeAssignmentForm_@a.Id"
                                                      style="display:inline;" class="ms-1">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="assignmentId" value="@a.Id" />
                                                    <button type="button"
                                                            class="btn-close btn-close-white"
                                                            style="font-size:0.4rem; vertical-align:middle;"
                                                            onclick="confirmRemoveAssignment(@a.Id)"
                                                            title="Remove" aria-label="Remove">
                                                    </button>
                                                </form>
                                            </span>
                                        }
                                    }
                                </td>
                                <td>
                                    @if (judge.Status == StatusConstants.Active)
                                    {
                                        <form method="post" asp-page-handler="DeactivateJudge"
                                              id="deactivateJudgeForm_@judge.Id" style="display:inline;">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="judgeId" value="@judge.Id" />
                                            <button type="button"
                                                    class="btn btn-sm btn-danger"
                                                    onclick="confirmDeactivateJudge(@judge.Id)">
                                                <i class="ri ri-user-unfollow-line me-1"></i>Deactivate
                                            </button>
                                        </form>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

@section PageScripts {
<script>
function confirmRemoveAssignment(id) {
    Swal.fire({
        title:              'Remove Assignment?',
        text:               'This judge will no longer be assigned to this category.',
        icon:               'warning',
        showCancelButton:   true,
        confirmButtonText:  'Yes, Remove',
        cancelButtonText:   'Cancel',
        confirmButtonColor: '#c62828'
    }).then(function (result) {
        if (result.isConfirmed) {
            document.getElementById('removeAssignmentForm_' + id).submit();
        }
    });
}

function confirmDeactivateJudge(id) {
    Swal.fire({
        title:              'Deactivate Judge?',
        text:               'This will deactivate the judge account and remove all category assignments.',
        icon:               'warning',
        showCancelButton:   true,
        confirmButtonText:  'Yes, Deactivate',
        cancelButtonText:   'Cancel',
        confirmButtonColor: '#c62828'
    }).then(function (result) {
        if (result.isConfirmed) {
            document.getElementById('deactivateJudgeForm_' + id).submit();
        }
    });
}
</script>
}
