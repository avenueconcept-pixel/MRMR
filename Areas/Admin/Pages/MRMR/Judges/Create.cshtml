@page
@model MyApp.Areas.Admin.Pages.MRMR.Judges.CreateModel
@{
    ViewData["Title"]      = "Add Judge";
    ViewData["ActiveMenu"] = "MRMR_JUDGES";
}

<div class="d-flex justify-content-between align-items-center py-3 mb-4">
    <h4 class="mb-0"><i class="ri ri-user-star-line me-1"></i>Add Judge</h4>
    <a asp-page="Index" class="btn btn-outline-secondary">
        <i class="ri ri-arrow-left-line me-1"></i>Back to Judges
    </a>
</div>

@if (!string.IsNullOrEmpty(Model.AlertMessageContent))
{
    <div class="alert alert-danger mb-3">
        <i class="ri ri-error-warning-line me-1"></i>@Model.AlertMessageContent
    </div>
}

<div class="row">
    <div class="col-12 col-md-8 offset-md-2">
        <form method="post" asp-page-handler="Create">
            @Html.AntiForgeryToken()

            <div class="card mb-3">
                <div class="card-body">
                    <h5 class="card-title">Judge Account</h5>
                    <p class="text-muted" style="font-size:0.85rem;">
                        A temporary password will be generated and emailed to the judge.
                        They must change it on first login.
                    </p>

                    <div class="row g-3">
                        <div class="col-12">
                            <label class="form-label" for="FullName">Full Name *</label>
                            <input type="text" id="FullName" name="FullName" class="form-control"
                                   value="@Model.FullName" required />
                        </div>
                        <div class="col-12 col-md-6">
                            <label class="form-label" for="Email">Email *</label>
                            <input type="email" id="Email" name="Email" class="form-control"
                                   value="@Model.Email" required />
                        </div>
                        <div class="col-12 col-md-6">
                            <label class="form-label" for="Username">Username *</label>
                            <input type="text" id="Username" name="Username" class="form-control"
                                   value="@Model.Username" required />
                        </div>
                    </div>
                </div>
            </div>

            @if (Model.Categories.Any())
            {
                <div class="card mb-3">
                    <div class="card-body">
                        <h5 class="card-title">
                            Assign to Categories <small class="text-muted">(optional)</small>
                        </h5>
                        <div class="row">
                            @foreach (var cat in Model.Categories)
                            {
                                <div class="col-12 col-md-6">
                                    <div class="form-check mb-2">
                                        @if (Model.CategoryIds.Contains(cat.Id))
                                        {
                                            <input type="checkbox" class="form-check-input"
                                                   id="cat_@cat.Id" name="CategoryIds" value="@cat.Id" checked />
                                        }
                                        else
                                        {
                                            <input type="checkbox" class="form-check-input"
                                                   id="cat_@cat.Id" name="CategoryIds" value="@cat.Id" />
                                        }
                                        <label class="form-check-label" for="cat_@cat.Id">
                                            @cat.Name
                                            <small class="text-muted">(@cat.CategoryType)</small>
                                        </label>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }

            <div class="d-flex justify-content-end mb-3 gap-2">
                <a asp-page="Index" class="btn btn-outline-secondary">Cancel</a>
                <button type="submit" class="btn btn-primary">
                    <i class="ri ri-user-add-line me-1"></i>Create Judge
                </button>
            </div>
        </form>
    </div>
</div>
