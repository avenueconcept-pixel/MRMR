@page
@model MyApp.Areas.Admin.Pages.MRMR.Judges.CreateModel
@{
    ViewData["Title"]      = "Add Judge";
    ViewData["ActiveMenu"] = "MRMR_JUDGES";
}

<div class="row">
    <div class="col s12 m8 offset-m2">
        <a asp-page="Index" class="btn-flat grey-text waves-effect mb-2">
            <i class="ri ri-arrow-left-line me-1"></i>Back to Judges
        </a>
        <h5 class="mb-3"><i class="ri ri-user-star-line me-1"></i>Add Judge</h5>

        @if (!string.IsNullOrEmpty(Model.AlertMessageContent))
        {
            <div class="card-panel red lighten-4 mb-2">
                <i class="ri ri-error-warning-line me-1 red-text"></i>@Model.AlertMessageContent
            </div>
        }

        <form method="post" asp-page-handler="Create">
            @Html.AntiForgeryToken()

            <div class="card">
                <div class="card-content">
                    <span class="card-title" style="font-size:1rem;">Judge Account</span>
                    <p class="grey-text" style="font-size:0.85rem;">
                        A temporary password will be generated and emailed to the judge.
                        They must change it on first login.
                    </p>

                    <div class="row">
                        <div class="input-field col s12">
                            <input type="text" id="FullName" name="FullName"
                                   value="@Model.FullName" required />
                            <label for="FullName">Full Name *</label>
                        </div>
                        <div class="input-field col s12 m6">
                            <input type="email" id="Email" name="Email"
                                   value="@Model.Email" required />
                            <label for="Email">Email *</label>
                        </div>
                        <div class="input-field col s12 m6">
                            <input type="text" id="Username" name="Username"
                                   value="@Model.Username" required />
                            <label for="Username">Username *</label>
                        </div>
                    </div>
                </div>
            </div>

            @if (Model.Categories.Any())
            {
                <div class="card">
                    <div class="card-content">
                        <span class="card-title" style="font-size:1rem;">
                            Assign to Categories <small class="grey-text">(optional)</small>
                        </span>
                        <div class="row mb-0">
                            @foreach (var cat in Model.Categories)
                            {
                                <div class="col s12 m6">
                                    <label>
                                        @if (Model.CategoryIds.Contains(cat.Id))
                                        {
                                            <input type="checkbox" name="CategoryIds" value="@cat.Id" checked />
                                        }
                                        else
                                        {
                                            <input type="checkbox" name="CategoryIds" value="@cat.Id" />
                                        }
                                        <span>
                                            @cat.Name
                                            <small class="grey-text">(@cat.CategoryType)</small>
                                        </span>
                                    </label>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }

            <div class="right-align mb-3">
                <a asp-page="Index" class="btn-flat grey-text waves-effect me-2">Cancel</a>
                <button type="submit" class="btn blue darken-3 waves-effect waves-light">
                    <i class="ri ri-user-add-line me-1"></i>Create Judge
                </button>
            </div>
        </form>
    </div>
</div>
