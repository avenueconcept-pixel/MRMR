@page
@model MyApp.Areas.Admin.Pages.MRMR.Payments.DetailModel
@using MyApp.Constants.MRMR
@using System.IO
@{
    ViewData["Title"]      = $"Payment — {Model.Payment?.InvoiceNo}";
    ViewData["ActiveMenu"] = "MRMR_PAYMENTS";
    var pay     = Model.Payment!;
    var app     = pay.Application;
    var reg     = app?.Registrant;
    bool pending = pay.Status == nameof(PaymentStatus.PendingVerification);
}

<div class="d-flex justify-content-between align-items-center py-3 mb-4">
    <h4 class="mb-0"><i class="ri ri-receipt-line me-1"></i>Payment — @pay.InvoiceNo</h4>
    <a asp-page="Index" class="btn btn-outline-secondary">
        <i class="ri ri-arrow-left-line me-1"></i>Back to Queue
    </a>
</div>

@if (!string.IsNullOrEmpty(Model.AlertMessageContent))
{
    <div class="alert @(Model.AlertMessageType == "success" ? "alert-success" : "alert-danger") mb-3">
        @Model.AlertMessageContent
    </div>
}

<div class="row">
    @* Left column — payment info + slip *@
    <div class="col-12 col-lg-7">

        <div class="card mb-3">
            <div class="card-body">
                @{
                    var badgeClass = pay.Status switch
                    {
                        nameof(PaymentStatus.Verified)            => "bg-success",
                        nameof(PaymentStatus.Rejected)            => "bg-danger",
                        nameof(PaymentStatus.PendingVerification) => "bg-warning text-dark",
                        _ => "bg-secondary"
                    };
                }
                <h5 class="card-title">
                    <i class="ri ri-receipt-line me-1"></i>@pay.InvoiceNo
                    <span class="badge @badgeClass ms-2">@pay.Status</span>
                </h5>

                <div class="table-responsive">
                    <table class="table table-striped align-middle mb-0">
                        <tbody>
                            <tr><td class="text-muted">Applicant</td><td><strong>@reg?.FullName</strong></td></tr>
                            <tr><td class="text-muted">Application ID</td><td>@app?.ApplicationId</td></tr>
                            <tr><td class="text-muted">Application Type</td><td>@app?.ApplicationType</td></tr>
                            <tr><td class="text-muted">Payment Type</td><td>@pay.PaymentType</td></tr>
                            <tr><td class="text-muted">Amount</td><td><strong>RM @pay.Amount.ToString("N2")</strong></td></tr>
                            <tr><td class="text-muted">Method</td><td>@pay.Method</td></tr>
                            <tr><td class="text-muted">Slip Uploaded</td><td>@(pay.SlipUploadedAt?.ToString("dd MMM yyyy, HH:mm") ?? "-")</td></tr>
                            @if (pay.Status == nameof(PaymentStatus.Verified) || pay.Status == nameof(PaymentStatus.Rejected))
                            {
                                <tr><td class="text-muted">Actioned At</td><td>@(pay.VerifiedAt?.ToString("dd MMM yyyy, HH:mm") ?? "-")</td></tr>
                            }
                            @if (!string.IsNullOrEmpty(pay.AdminRemarks))
                            {
                                <tr><td class="text-muted">Admin Remarks</td><td class="text-danger">@pay.AdminRemarks</td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        @* Payment slip preview *@
        @if (!string.IsNullOrEmpty(pay.SlipFilePath))
        {
            <div class="card mb-3">
                <div class="card-body">
                    <h5 class="card-title"><i class="ri ri-image-line me-1"></i>Payment Slip</h5>
                    @{
                        var ext = System.IO.Path.GetExtension(pay.SlipFilePath).ToLowerInvariant();
                    }
                    @if (ext == ".pdf")
                    {
                        <a href="/@pay.SlipFilePath" target="_blank" class="btn btn-primary">
                            <i class="ri ri-file-pdf-line me-1"></i>Open PDF Slip
                        </a>
                    }
                    else
                    {
                        <a href="/@pay.SlipFilePath" target="_blank">
                            <img src="/@pay.SlipFilePath" alt="Payment Slip"
                                 style="max-width:100%; border:1px solid #ddd; border-radius:4px;" />
                        </a>
                        <p class="text-muted mt-1"><small>Click image to open full size</small></p>
                    }
                </div>
            </div>
        }
    </div>

    @* Right column — approve/reject + audit log *@
    <div class="col-12 col-lg-5">

        @if (pending)
        {
            <div class="card mb-3">
                <div class="card-body">
                    <h5 class="card-title"><i class="ri ri-shield-check-line me-1"></i>Verification Action</h5>

                    @* Approve *@
                    <form method="post" asp-page-handler="Approve" class="mb-3">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="PaymentId" value="@pay.Id" />
                        <button type="button" onclick="confirmApprove()"
                                class="btn btn-success w-100">
                            <i class="ri ri-checkbox-circle-line me-1"></i>Approve Payment
                        </button>
                        <div id="approveForm" style="display:none;">
                            <button type="submit" id="approveSubmit"></button>
                        </div>
                    </form>

                    <hr class="mb-3" />

                    @* Reject *@
                    <form method="post" asp-page-handler="Reject" id="rejectForm">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="PaymentId" value="@pay.Id" />
                        <div class="mb-3">
                            <label class="form-label" for="txtRejectRemarks">Rejection Remarks *</label>
                            <textarea id="txtRejectRemarks" name="RejectRemarks"
                                      class="form-control" rows="3"
                                      placeholder="Reason for rejection (required)">@Model.RejectRemarks</textarea>
                        </div>
                        <button type="button" onclick="confirmReject()"
                                class="btn btn-danger w-100">
                            <i class="ri ri-close-circle-line me-1"></i>Reject Payment
                        </button>
                        <button type="submit" id="rejectSubmit" style="display:none;"></button>
                    </form>
                </div>
            </div>
        }

        @* Audit log *@
        <div class="card">
            <div class="card-body">
                <h5 class="card-title"><i class="ri ri-history-line me-1"></i>Audit Log</h5>
                @if (!pay.AuditLogs.Any())
                {
                    <p class="text-muted">No audit entries.</p>
                }
                else
                {
                    <ul class="list-group list-group-flush">
                        @foreach (var log in pay.AuditLogs)
                        {
                            <li class="list-group-item py-2 px-0">
                                <span class="badge @(log.Action.Contains("Approved") ? "bg-success" : log.Action.Contains("Rejected") ? "bg-danger" : "bg-primary") me-2" style="font-size:0.75rem;">
                                    @log.Action
                                </span>
                                <small class="text-muted">@log.PerformedAt.ToString("dd MMM yyyy HH:mm")</small>
                                @if (!string.IsNullOrEmpty(log.Remarks))
                                {
                                    <br /><small class="text-muted">@log.Remarks</small>
                                }
                            </li>
                        }
                    </ul>
                }
            </div>
        </div>
    </div>
</div>

@section PageScripts {
<script>
function confirmApprove() {
    Swal.fire({
        title:              'Approve Payment?',
        text:               'This will verify the payment and notify the applicant. This action cannot be undone.',
        icon:               'question',
        showCancelButton:   true,
        confirmButtonText:  'Yes, Approve',
        cancelButtonText:   'Cancel',
        confirmButtonColor: '#388e3c'
    }).then(function (result) {
        if (result.isConfirmed) {
            document.getElementById('approveSubmit').click();
        }
    });
}

function confirmReject() {
    var remarks = document.getElementById('txtRejectRemarks').value.trim();
    if (!remarks) {
        Swal.fire({ icon: 'warning', title: 'Remarks Required', text: 'Please enter a reason for rejection.' });
        return;
    }
    Swal.fire({
        title:              'Reject Payment?',
        text:               'The applicant will be notified with your remarks.',
        icon:               'warning',
        showCancelButton:   true,
        confirmButtonText:  'Yes, Reject',
        cancelButtonText:   'Cancel',
        confirmButtonColor: '#c62828'
    }).then(function (result) {
        if (result.isConfirmed) {
            document.getElementById('rejectSubmit').click();
        }
    });
}
</script>
}
