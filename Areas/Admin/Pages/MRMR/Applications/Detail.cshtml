@page "{id:int}"
@model MyApp.Areas.Admin.Pages.MRMR.Applications.DetailModel
@using MyApp.Constants.MRMR
@{
    ViewData["Title"]      = $"Application — {Model.Application?.ApplicationId}";
    ViewData["ActiveMenu"] = "MRMR_APPLICATIONS";
    var app = Model.Application!;
    var reg = app.Registrant;
}

<div class="d-flex justify-content-between align-items-center py-3 mb-4">
    <h4 class="mb-0"><i class="ri ri-file-list-3-line me-1"></i>Application — @app.ApplicationId</h4>
    <a asp-page="Index" class="btn btn-outline-secondary">
        <i class="ri ri-arrow-left-line me-1"></i>Back to List
    </a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success mb-3">
        <i class="ri ri-checkbox-circle-line me-1"></i>@TempData["SuccessMessage"]
    </div>
}
@if (!string.IsNullOrEmpty(Model.AlertMessageContent))
{
    <div class="alert @(Model.AlertMessageType == "success" ? "alert-success" : "alert-danger") mb-3">
        @Model.AlertMessageContent
    </div>
}

<div class="row">

    @* Left — Application + Registrant info *@
    <div class="col-12 col-lg-8">

        @* Application summary *@
        <div class="card mb-3">
            <div class="card-body">
                @{
                    var statusClass = app.Status switch
                    {
                        nameof(ApplicationStatus.Approved)              => "bg-success",
                        nameof(ApplicationStatus.Rejected)              => "bg-danger",
                        nameof(ApplicationStatus.SubmissionCompleted)   => "bg-info",
                        nameof(ApplicationStatus.AwardFeeVerified)      => "bg-primary",
                        nameof(ApplicationStatus.NominationFeeVerified) => "bg-info",
                        _ => "bg-secondary"
                    };
                    var statusStyle = app.Status == nameof(ApplicationStatus.UnderEvaluation)
                        ? "background:#6f42c1" : "";
                }
                <h5 class="card-title">
                    @app.ApplicationId
                    <span class="badge @statusClass ms-2" style="@statusStyle">@app.Status</span>
                </h5>
                <div class="table-responsive">
                    <table class="table table-striped align-middle mb-0">
                        <tbody>
                            <tr><td class="text-muted" style="width:40%">Application Type</td><td>@app.ApplicationType</td></tr>
                            <tr><td class="text-muted">Award Category</td><td>@app.AwardCategory?.Name</td></tr>
                            <tr><td class="text-muted">Payment Method</td><td>@app.PaymentMethod</td></tr>
                            <tr><td class="text-muted">Final Submitted</td><td>@(app.IsFinalSubmitted ? (app.SubmittedAt?.ToString("dd MMM yyyy HH:mm") ?? "Yes") : "No")</td></tr>
                            <tr><td class="text-muted">Registered</td><td>@app.CreatedAt.ToString("dd MMM yyyy HH:mm")</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        @* Registrant info *@
        <div class="card mb-3">
            <div class="card-body">
                <h5 class="card-title"><i class="ri ri-user-line me-1"></i>Registrant</h5>
                <div class="table-responsive">
                    <table class="table table-striped align-middle mb-0">
                        <tbody>
                            <tr><td class="text-muted" style="width:40%">Full Name</td><td>@reg.FullName</td></tr>
                            <tr><td class="text-muted">NRIC / Passport</td><td>@reg.NricPassport</td></tr>
                            <tr><td class="text-muted">Email</td><td>@reg.Email</td></tr>
                            <tr><td class="text-muted">Contact No</td><td>@reg.ContactNo</td></tr>
                            @if (app.ApplicationType == "Corporate")
                            {
                                <tr><td class="text-muted">Company Name</td><td>@reg.CompanyName</td></tr>
                                <tr><td class="text-muted">SSM Reg No</td><td>@reg.SsmRegNo</td></tr>
                                <tr><td class="text-muted">Industry</td><td>@reg.Industry</td></tr>
                                <tr><td class="text-muted">Website</td><td>@(reg.Website ?? "-")</td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        @* Payment summary *@
        @if (app.Payments.Any())
        {
            <div class="card mb-3">
                <div class="card-body">
                    <h5 class="card-title"><i class="ri ri-bank-card-line me-1"></i>Payments</h5>
                    <div class="table-responsive">
                        <table class="table table-striped align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>Invoice</th>
                                    <th>Type</th>
                                    <th class="text-end">Amount (RM)</th>
                                    <th>Method</th>
                                    <th>Status</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var pay in app.Payments)
                                {
                                    var payBadge = pay.Status switch
                                    {
                                        nameof(PaymentStatus.Verified)            => "bg-success",
                                        nameof(PaymentStatus.Rejected)            => "bg-danger",
                                        nameof(PaymentStatus.PendingVerification) => "bg-warning text-dark",
                                        _ => "bg-secondary"
                                    };
                                    <tr>
                                        <td>@pay.InvoiceNo</td>
                                        <td>@pay.PaymentType</td>
                                        <td class="text-end">@pay.Amount.ToString("N2")</td>
                                        <td>@pay.Method</td>
                                        <td>
                                            <span class="badge @payBadge">@pay.Status</span>
                                        </td>
                                        <td>
                                            <a asp-area="Admin" asp-page="/MRMR/Payments/Detail"
                                               asp-route-paymentId="@pay.Id"
                                               class="btn btn-sm btn-outline-primary">
                                                <i class="ri ri-external-link-line"></i>
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }

        @* Document status overview *@
        @if (app.Documents.Any())
        {
            <div class="card mb-3">
                <div class="card-body">
                    <h5 class="card-title"><i class="ri ri-folder-line me-1"></i>Documents</h5>
                    <div class="table-responsive">
                        <table class="table table-striped align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>Document Type</th>
                                    <th>Uploaded</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var doc in app.Documents)
                                {
                                    var docBadge = doc.VerificationStatus switch
                                    {
                                        nameof(DocumentVerificationStatus.Verified) => "bg-success",
                                        nameof(DocumentVerificationStatus.Rejected) => "bg-danger",
                                        _ => "bg-warning text-dark"
                                    };
                                    <tr>
                                        <td>@doc.DocumentType</td>
                                        <td>@doc.UploadedAt.ToString("dd MMM yyyy")</td>
                                        <td>
                                            <span class="badge @docBadge">@doc.VerificationStatus</span>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }

        @* Submission checklist *@
        @if (app.Submission != null)
        {
            var sub = app.Submission;
            <div class="card mb-3">
                <div class="card-body">
                    <h5 class="card-title"><i class="ri ri-task-line me-1"></i>Submission Sections</h5>
                    <div class="row mb-0">
                        @{
                            var sections = new (string Label, bool Done)[]
                            {
                                ("A — Personal Info",      sub.SectionAComplete),
                                ("B — Business Profile",   sub.SectionBComplete),
                                ("C — Category",           sub.SectionCComplete),
                                ("D — Positioning",        sub.SectionDComplete),
                                ("E — Achievements",       sub.SectionEComplete),
                                ("F — Notable Impact",     sub.SectionFComplete),
                                ("G — Vision",             sub.SectionGComplete),
                                ("H — Innovation",         sub.SectionHComplete),
                                ("I — Corp Info",          sub.SectionIComplete),
                                ("J — Introducer",         sub.SectionJComplete),
                                ("K — Documents",          sub.SectionKComplete),
                                ("L — Declarations",       sub.SectionLComplete),
                            };
                        }
                        @foreach (var (label, done) in sections)
                        {
                            <div class="col-6 col-md-4">
                                <p class="@(done ? "text-success" : "text-muted")">
                                    <i class="ri @(done ? "ri-checkbox-circle-fill" : "ri-checkbox-blank-circle-line") me-1"></i>
                                    @label
                                </p>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
    </div>

    @* Right column — Manual status override *@
    <div class="col-12 col-lg-4">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title"><i class="ri ri-settings-3-line me-1"></i>Manual Status Override</h5>
                <p class="text-muted" style="font-size:0.85rem;">
                    Current: <strong>@app.Status</strong>
                </p>
                <form method="post" asp-page-handler="OverrideStatus" id="overrideForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="Id" value="@app.Id" />

                    <div class="mb-3">
                        <label class="form-label" for="ddlOverrideStatus">New Status</label>
                        <select name="OverrideStatus" id="ddlOverrideStatus" class="form-select">
                            <option value="" disabled selected>Select new status</option>
                            @foreach (var stype in Model.AllStatuses)
                            {
                                @if (Model.OverrideStatus == stype)
                                {
                                    <option value="@stype" selected>@stype</option>
                                }
                                else
                                {
                                    <option value="@stype">@stype</option>
                                }
                            }
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label" for="txtOverrideReason">Reason *</label>
                        <textarea id="txtOverrideReason" name="OverrideReason"
                                  class="form-control" rows="3">@Model.OverrideReason</textarea>
                    </div>

                    <button type="button" onclick="confirmOverride()"
                            class="btn btn-warning w-100">
                        <i class="ri ri-refresh-line me-1"></i>Override Status
                    </button>
                    <button type="submit" id="overrideSubmit" style="display:none;"></button>
                </form>
            </div>
        </div>
    </div>
</div>

@section PageScripts {
<script>
    function confirmOverride() {
        Swal.fire({
            title:             'Override Application Status?',
            text:              'This will manually change the application status. Please ensure the reason is documented.',
            icon:              'warning',
            showCancelButton:  true,
            confirmButtonText: 'Yes, Override',
            cancelButtonText:  'Cancel',
            confirmButtonColor: '#e65100'
        }).then(function (result) {
            if (result.isConfirmed) {
                document.getElementById('overrideSubmit').click();
            }
        });
    }
</script>
}
