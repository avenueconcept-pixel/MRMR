@page
@model MyApp.Areas.Admin.Pages.MRMR.Evaluation.IndexModel
@using MyApp.Constants.MRMR
@{
    ViewData["Title"]      = "Evaluation Overview";
    ViewData["ActiveMenu"] = "MRMR_EVALUATION";
}

<div class="d-flex justify-content-between align-items-center py-3 mb-4">
    <h4 class="mb-0"><i class="ri ri-bar-chart-2-line me-1"></i>Evaluation Overview</h4>
</div>

<div class="card mb-3">
    <div class="card-body py-2">
        <form method="get" class="row align-items-end g-2">
            <div class="col-12 col-md-6">
                <label class="form-label">Award Category</label>
                <select name="CategoryId" id="CategoryId" class="form-select">
                    @if (Model.CategoryId == 0)
                    {
                        <option value="0" disabled selected>Select a category</option>
                    }
                    else
                    {
                        <option value="0" disabled>Select a category</option>
                    }
                    @foreach (var cat in Model.Categories)
                    {
                        @if (Model.CategoryId == cat.Id)
                        {
                            <option value="@cat.Id" selected>@cat.Name (@cat.CategoryType)</option>
                        }
                        else
                        {
                            <option value="@cat.Id">@cat.Name (@cat.CategoryType)</option>
                        }
                    }
                </select>
            </div>
            <div class="col-12 col-md-3">
                <button type="submit" class="btn btn-primary w-100">
                    <i class="ri ri-search-line me-1"></i>View
                </button>
            </div>
            @if (Model.CategoryId > 0)
            {
                <div class="col-12 col-md-3">
                    <a asp-page="Finalize" asp-route-categoryId="@Model.CategoryId"
                       class="btn btn-warning w-100">
                        <i class="ri ri-trophy-line me-1"></i>Finalize
                    </a>
                </div>
            }
        </form>
    </div>
</div>

@if (Model.CategoryId > 0)
{
    @if (!Model.Summaries.Any())
    {
        <div class="card">
            <div class="card-body text-center py-4">
                <i class="ri ri-inbox-line text-muted" style="font-size:3rem;"></i>
                <p class="text-muted">No submitted evaluations yet for this category.</p>
            </div>
        </div>
    }
    else
    {
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">
                    Leaderboard — @Model.Category?.Name
                    <small class="text-muted">(@Model.Summaries.Count applications)</small>
                </h5>
                <div class="table-responsive">
                    <table class="table table-hover table-striped align-middle">
                        <thead>
                            <tr>
                                <th style="width:50px">#</th>
                                <th>Application</th>
                                <th>Applicant</th>
                                <th class="text-end">Avg Weighted Score</th>
                                <th class="text-center">Judges</th>
                                <th>Consensus</th>
                                <th>Rank</th>
                            </tr>
                        </thead>
                        <tbody>
                            @for (int idx = 0; idx < Model.Summaries.Count; idx++)
                            {
                                var s           = Model.Summaries[idx];
                                int pos         = idx + 1;
                                var recommended = s.JudgeRows.Count(j => j.Recommendation == "Recommended");
                                var notRecom    = s.JudgeRows.Count(j => j.Recommendation == "NotRecommended");
                                var neutral     = s.JudgeRows.Count(j => j.Recommendation == "Neutral");

                                <tr>
                                    <td>
                                        @if (pos == 1)
                                        {
                                            <i class="ri ri-trophy-fill" style="color:#FFD700;"></i>
                                        }
                                        else if (pos == 2)
                                        {
                                            <i class="ri ri-trophy-fill" style="color:#C0C0C0;"></i>
                                        }
                                        else if (pos == 3)
                                        {
                                            <i class="ri ri-trophy-fill" style="color:#CD7F32;"></i>
                                        }
                                        else
                                        {
                                            <span class="text-muted">@pos</span>
                                        }
                                    </td>
                                    <td><strong>@s.Application.ApplicationId</strong></td>
                                    <td>
                                        @s.Application.Registrant.FullName
                                        @if (!string.IsNullOrEmpty(s.Application.Registrant.CompanyName))
                                        {
                                            <br /><small class="text-muted">@s.Application.Registrant.CompanyName</small>
                                        }
                                    </td>
                                    <td class="text-end">
                                        <strong class="@(pos == 1 ? "text-success" : "")">
                                            @s.TotalWeighted.ToString("N2")
                                        </strong>
                                        / 100
                                    </td>
                                    <td class="text-center">@s.JudgeCount</td>
                                    <td>
                                        @if (recommended > 0)
                                        {
                                            <span class="badge bg-success">&#10003;@recommended</span>
                                        }
                                        @if (neutral > 0)
                                        {
                                            <span class="badge bg-secondary ms-1">~@neutral</span>
                                        }
                                        @if (notRecom > 0)
                                        {
                                            <span class="badge bg-danger ms-1">&#10007;@notRecom</span>
                                        }
                                    </td>
                                    <td>
                                        @if (s.Ranking != null)
                                        {
                                            @if (s.Ranking.IsApprovedWinner)
                                            {
                                                <span class="badge bg-success">Winner</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-secondary">#@s.Ranking.RankPosition</span>
                                            }
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                @* Judge breakdown per application *@
                @foreach (var s in Model.Summaries.Where(x => x.JudgeRows.Any()))
                {
                    <div class="mt-3">
                        <p class="text-muted mb-1" style="font-size:0.85rem;">
                            <strong>@s.Application.ApplicationId</strong> — Judge Breakdown
                        </p>
                        <div class="table-responsive">
                            <table class="table table-striped align-middle" style="font-size:0.85rem;">
                                <thead>
                                    <tr>
                                        <th>Judge</th>
                                        <th class="text-end">Weighted Total</th>
                                        <th>Recommendation</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var j in s.JudgeRows)
                                    {
                                        <tr>
                                            <td>@j.JudgeName</td>
                                            <td class="text-end">@j.TotalWeighted.ToString("N2")</td>
                                            <td>
                                                <span class="@(j.Recommendation switch { "Recommended" => "text-success", "NotRecommended" => "text-danger", _ => "text-muted" })">
                                                    @(j.Recommendation ?? "-")
                                                </span>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                }
            </div>
        </div>
    }
}
