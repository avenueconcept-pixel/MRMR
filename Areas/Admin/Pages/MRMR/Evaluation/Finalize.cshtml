@page "{categoryId:int}"
@model MyApp.Areas.Admin.Pages.MRMR.Evaluation.FinalizeModel
@using MyApp.Dtos
@{
    ViewData["Title"]      = $"Finalize — {Model.Category?.Name}";
    ViewData["ActiveMenu"] = "MRMR_EVALUATION";
}

<div class="d-flex justify-content-between align-items-center py-3 mb-4">
    <h4 class="mb-0"><i class="ri ri-trophy-line me-1"></i>Finalize Rankings — @Model.Category?.Name</h4>
    <a asp-page="Index" asp-route-categoryId="@Model.CategoryId" class="btn btn-outline-secondary">
        <i class="ri ri-arrow-left-line me-1"></i>Back to Overview
    </a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success mb-3">
        <i class="ri ri-checkbox-circle-line me-1"></i>@TempData["SuccessMessage"]
    </div>
}
@if (!string.IsNullOrEmpty(Model.AlertMessageContent))
{
    <div class="alert alert-danger mb-3">
        <i class="ri ri-error-warning-line me-1"></i>@Model.AlertMessageContent
    </div>
}

<div class="alert alert-warning mb-3">
    <i class="ri ri-information-line me-1"></i>
    Finalizing will overwrite any existing rankings for this category.
    Winners will be marked as <strong>Approved</strong>.
</div>

@if (!Model.Summaries.Any())
{
    <div class="card">
        <div class="card-body text-center py-4">
            <p class="text-muted">No evaluated applications to finalize.</p>
        </div>
    </div>
}
else
{
    <form method="post" asp-page-handler="Finalize">
        @Html.AntiForgeryToken()
        <input type="hidden" name="CategoryId" value="@Model.CategoryId" />

        <div class="card mb-3">
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-striped align-middle">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Application</th>
                                <th>Applicant</th>
                                <th class="text-end">Avg Score</th>
                                <th class="text-center">Approve Winner</th>
                                <th>Committee Remarks</th>
                            </tr>
                        </thead>
                        <tbody>
                            @for (int i = 0; i < Model.Summaries.Count; i++)
                            {
                                var s = Model.Summaries[i];
                                var d = Model.Decisions.ElementAtOrDefault(i) ?? new FinalizeDecisionDto();
                                <tr>
                                    <td>@(i + 1)</td>
                                    <td>
                                        <input type="hidden"
                                               name="Decisions[@i].ApplicationId"
                                               value="@s.Application.Id" />
                                        <strong>@s.Application.ApplicationId</strong>
                                    </td>
                                    <td>@s.Application.Registrant.FullName</td>
                                    <td class="text-end">
                                        <strong>@s.TotalWeighted.ToString("N2")</strong>
                                    </td>
                                    <td class="text-center">
                                        @if (d.IsApprovedWinner)
                                        {
                                            <input type="checkbox"
                                                   class="form-check-input"
                                                   name="Decisions[@i].IsApprovedWinner"
                                                   value="true"
                                                   checked />
                                        }
                                        else
                                        {
                                            <input type="checkbox"
                                                   class="form-check-input"
                                                   name="Decisions[@i].IsApprovedWinner"
                                                   value="true" />
                                        }
                                        <input type="hidden"
                                               name="Decisions[@i].IsApprovedWinner"
                                               value="false" />
                                    </td>
                                    <td>
                                        <input type="text"
                                               name="Decisions[@i].CommitteeRemarks"
                                               value="@d.CommitteeRemarks"
                                               class="form-control"
                                               placeholder="Optional remarks" />
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="d-flex justify-content-end mb-3 gap-2">
            <a asp-page="Index" asp-route-categoryId="@Model.CategoryId"
               class="btn btn-outline-secondary">Cancel</a>
            <button type="button" onclick="confirmFinalize()"
                    class="btn btn-success">
                <i class="ri ri-trophy-line me-1"></i>Finalize Rankings
            </button>
            <div id="finalizeFormWrapper" style="display:none;">
                <button type="submit" id="finalizeBtn"></button>
            </div>
        </div>
    </form>
}

@section PageScripts {
<script>
function confirmFinalize() {
    Swal.fire({
        title:             'Finalize Rankings?',
        text:              'This will overwrite any existing rankings for this category.',
        icon:              'warning',
        showCancelButton:  true,
        confirmButtonText: 'Yes, Finalize',
        cancelButtonText:  'Cancel',
        confirmButtonColor:'#2e7d32'
    }).then(function (result) {
        if (result.isConfirmed)
            document.getElementById('finalizeBtn').click();
    });
}
</script>
}
