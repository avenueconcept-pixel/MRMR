@page
@model MyApp.Areas.Admin.Pages.MRMR.Categories.IndexModel
@{
    ViewData["Title"]      = "Category Management";
    ViewData["ActiveMenu"] = "MRMR_CATEGORIES";
}

<div class="d-flex justify-content-between align-items-center py-3 mb-4">
    <h4 class="mb-0"><i class="ri ri-trophy-line me-1"></i>Award Categories</h4>
    <a asp-page="Create" class="btn btn-primary">
        <i class="ri ri-add-line me-1"></i>New Category
    </a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success mb-3">
        <i class="ri ri-checkbox-circle-line me-1"></i>@TempData["SuccessMessage"]
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger mb-3">
        <i class="ri ri-error-warning-line me-1"></i>@TempData["ErrorMessage"]
    </div>
}

@if (!Model.Categories.Any())
{
    <div class="card">
        <div class="card-body text-center py-4">
            <i class="ri ri-trophy-line text-muted" style="font-size:3rem;"></i>
            <p class="text-muted">No categories yet. Create the first one.</p>
        </div>
    </div>
}
else
{
    @foreach (var cat in Model.Categories)
    {
        <div class="card mb-3 @(!cat.IsActive ? "bg-light" : "")">
            <div class="card-body">
                <div class="row align-items-center mb-0">
                    <div class="col-12 col-md-7">
                        <h5 class="card-title mb-1">
                            @cat.Name
                            @if (cat.CategoryType == "Corporate")
                            {
                                <span class="badge bg-warning text-dark ms-1">@cat.CategoryType</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary ms-1">@cat.CategoryType</span>
                            }
                            @if (!cat.IsActive)
                            {
                                <span class="badge bg-secondary ms-1">Inactive</span>
                            }
                            @if (cat.CriteriaLocked)
                            {
                                <span class="badge bg-danger ms-1">
                                    <i class="ri ri-lock-line"></i> Criteria Locked
                                </span>
                            }
                        </h5>
                        <p class="text-muted mb-0" style="font-size:0.85rem;">
                            RM @cat.Price.ToString("N2") &nbsp;|&nbsp;
                            Max Recipients: @cat.MaxRecipients &nbsp;|&nbsp;
                            Criteria: @cat.Criteria.Count(x => x.IsActive)
                        </p>
                        @if (!string.IsNullOrEmpty(cat.Description))
                        {
                            <p class="text-muted mb-0" style="font-size:0.8rem;">@cat.Description</p>
                        }
                    </div>
                    <div class="col-12 col-md-5 text-end mt-2 mt-md-0">
                        <a asp-page="Edit" asp-route-id="@cat.Id" class="btn btn-sm btn-primary">
                            <i class="ri ri-edit-line me-1"></i>Edit
                        </a>
                        @if (cat.IsActive)
                        {
                            <form method="post" asp-page-handler="Deactivate"
                                  id="deactivateForm_@cat.Id" style="display:inline;">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@cat.Id" />
                                <button type="button"
                                        class="btn btn-sm btn-danger ms-1"
                                        onclick="confirmDeactivate(@cat.Id)">
                                    <i class="ri ri-eye-off-line me-1"></i>Deactivate
                                </button>
                            </form>
                        }
                    </div>
                </div>

                @if (cat.Criteria.Any(x => x.IsActive))
                {
                    <div class="mt-3">
                        @foreach (var c in cat.Criteria.Where(x => x.IsActive))
                        {
                            <div class="row align-items-center mb-1" style="font-size:0.8rem;">
                                <div class="col-5 text-muted">@c.CriterionName</div>
                                <div class="col-5">
                                    <div class="progress" style="height:8px; margin:6px 0;">
                                        <div class="progress-bar" style="width:@c.Weight%"></div>
                                    </div>
                                </div>
                                <div class="col-2 text-muted">@c.Weight%</div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    }
}

@section PageScripts {
<script>
function confirmDeactivate(id) {
    Swal.fire({
        title:              'Deactivate Category?',
        text:               'This will hide the category from applicants.',
        icon:               'warning',
        showCancelButton:   true,
        confirmButtonText:  'Yes, Deactivate',
        cancelButtonText:   'Cancel',
        confirmButtonColor: '#c62828'
    }).then(function (result) {
        if (result.isConfirmed) {
            document.getElementById('deactivateForm_' + id).submit();
        }
    });
}
</script>
}
