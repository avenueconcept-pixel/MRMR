@page
@model MyApp.Areas.Admin.Pages.MRMR.Categories.IndexModel
@{
    ViewData["Title"]      = "Category Management";
    ViewData["ActiveMenu"] = "MRMR_CATEGORIES";
}

<div class="row">
    <div class="col s12">
        <div class="row valign-wrapper mb-3">
            <div class="col s12 m8">
                <h5 class="mb-0">
                    <i class="ri ri-trophy-line me-1"></i>Award Categories
                </h5>
            </div>
            <div class="col s12 m4 right-align">
                <a asp-page="Create" class="btn blue darken-3 waves-effect waves-light">
                    <i class="ri ri-add-line me-1"></i>New Category
                </a>
            </div>
        </div>

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="card-panel green lighten-4 mb-2">
                <i class="ri ri-checkbox-circle-line me-1 green-text"></i>@TempData["SuccessMessage"]
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="card-panel red lighten-4 mb-2">
                <i class="ri ri-error-warning-line me-1 red-text"></i>@TempData["ErrorMessage"]
            </div>
        }

        @if (!Model.Categories.Any())
        {
            <div class="card">
                <div class="card-content center-align py-4">
                    <i class="ri ri-trophy-line grey-text" style="font-size:3rem;"></i>
                    <p class="grey-text">No categories yet. Create the first one.</p>
                </div>
            </div>
        }
        else
        {
            @foreach (var cat in Model.Categories)
            {
                <div class="card @(!cat.IsActive ? "grey lighten-3" : "")">
                    <div class="card-content">
                        <div class="row valign-wrapper mb-0">
                            <div class="col s12 m7">
                                <span class="card-title mb-0" style="font-size:1.1rem;">
                                    @cat.Name
                                    <span class="badge @(cat.CategoryType == "Corporate" ? "orange" : "blue-grey") white-text ms-1"
                                          style="float:none; font-size:0.7rem;">@cat.CategoryType</span>
                                    @if (!cat.IsActive)
                                    {
                                        <span class="badge grey white-text ms-1" style="float:none; font-size:0.7rem;">Inactive</span>
                                    }
                                    @if (cat.CriteriaLocked)
                                    {
                                        <span class="badge red white-text ms-1" style="float:none; font-size:0.7rem;">
                                            <i class="ri ri-lock-line"></i> Criteria Locked
                                        </span>
                                    }
                                </span>
                                <p class="grey-text mb-0" style="font-size:0.85rem;">
                                    RM @cat.Price.ToString("N2") &nbsp;|&nbsp;
                                    Max Recipients: @cat.MaxRecipients &nbsp;|&nbsp;
                                    Criteria: @cat.Criteria.Count(x => x.IsActive)
                                </p>
                                @if (!string.IsNullOrEmpty(cat.Description))
                                {
                                    <p class="grey-text mb-0" style="font-size:0.8rem;">@cat.Description</p>
                                }
                            </div>
                            <div class="col s12 m5 right-align">
                                <a asp-page="Edit" asp-route-id="@cat.Id"
                                   class="btn-small blue darken-3 waves-effect waves-light">
                                    <i class="ri ri-edit-line me-1"></i>Edit
                                </a>
                                @if (cat.IsActive)
                                {
                                    <form method="post" asp-page-handler="Deactivate"
                                          id="deactivateForm_@cat.Id" style="display:inline;">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@cat.Id" />
                                        <button type="button"
                                                class="btn-small red darken-2 waves-effect waves-light ms-1"
                                                onclick="confirmDeactivate(@cat.Id)">
                                            <i class="ri ri-eye-off-line me-1"></i>Deactivate
                                        </button>
                                    </form>
                                }
                            </div>
                        </div>

                        @if (cat.Criteria.Any(x => x.IsActive))
                        {
                            <div class="mt-2">
                                @foreach (var c in cat.Criteria.Where(x => x.IsActive))
                                {
                                    <div class="row valign-wrapper mb-0" style="font-size:0.8rem;">
                                        <div class="col s5 grey-text">@c.CriterionName</div>
                                        <div class="col s5">
                                            <div class="progress" style="height:8px; margin:6px 0;">
                                                <div class="determinate blue darken-3"
                                                     style="width:@c.Weight%"></div>
                                            </div>
                                        </div>
                                        <div class="col s2 grey-text">@c.Weight%</div>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>
            }
        }
    </div>
</div>

@section PageScripts {
<script>
function confirmDeactivate(id) {
    Swal.fire({
        title:              'Deactivate Category?',
        text:               'This will hide the category from applicants.',
        icon:               'warning',
        showCancelButton:   true,
        confirmButtonText:  'Yes, Deactivate',
        cancelButtonText:   'Cancel',
        confirmButtonColor: '#c62828'
    }).then(function (result) {
        if (result.isConfirmed) {
            document.getElementById('deactivateForm_' + id).submit();
        }
    });
}
</script>
}
