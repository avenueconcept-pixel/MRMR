@page
@model MyApp.Areas.Admin.Pages.MRMR.Categories.CreateModel
@{
    ViewData["Title"]      = "Create Category";
    ViewData["ActiveMenu"] = "MRMR_CATEGORIES";
}

<div class="d-flex justify-content-between align-items-center py-3 mb-4">
    <h4 class="mb-0"><i class="ri ri-trophy-line me-1"></i>Create Award Category</h4>
    <a asp-page="Index" class="btn btn-outline-secondary">
        <i class="ri ri-arrow-left-line me-1"></i>Back to Categories
    </a>
</div>

@if (!string.IsNullOrEmpty(Model.AlertMessageContent))
{
    <div class="alert alert-danger mb-3">
        <i class="ri ri-error-warning-line me-1"></i>@Model.AlertMessageContent
    </div>
}

<form method="post" asp-page-handler="Create">
    @Html.AntiForgeryToken()

    <div class="card mb-3">
        <div class="card-body">
            <h5 class="card-title">Category Details</h5>
            <div class="row g-3">
                <div class="col-12 col-md-6">
                    <label class="form-label" for="Category_Name">Category Name *</label>
                    <input type="text" id="Category_Name" name="Category.Name" class="form-control"
                           value="@Model.Category.Name" required />
                </div>
                <div class="col-12 col-md-3">
                    <label class="form-label">Type *</label>
                    <select name="Category.CategoryType" id="Category_CategoryType" class="form-select">
                        @if (Model.Category.CategoryType == "Corporate")
                        {
                            <option value="Individual">Individual</option>
                            <option value="Corporate" selected>Corporate</option>
                        }
                        else
                        {
                            <option value="Individual" selected>Individual</option>
                            <option value="Corporate">Corporate</option>
                        }
                    </select>
                </div>
                <div class="col-12 col-md-3">
                    <label class="form-label" for="Category_Price">Award Fee (RM) *</label>
                    <input type="number" id="Category_Price" name="Category.Price" class="form-control"
                           value="@Model.Category.Price" min="0" step="0.01" required />
                </div>
                <div class="col-12 col-md-3">
                    <label class="form-label" for="Category_MaxRecipients">Max Recipients *</label>
                    <input type="number" id="Category_MaxRecipients" name="Category.MaxRecipients" class="form-control"
                           value="@(Model.Category.MaxRecipients == 0 ? 1 : Model.Category.MaxRecipients)"
                           min="1" required />
                </div>
                <div class="col-12 col-md-3">
                    <label class="form-label" for="Category_DisplayOrder">Display Order</label>
                    <input type="number" id="Category_DisplayOrder" name="Category.DisplayOrder" class="form-control"
                           value="@Model.Category.DisplayOrder" min="0" />
                </div>
                <div class="col-12">
                    <label class="form-label" for="Category_Description">Description</label>
                    <textarea id="Category_Description" name="Category.Description"
                              class="form-control" rows="3">@Model.Category.Description</textarea>
                </div>
            </div>
        </div>
    </div>

    <div class="card mb-3">
        <div class="card-body">
            <h5 class="card-title d-flex align-items-center gap-2">
                Evaluation Criteria
                <small class="text-muted">(weights must total 100%)</small>
                <button type="button" class="btn btn-sm btn-outline-secondary ms-auto" id="btnCopyCriteria">
                    <i class="ri ri-file-copy-line me-1"></i>Copy from Category
                </button>
            </h5>
            <p class="text-muted" style="font-size:0.85rem;">
                Leave blank to skip. Weight total: <strong id="weightTotal">0</strong>%
                <span id="weightWarning" class="text-danger ms-2" style="display:none;">&#9888; Must equal 100%</span>
            </p>

            <div class="table-responsive">
                <table id="criteriaTable" class="table table-striped align-middle">
                    <thead>
                        <tr>
                            <th style="width:50%">Criterion Name</th>
                            <th style="width:20%">Weight (%)</th>
                            <th>Description</th>
                        </tr>
                    </thead>
                    <tbody>
                        @for (int i = 0; i < Model.Criteria.Count; i++)
                        {
                            <tr>
                                <td>
                                    <input type="text"
                                           name="Criteria[@i].CriterionName"
                                           value="@Model.Criteria[i].CriterionName"
                                           class="form-control"
                                           placeholder="e.g. Innovation" />
                                </td>
                                <td>
                                    <input type="number"
                                           name="Criteria[@i].Weight"
                                           value="@Model.Criteria[i].Weight"
                                           class="form-control weight-input"
                                           style="width:80px;"
                                           min="0" max="100" step="0.01" />
                                </td>
                                <td>
                                    <input type="text"
                                           name="Criteria[@i].Description"
                                           value="@Model.Criteria[i].Description"
                                           class="form-control"
                                           placeholder="Optional" />
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="d-flex justify-content-end mb-3 gap-2">
        <a asp-page="Index" class="btn btn-outline-secondary">Cancel</a>
        <button type="submit" class="btn btn-primary">
            <i class="ri ri-save-line me-1"></i>Create Category
        </button>
    </div>
</form>

@section PageScripts {
<script>
const allCategories = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
    Model.AllCategories
        .Where(c => c.Criteria != null && c.Criteria.Any())
        .Select(c => new {
            id       = c.Id,
            name     = c.Name,
            criteria = c.Criteria
                .Where(x => x.IsActive)
                .OrderBy(x => x.DisplayOrder)
                .Select(x => new {
                    criterionName = x.CriterionName,
                    weight        = x.Weight,
                    description   = x.Description ?? ""
                })
        })
));

document.addEventListener('DOMContentLoaded', function () {
    updateWeightTotal();
    document.querySelectorAll('.weight-input').forEach(function (el) {
        el.addEventListener('input', updateWeightTotal);
    });

    document.getElementById('btnCopyCriteria').addEventListener('click', function () {
        if (!allCategories.length) {
            Swal.fire('No categories', 'No other categories with criteria found.', 'info');
            return;
        }

        const options = allCategories
            .map(c => `<option value="${c.id}">${escHtml(c.name)}</option>`)
            .join('');

        Swal.fire({
            title: 'Copy from Category',
            html: `<select id="swalCatSelect" class="form-select mt-2">${options}</select>`,
            confirmButtonText: 'Copy',
            showCancelButton: true,
            preConfirm: () => document.getElementById('swalCatSelect').value
        }).then(result => {
            if (!result.isConfirmed) return;

            const catId    = parseInt(result.value);
            const selected = allCategories.find(c => c.id === catId);
            if (!selected) return;

            const rows = [...selected.criteria];
            while (rows.length < 5) rows.push({ criterionName: '', weight: '', description: '' });

            const tbody = document.querySelector('#criteriaTable tbody');
            tbody.innerHTML = rows.map((c, i) => `
                <tr>
                    <td><input type="text"   name="Criteria[${i}].CriterionName" value="${escHtml(c.criterionName)}" class="form-control" placeholder="e.g. Innovation" /></td>
                    <td><input type="number" name="Criteria[${i}].Weight"         value="${c.weight}"                 class="form-control weight-input" style="width:80px;" min="0" max="100" step="0.01" /></td>
                    <td><input type="text"   name="Criteria[${i}].Description"    value="${escHtml(c.description)}"   class="form-control" placeholder="Optional" /></td>
                </tr>`).join('');

            tbody.querySelectorAll('.weight-input').forEach(el => el.addEventListener('input', updateWeightTotal));
            updateWeightTotal();
        });
    });
});

function updateWeightTotal() {
    var total = 0;
    document.querySelectorAll('.weight-input').forEach(function (el) {
        total += parseFloat(el.value) || 0;
    });
    total = Math.round(total * 100) / 100;
    document.getElementById('weightTotal').textContent = total;
    var warn = document.getElementById('weightWarning');
    if (total > 0 && total !== 100) {
        warn.style.display = 'inline';
        document.getElementById('weightTotal').classList.add('text-danger');
    } else {
        warn.style.display = 'none';
        document.getElementById('weightTotal').classList.remove('text-danger');
    }
}

function escHtml(str) {
    return String(str ?? '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}
</script>
}
