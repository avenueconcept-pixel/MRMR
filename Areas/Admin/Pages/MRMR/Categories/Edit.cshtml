@page "{id:int}"
@model MyApp.Areas.Admin.Pages.MRMR.Categories.EditModel
@{
    ViewData["Title"]      = $"Edit — {Model.Category.Name}";
    ViewData["ActiveMenu"] = "MRMR_CATEGORIES";
}

<div class="d-flex justify-content-between align-items-center py-3 mb-4">
    <h4 class="mb-0"><i class="ri ri-edit-line me-1"></i>Edit Category</h4>
    <a asp-page="Index" class="btn btn-outline-secondary">
        <i class="ri ri-arrow-left-line me-1"></i>Back to Categories
    </a>
</div>

@if (!string.IsNullOrEmpty(Model.AlertMessageContent))
{
    <div class="alert alert-danger mb-3">
        <i class="ri ri-error-warning-line me-1"></i>@Model.AlertMessageContent
    </div>
}

<form method="post" asp-page-handler="Update">
    @Html.AntiForgeryToken()
    <input type="hidden" name="Id" value="@Model.Id" />

    <div class="card mb-3">
        <div class="card-body">
            <h5 class="card-title">Category Details</h5>
            <div class="row g-3">
                <div class="col-12 col-md-6">
                    <label class="form-label" for="Category_Name">Category Name *</label>
                    <input type="text" id="Category_Name" name="Category.Name" class="form-control"
                           value="@Model.Category.Name" required />
                </div>
                <div class="col-12 col-md-3">
                    <label class="form-label">Type *</label>
                    <select name="Category.CategoryType" id="Category_CategoryType" class="form-select">
                        @if (Model.Category.CategoryType == "Corporate")
                        {
                            <option value="Individual">Individual</option>
                            <option value="Corporate" selected>Corporate</option>
                        }
                        else
                        {
                            <option value="Individual" selected>Individual</option>
                            <option value="Corporate">Corporate</option>
                        }
                    </select>
                </div>
                <div class="col-12 col-md-3">
                    <label class="form-label" for="Category_Price">Award Fee (RM) *</label>
                    <input type="number" id="Category_Price" name="Category.Price" class="form-control"
                           value="@Model.Category.Price" min="0" step="0.01" required />
                </div>
                <div class="col-12 col-md-3">
                    <label class="form-label" for="Category_MaxRecipients">Max Recipients *</label>
                    <input type="number" id="Category_MaxRecipients" name="Category.MaxRecipients" class="form-control"
                           value="@Model.Category.MaxRecipients" min="1" required />
                </div>
                <div class="col-12 col-md-3">
                    <label class="form-label" for="Category_DisplayOrder">Display Order</label>
                    <input type="number" id="Category_DisplayOrder" name="Category.DisplayOrder" class="form-control"
                           value="@Model.Category.DisplayOrder" min="0" />
                </div>
                <div class="col-12 col-md-3 d-flex align-items-end">
                    <div class="form-check mb-2">
                        @if (Model.Category.IsActive)
                        {
                            <input type="checkbox" class="form-check-input" id="Category_IsActive"
                                   name="Category.IsActive" value="true" checked />
                        }
                        else
                        {
                            <input type="checkbox" class="form-check-input" id="Category_IsActive"
                                   name="Category.IsActive" value="true" />
                        }
                        <input type="hidden" name="Category.IsActive" value="false" />
                        <label class="form-check-label" for="Category_IsActive">Active</label>
                    </div>
                </div>
                <div class="col-12">
                    <label class="form-label" for="Category_Description">Description</label>
                    <textarea id="Category_Description" name="Category.Description"
                              class="form-control" rows="3">@Model.Category.Description</textarea>
                </div>
            </div>
        </div>
    </div>

    <div class="card mb-3">
        <div class="card-body">
            <h5 class="card-title">
                Evaluation Criteria
                @if (Model.Category.CriteriaLocked)
                {
                    <span class="badge bg-danger ms-1">
                        <i class="ri ri-lock-line"></i> Locked — evaluations in progress
                    </span>
                }
                else
                {
                    <small class="text-muted">(weights must total 100%)</small>
                }
            </h5>

            @if (Model.Category.CriteriaLocked)
            {
                <p class="text-warning">Criteria cannot be edited because judge evaluations have already been submitted.</p>
                <div class="table-responsive">
                    <table class="table table-striped align-middle">
                        <thead>
                            <tr><th>Criterion</th><th>Weight</th><th>Description</th></tr>
                        </thead>
                        <tbody>
                            @foreach (var c in Model.Criteria.Where(x => x.Id > 0))
                            {
                                <tr>
                                    <td>@c.CriterionName</td>
                                    <td>@c.Weight%</td>
                                    <td>@c.Description</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <p class="text-muted" style="font-size:0.85rem;">
                    Weight total: <strong id="weightTotal">0</strong>%
                    <span id="weightWarning" class="text-danger ms-2" style="display:none;">&#9888; Must equal 100%</span>
                </p>
                <div class="table-responsive">
                    <table class="table table-striped align-middle">
                        <thead>
                            <tr>
                                <th style="width:50%">Criterion Name</th>
                                <th style="width:20%">Weight (%)</th>
                                <th>Description</th>
                            </tr>
                        </thead>
                        <tbody>
                            @for (int i = 0; i < Model.Criteria.Count; i++)
                            {
                                <tr>
                                    <td>
                                        <input type="text"
                                               name="Criteria[@i].CriterionName"
                                               value="@Model.Criteria[i].CriterionName"
                                               class="form-control" />
                                    </td>
                                    <td>
                                        <input type="number"
                                               name="Criteria[@i].Weight"
                                               value="@Model.Criteria[i].Weight"
                                               class="form-control weight-input"
                                               style="width:80px;"
                                               min="0" max="100" step="0.01" />
                                    </td>
                                    <td>
                                        <input type="text"
                                               name="Criteria[@i].Description"
                                               value="@Model.Criteria[i].Description"
                                               class="form-control" />
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>

    <div class="d-flex justify-content-end mb-3 gap-2">
        <a asp-page="Index" class="btn btn-outline-secondary">Cancel</a>
        <button type="submit" class="btn btn-primary">
            <i class="ri ri-save-line me-1"></i>Save Changes
        </button>
    </div>
</form>

@section PageScripts {
<script>
document.addEventListener('DOMContentLoaded', function () {
    @if (!Model.Category.CriteriaLocked)
    {
        @:updateWeightTotal();
        @:document.querySelectorAll('.weight-input').forEach(function (el) {
        @:    el.addEventListener('input', updateWeightTotal);
        @:});
    }
});

function updateWeightTotal() {
    var total = 0;
    document.querySelectorAll('.weight-input').forEach(function (el) {
        total += parseFloat(el.value) || 0;
    });
    total = Math.round(total * 100) / 100;
    document.getElementById('weightTotal').textContent = total;
    var warn = document.getElementById('weightWarning');
    if (total > 0 && total !== 100) {
        warn.style.display = 'inline';
        document.getElementById('weightTotal').classList.add('text-danger');
    } else {
        warn.style.display = 'none';
        document.getElementById('weightTotal').classList.remove('text-danger');
    }
}
</script>
}
