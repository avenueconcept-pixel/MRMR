@inject MyApp.Helper.DB.MenuDbHelper _menuDbHelper
@inject MyApp.Services.AppSettingsService _menuBrandingSvc
@using MyApp.Models
@{
  TempData.Keep();
  var menuBrandLogo = await _menuBrandingSvc.GetAsync("global", "logo_path");
  var roleId       = int.TryParse(User.FindFirst(CookieConstants.SessionKeys.RoleId)?.Value, out var rid) ? rid : 0;
  var isSuperAdmin = User.FindFirst(CookieConstants.SessionKeys.IsSuperAdmin)?.Value == "true";
  var allMenus     = await _menuDbHelper.GetNavMenuAsync(roleId, isSuperAdmin);
  string? current        = Context.Request.Path.Value;
  string? activeMenuCode = ViewData["ActiveMenu"]?.ToString();

  bool IsActive(string? url) =>
      !string.IsNullOrEmpty(url) &&
      (string.Equals(current, url, StringComparison.OrdinalIgnoreCase) ||
       current?.StartsWith(url + "/", StringComparison.OrdinalIgnoreCase) == true);

  bool IsActiveByCode(string? menuCode) =>
      !string.IsNullOrEmpty(activeMenuCode) &&
      !string.IsNullOrEmpty(menuCode) &&
      string.Equals(activeMenuCode, menuCode, StringComparison.OrdinalIgnoreCase);

  bool HasActiveChild(Menu m) =>
      m.Children.Any(c =>
          IsActive(c.MenuUrl) || IsActiveByCode(c.MenuCode) ||
          c.Children.Any(gc => IsActive(gc.MenuUrl) || IsActiveByCode(gc.MenuCode)));
}

@* Menu *@
<aside id="layout-menu" class="layout-menu menu-vertical menu">

  <div class='app-brand demo @((@ViewData["navbarFull"] != null && Convert.ToBoolean(@ViewData["navbarFull"])) ? "d-xl-none" : "")'>
    <a asp-page="/Index" class="app-brand-link">
      <span class="app-brand-logo demo">
        @if (!string.IsNullOrEmpty(menuBrandLogo))
        {
          <img src="/uploads/branding/@menuBrandLogo" style="height:36px;object-fit:contain;" />
        }
        else
        {
          @await Html.PartialAsync("../_Partials/_Macros")
        }
      </span>
      <span class="app-brand-text demo menu-text fw-semibold ms-2">@TempData.Peek("appName")</span>
    </a>

    <a href="javascript:void(0);" class="layout-menu-toggle menu-link text-large ms-auto">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
        <path d="M8.47365 11.7183C8.11707 12.0749 8.11707 12.6531 8.47365 13.0097L12.071 16.607C12.4615 16.9975 12.4615 17.6305 12.071 18.021C11.6805 18.4115 11.0475 18.4115 10.657 18.021L5.83009 13.1941C5.37164 12.7356 5.37164 11.9924 5.83009 11.5339L10.657 6.707C11.0475 6.31653 11.6805 6.31653 12.071 6.707C12.4615 7.09747 12.4615 7.73053 12.071 8.121L8.47365 11.7183Z" fill-opacity="0.9" />
        <path d="M14.3584 11.8336C14.0654 12.1266 14.0654 12.6014 14.3584 12.8944L18.071 16.607C18.4615 16.9975 18.4615 17.6305 18.071 18.021C17.6805 18.4115 17.0475 18.4115 16.657 18.021L11.6819 13.0459C11.3053 12.6693 11.3053 12.0587 11.6819 11.6821L16.657 6.707C17.0475 6.31653 17.6805 6.31653 18.071 6.707C18.4615 7.09747 18.4615 7.73053 18.071 8.121L14.3584 11.8336Z" fill-opacity="0.4" />
      </svg>
    </a>
  </div>

  <div class="menu-inner-shadow"></div>

  <ul class="menu-inner py-1">
    @foreach (var item in allMenus)
    {
      if (item.Level == 0)
      {
        @* Group header *@
        <li class="menu-header small text-uppercase">
          <span class="menu-header-text">@item.MenuName</span>
        </li>

        @* Level 1 items under this group *@
        @foreach (var parent in item.Children.OrderBy(c => c.SortOrder))
        {
          var hasChildren  = parent.Children.Any();
          var parentActive = IsActive(parent.MenuUrl) || IsActiveByCode(parent.MenuCode) || HasActiveChild(parent);

          if (hasChildren)
          {
            <li class='menu-item@(parentActive ? " active open" : "")'>
              <a href="javascript:void(0);" class="menu-link menu-toggle">
                @if (!string.IsNullOrEmpty(parent.MenuIcon))
                {
                  <i class="menu-icon icon-base ri @parent.MenuIcon"></i>
                }
                <div>@parent.MenuName</div>
              </a>
              <ul class="menu-sub">
                @foreach (var child in parent.Children.OrderBy(c => c.SortOrder))
                {
                  var childHasChildren = child.Children.Any();
                  var childActive      = IsActive(child.MenuUrl) || IsActiveByCode(child.MenuCode) || child.Children.Any(gc => IsActive(gc.MenuUrl) || IsActiveByCode(gc.MenuCode));
                  if (childHasChildren)
                  {
                    <li class='menu-item@(childActive ? " active open" : "")'>
                      <a href="javascript:void(0);" class="menu-link menu-toggle">
                        <div>@child.MenuName</div>
                      </a>
                      <ul class="menu-sub">
                        @foreach (var grandchild in child.Children.OrderBy(c => c.SortOrder))
                        {
                          <li class='menu-item@(IsActive(grandchild.MenuUrl) || IsActiveByCode(grandchild.MenuCode) ? " active" : "")'>
                            <a href="@grandchild.MenuUrl" class="menu-link">
                              <div>@grandchild.MenuName</div>
                            </a>
                          </li>
                        }
                      </ul>
                    </li>
                  }
                  else
                  {
                    <li class='menu-item@(childActive ? " active" : "")'>
                      <a href="@child.MenuUrl" class="menu-link">
                        <div>@child.MenuName</div>
                      </a>
                    </li>
                  }
                }
              </ul>
            </li>
          }
          else
          {
            <li class='menu-item@(parentActive ? " active" : "")'>
              <a href="@parent.MenuUrl" class="menu-link">
                @if (!string.IsNullOrEmpty(parent.MenuIcon))
                {
                  <i class="menu-icon icon-base ri @parent.MenuIcon"></i>
                }
                <div>@parent.MenuName</div>
              </a>
            </li>
          }
        }
      }
      else if (item.Level == 1)
      {
        @* Orphan Level 1 — no group assigned *@
        var hasChildren  = item.Children.Any();
        var itemActive   = IsActive(item.MenuUrl) || IsActiveByCode(item.MenuCode) || HasActiveChild(item);

        if (hasChildren)
        {
          <li class='menu-item@(itemActive ? " active open" : "")'>
            <a href="javascript:void(0);" class="menu-link menu-toggle">
              @if (!string.IsNullOrEmpty(item.MenuIcon))
              {
                <i class="menu-icon icon-base ri @item.MenuIcon"></i>
              }
              <div>@item.MenuName</div>
            </a>
            <ul class="menu-sub">
              @foreach (var child in item.Children.OrderBy(c => c.SortOrder))
              {
                var childHasChildren = child.Children.Any();
                var childActive      = IsActive(child.MenuUrl) || IsActiveByCode(child.MenuCode) || child.Children.Any(gc => IsActive(gc.MenuUrl) || IsActiveByCode(gc.MenuCode));
                if (childHasChildren)
                {
                  <li class='menu-item@(childActive ? " active open" : "")'>
                    <a href="javascript:void(0);" class="menu-link menu-toggle">
                      <div>@child.MenuName</div>
                    </a>
                    <ul class="menu-sub">
                      @foreach (var grandchild in child.Children.OrderBy(c => c.SortOrder))
                      {
                        <li class='menu-item@(IsActive(grandchild.MenuUrl) || IsActiveByCode(grandchild.MenuCode) ? " active" : "")'>
                          <a href="@grandchild.MenuUrl" class="menu-link">
                            <div>@grandchild.MenuName</div>
                          </a>
                        </li>
                      }
                    </ul>
                  </li>
                }
                else
                {
                  <li class='menu-item@(childActive ? " active" : "")'>
                    <a href="@child.MenuUrl" class="menu-link">
                      <div>@child.MenuName</div>
                    </a>
                  </li>
                }
              }
            </ul>
          </li>
        }
        else
        {
          <li class='menu-item@(itemActive ? " active" : "")'>
            <a href="@item.MenuUrl" class="menu-link">
              @if (!string.IsNullOrEmpty(item.MenuIcon))
              {
                <i class="menu-icon icon-base ri @item.MenuIcon"></i>
              }
              <div>@item.MenuName</div>
            </a>
          </li>
        }
      }
    }
  </ul>

</aside>
@* / Menu *@
