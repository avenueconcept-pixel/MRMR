@page
@model MyApp.Areas.Admin.Pages.CompanyBankAccounts.CreateModel
@{
  ViewData["title"] = await T.GetAsync("CompanyBankAccount.AddAccount");
}

@section VendorStyles {
  <link rel="stylesheet" href="~/vendor/libs/sweetalert2/sweetalert2.dist.css" />
}

<div class="d-flex justify-content-between align-items-center py-3 mb-4">
  <h4 class="mb-0">@await T.GetAsync("CompanyBankAccount.AddAccount")</h4>
  <a asp-area="Admin" asp-page="/CompanyBankAccounts/Index" class="btn btn-outline-secondary">
    <i class="ri ri-arrow-left-line me-1"></i> @await T.GetAsync("BackToList")
  </a>
</div>

<div class="card">
  <div class="card-body">
    <form method="post" asp-page-handler="Create">

      <div class="row g-4">
        <div class="col-md-6">
          <label class="form-label" for="ddlCountryCode">
            @await T.GetAsync("CompanyBankAccount.Country") <span class="text-danger">*</span>
          </label>
          <select asp-for="ddlCountryCode" class="form-select" asp-items="@Model.CountryOptions">
            <option value="">— @await T.GetAsync("SelectCountry") —</option>
          </select>
        </div>
        <div class="col-md-6">
          <label class="form-label" for="txtBankName">
            @await T.GetAsync("CompanyBankAccount.BankName") <span class="text-danger">*</span>
          </label>
          <div class="form-floating form-floating-outline">
            <input type="text" id="txtBankName" name="txtBankName" class="form-control"
                   maxlength="150" value="@Model.txtBankName"
                   placeholder="@await T.GetAsync("CompanyBankAccount.BankName")" />
            <label for="txtBankName">@await T.GetAsync("CompanyBankAccount.BankName")</label>
          </div>
        </div>
        <div class="col-md-6">
          <label class="form-label" for="txtAccountName">
            @await T.GetAsync("CompanyBankAccount.AccountName") <span class="text-danger">*</span>
          </label>
          <div class="form-floating form-floating-outline">
            <input type="text" id="txtAccountName" name="txtAccountName" class="form-control"
                   maxlength="150" value="@Model.txtAccountName"
                   placeholder="@await T.GetAsync("CompanyBankAccount.AccountName")" />
            <label for="txtAccountName">@await T.GetAsync("CompanyBankAccount.AccountName")</label>
          </div>
        </div>
        <div class="col-md-6">
          <label class="form-label" for="txtAccountNumber">
            @await T.GetAsync("CompanyBankAccount.AccountNumber") <span class="text-danger">*</span>
          </label>
          <div class="form-floating form-floating-outline">
            <input type="text" id="txtAccountNumber" name="txtAccountNumber" class="form-control"
                   maxlength="50" value="@Model.txtAccountNumber"
                   placeholder="@await T.GetAsync("CompanyBankAccount.AccountNumber")" />
            <label for="txtAccountNumber">@await T.GetAsync("CompanyBankAccount.AccountNumber")</label>
          </div>
        </div>
        <div class="col-md-6">
          <label class="form-label" for="txtBranch">@await T.GetAsync("CompanyBankAccount.Branch")</label>
          <div class="form-floating form-floating-outline">
            <input type="text" id="txtBranch" name="txtBranch" class="form-control"
                   maxlength="150" value="@Model.txtBranch"
                   placeholder="@await T.GetAsync("CompanyBankAccount.Branch")" />
            <label for="txtBranch">@await T.GetAsync("CompanyBankAccount.Branch")</label>
          </div>
        </div>
        <div class="col-md-6">
          <label class="form-label" for="txtCurrency">
            @await T.GetAsync("CompanyBankAccount.Currency") <span class="text-danger">*</span>
          </label>
          <div class="form-floating form-floating-outline">
            <input type="text" id="txtCurrency" name="txtCurrency" class="form-control"
                   maxlength="10" value="@Model.txtCurrency"
                   placeholder="@await T.GetAsync("CompanyBankAccount.Currency")" />
            <label for="txtCurrency">@await T.GetAsync("CompanyBankAccount.Currency")</label>
          </div>
        </div>
        <div class="col-md-6">
          <label class="form-label" for="ddlStatus">@await T.GetAsync("Status")</label>
          <select asp-for="ddlStatus" class="form-select" asp-items="@Model.StatusOptions"></select>
        </div>
        <div class="col-12">
          <label class="form-label" for="txtRemarks">@await T.GetAsync("CompanyBankAccount.Remarks")</label>
          <textarea id="txtRemarks" name="txtRemarks" class="form-control" rows="3"
                    maxlength="1000">@Model.txtRemarks</textarea>
        </div>
      </div>

      <div class="mt-4 d-flex gap-2">
        <button type="submit" class="btn btn-primary">@await T.GetAsync("Save")</button>
        <a asp-area="Admin" asp-page="/CompanyBankAccounts/Index" class="btn btn-outline-secondary">@await T.GetAsync("Cancel")</a>
      </div>

    </form>
  </div>
</div>

@section VendorScripts {
  <script src="~/vendor/libs/sweetalert2/sweetalert2.dist.js"></script>
}

@section PageScripts {
<script>
  document.getElementById('txtCurrency').addEventListener('input', function () {
    this.value = this.value.toUpperCase();
  });

  document.addEventListener("DOMContentLoaded", function () {
    var messageType = '@Model.AlertMessageType';
    if (messageType !== '') {
      Swal.fire({
        icon: messageType,
        title: @Html.Raw(Json.Serialize(Model.AlertMessageTitle)),
        text:  @Html.Raw(Json.Serialize(Model.AlertMessageContent))
      });
    }
  });
</script>
}
