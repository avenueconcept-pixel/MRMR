@page
@model MyApp.Areas.Admin.Pages.States.IndexModel
@{
  ViewData["title"] = await T.GetAsync("State.PageTitle");
}

@section VendorStyles {
  <link rel="stylesheet" href="~/vendor/libs/sweetalert2/sweetalert2.dist.css" />
}

@{
  var lblToggleTitle       = await T.GetAsync("ToggleStatusTitle");
  var lblToggleConfirm     = await T.GetAsync("ToggleStatusConfirm");
  var lblToggleYes         = await T.GetAsync("ToggleStatusYes");
  var lblCancel            = await T.GetAsync("Cancel");
  var lblToggleFailed      = await T.GetAsync("ToggleFailed");
  var lblToggleError       = await T.GetAsync("ToggleError");
  var lblEdit              = await T.GetAsync("Edit");
  var lblToggleStatus      = await T.GetAsync("ToggleStatus");
  var lblActiveStatus      = await T.GetAsync("status.active");
  var lblInactiveStatus    = await T.GetAsync("status.inactive");
  var lblSelectCountryFirst = await T.GetAsync("State.SelectCountryFirst");
  var lblNoStates          = await T.GetAsync("State.NoStates");
}

<div class="d-flex justify-content-between align-items-center py-3 mb-4">
  <h4 class="mb-0">@await T.GetAsync("State.PageTitle")</h4>
</div>

@* Country filter card *@
<div class="card mb-4">
  <div class="card-body">
    <div class="row g-3 align-items-end">
      <div class="col-md-4">
        <label class="form-label">@await T.GetAsync("Country")</label>
        <select id="ddlCountryFilter" class="form-select">
          <option value="">@await T.GetAsync("State.SelectCountry")</option>
          @foreach (var c in Model.CountryOptions)
          {
            <option value="@c.Value">@c.Text</option>
          }
        </select>
      </div>
      <div class="col-md-auto">
        <a id="btnAdd" href="#" class="btn btn-primary disabled">
          <i class="ri ri-add-line me-1"></i> @await T.GetAsync("State.AddState")
        </a>
      </div>
    </div>
  </div>
</div>

@* States table (initially empty) *@
<div class="card">
  <div class="card-header">
    <h5 class="mb-0">@await T.GetAsync("State.StateList")</h5>
  </div>
  <div class="card-body">
    <div class="table-responsive">
      <table id="tblStates" class="table table-hover align-middle">
        <thead>
          <tr>
            <th>@await T.GetAsync("SortOrder")</th>
            <th>@await T.GetAsync("StateCode")</th>
            <th>@await T.GetAsync("StateName")</th>
            <th>@await T.GetAsync("Status")</th>
            <th>@await T.GetAsync("UpdatedAt")</th>
            <th>@await T.GetAsync("Actions")</th>
          </tr>
        </thead>
        <tbody id="tblStatesBody">
          <tr><td colspan="6" class="text-center text-muted">@await T.GetAsync("State.SelectCountryFirst")</td></tr>
        </tbody>
      </table>
    </div>
  </div>
</div>

@* Hidden form supplies antiforgery token for AJAX calls *@
<form id="formAjax" method="post">
  @Html.AntiForgeryToken()
</form>

@section VendorScripts {
  <script src="~/vendor/libs/sweetalert2/sweetalert2.dist.js"></script>
}

@section PageScripts {
<script>
  var msgToggleTitle        = '@Html.Raw(lblToggleTitle)';
  var msgToggleConfirm      = '@Html.Raw(lblToggleConfirm)';
  var msgToggleYes          = '@Html.Raw(lblToggleYes)';
  var msgCancel             = '@Html.Raw(lblCancel)';
  var msgToggleFailed       = '@Html.Raw(lblToggleFailed)';
  var msgToggleError        = '@Html.Raw(lblToggleError)';
  var lblEdit               = '@Html.Raw(lblEdit)';
  var lblToggleStatus       = '@Html.Raw(lblToggleStatus)';
  var lblActiveStatus       = '@Html.Raw(lblActiveStatus)';
  var lblInactiveStatus     = '@Html.Raw(lblInactiveStatus)';
  var msgSelectCountryFirst = '@Html.Raw(lblSelectCountryFirst)';
  var msgNoStates           = '@Html.Raw(lblNoStates)';

  function getToken() {
    return $('#formAjax input[name="__RequestVerificationToken"]').val();
  }

  function toggleStatus(id) {
    Swal.fire({
      title: msgToggleTitle,
      text: msgToggleConfirm,
      icon: 'warning',
      showCancelButton: true,
      confirmButtonText: msgToggleYes,
      cancelButtonText: msgCancel
    }).then(function (result) {
      if (result.isConfirmed) {
        $.ajax({
          url: '?handler=ToggleStatus',
          type: 'POST',
          data: { id: id, __RequestVerificationToken: getToken() },
          success: function (data) {
            if (data.success) {
              $('#ddlCountryFilter').trigger('change');
            } else {
              Swal.fire({ icon: 'error', text: msgToggleFailed });
            }
          },
          error: function () {
            Swal.fire({ icon: 'error', text: msgToggleError });
          }
        });
      }
    });
  }

  function buildRows(states) {
    var html = '';
    $.each(states, function (i, state) {
      var badgeClass  = state.status === 'active' ? 'bg-success' : 'bg-danger';
      var statusLabel = state.status === 'active' ? lblActiveStatus : lblInactiveStatus;
      html += '<tr>';
      html += '<td>' + state.sortOrder + '</td>';
      html += '<td><strong>' + state.stateCode + '</strong></td>';
      html += '<td>' + state.stateName + '</td>';
      html += '<td><span class="badge ' + badgeClass + '">' + statusLabel + '</span></td>';
      html += '<td>' + state.updatedAt + '</td>';
      html += '<td>';
      html +=   '<div class="dropdown">';
      html +=     '<button type="button" class="btn btn-sm btn-outline-secondary dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false">';
      html +=       '<i class="ri ri-more-2-fill"></i>';
      html +=     '</button>';
      html +=     '<ul class="dropdown-menu dropdown-menu-end">';
      html +=       '<li><a class="dropdown-item" href="/Admin/States/Edit/' + state.id + '">';
      html +=         '<i class="ri ri-edit-line me-1"></i>' + lblEdit + '</a></li>';
      html +=       '<li><button class="dropdown-item" type="button" onclick="toggleStatus(' + state.id + ')">';
      html +=         '<i class="ri ri-toggle-line me-1"></i>' + lblToggleStatus + '</button></li>';
      html +=     '</ul>';
      html +=   '</div>';
      html += '</td>';
      html += '</tr>';
    });
    return html;
  }

  $('#ddlCountryFilter').on('change', function () {
    var countryCode = $(this).val();
    var tbody = $('#tblStatesBody');

    if (countryCode) {
      $('#btnAdd').attr('href', '/Admin/States/Create?countryCode=' + countryCode)
                 .removeClass('disabled');
    } else {
      $('#btnAdd').attr('href', '#').addClass('disabled');
    }

    if ($.fn.DataTable.isDataTable('#tblStates')) {
      $('#tblStates').DataTable().destroy();
    }

    if (!countryCode) {
      tbody.html('<tr><td colspan="6" class="text-center text-muted">' + msgSelectCountryFirst + '</td></tr>');
      return;
    }

    tbody.html('<tr><td colspan="6" class="text-center"><i class="ri ri-loader-4-line ri-spin"></i></td></tr>');

    $.ajax({
      url: '?handler=LoadStates',
      type: 'POST',
      data: { countryCode: countryCode, __RequestVerificationToken: getToken() },
      success: function (data) {
        if (data.success) {
          if (data.states.length === 0) {
            tbody.html('<tr><td colspan="6" class="text-center text-muted">' + msgNoStates + '</td></tr>');
            return;
          }
          tbody.html(buildRows(data.states));
          initDataTable('#tblStates', 5);
        }
      },
      error: function () {
        tbody.html('<tr><td colspan="6" class="text-center text-muted">' + msgToggleError + '</td></tr>');
      }
    });
  });

  document.addEventListener("DOMContentLoaded", function () {
    var messageType = '@Model.AlertMessageType';
    if (messageType !== '') {
      Swal.fire({
        icon: messageType,
        title: @Html.Raw(Json.Serialize(Model.AlertMessageTitle)),
        text: @Html.Raw(Json.Serialize(Model.AlertMessageContent))
      });
    }
  });
</script>
}
