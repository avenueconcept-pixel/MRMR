@page
@model MyApp.Areas.Admin.Pages.ResetPasswordModel
@{
	Layout = "Layouts/_BlankLayout";
	ViewData["Title"] = await T.GetAsync("ResetPassword");
}

@section VendorStyles {
	<link rel="stylesheet" href="~/vendor/libs/&#64;form-validation/form-validation.dist.css" />
	<link rel="stylesheet" href="~/vendor/libs/sweetalert2/sweetalert2.dist.css" />
}

@section VendorScripts {
	<script src="~/vendor/libs/&#64;form-validation/popular.dist.js"></script>
	<script src="~/vendor/libs/&#64;form-validation/bootstrap5.dist.js"></script>
	<script src="~/vendor/libs/&#64;form-validation/auto-focus.dist.js"></script>
	<script src="~/vendor/libs/sweetalert2/sweetalert2.dist.js"></script>
}

@section PageStyles {
	<link rel="stylesheet" href="~/vendor/css/pages/page-auth.dist.css">
}

@section PageScripts {
	<script src="~/js/pages-auth.dist.js"></script>
}

<div class="position-relative">
	<div class="authentication-wrapper authentication-basic container-p-y p-4 p-sm-0">
		<div class="authentication-inner py-6">

			<div class="card p-md-7 p-1">
				<!-- Logo -->
				<div class="app-brand justify-content-center mt-5">
					<a href="/" class="app-brand-link gap-2">
						<span class="app-brand-logo demo"><img src="~/img/LogoLogin.png" width="300px" /></span>
					</a>
				</div>
				<!-- /Logo -->

				<div class="card-body mt-1">
					<h4 class="mb-1">@await T.GetAsync("ResetPassword") 🔒</h4>
					<p class="mb-5">@await T.GetAsync("EnterNewPasswordBelow")</p>

					<form id="formResetPassword" class="mb-5" method="post">
						<input type="hidden" asp-for="Token" />

						<div class="mb-5">
							<div class="form-password-toggle">
								<div class="input-group input-group-merge">
									<div class="form-floating form-floating-outline">
										<input type="password" class="form-control" id="txtNewPassword" name="txtNewPassword" placeholder="&#xb7;&#xb7;&#xb7;&#xb7;&#xb7;&#xb7;&#xb7;&#xb7;&#xb7;&#xb7;&#xb7;&#xb7;" />
										<label for="txtNewPassword">@await T.GetAsync("NewPassword")</label>
									</div>
									<span class="input-group-text cursor-pointer"><i class="ri-eye-off-line"></i></span>
								</div>
							</div>
						</div>

						<div class="mb-5">
							<div class="form-password-toggle">
								<div class="input-group input-group-merge">
									<div class="form-floating form-floating-outline">
										<input type="password" class="form-control" id="txtConfirmPassword" name="txtConfirmPassword" placeholder="&#xb7;&#xb7;&#xb7;&#xb7;&#xb7;&#xb7;&#xb7;&#xb7;&#xb7;&#xb7;&#xb7;&#xb7;" />
										<label for="txtConfirmPassword">@await T.GetAsync("ConfirmPassword")</label>
									</div>
									<span class="input-group-text cursor-pointer"><i class="ri-eye-off-line"></i></span>
								</div>
							</div>
						</div>

						<button class="btn btn-primary d-grid w-100" type="submit">@await T.GetAsync("ResetPasswordButton")</button>
					</form>

					<div class="text-center">
						<a asp-area="Admin" asp-page="/Login" class="d-flex align-items-center justify-content-center">
							<i class="ri-arrow-left-s-line scaleX-n1-rtl ri-20px me-1_5"></i>
							@await T.GetAsync("BacktoLogin")
						</a>
					</div>
				</div>
			</div>

			<img alt="mask" src="~/img/illustrations/auth-basic-reset-password-mask-light.png" class="authentication-image d-none d-lg-block"
				data-app-light-img="illustrations/auth-basic-reset-password-mask-light.png"
				data-app-dark-img="illustrations/auth-basic-reset-password-mask-dark.png" />
		</div>
	</div>
</div>

<script>
	var msgEnterNewPassword = '@await T.GetAsync("EnterNewPassword")';
	var msgPasswordMismatch = '@await T.GetAsync("PasswordMismatch")';
	var msgError = '@MessageTitle.Error';

	document.getElementById('formResetPassword').addEventListener('submit', function (e) {
		var newPassword = document.getElementById('txtNewPassword').value.trim();
		var confirmPassword = document.getElementById('txtConfirmPassword').value.trim();

		if (newPassword === '') {
			e.preventDefault();
			Swal.fire({ icon: 'error', title: msgError, text: msgEnterNewPassword });
			return;
		}
		if (newPassword !== confirmPassword) {
			e.preventDefault();
			Swal.fire({ icon: 'error', title: msgError, text: msgPasswordMismatch });
			return;
		}
	});

	document.addEventListener("DOMContentLoaded", function () {
		var messageType = '@Model.AlertMessageType';

		if (messageType !== '') {
			Swal.fire({
				icon: messageType,
				title: @Html.Raw(Json.Serialize(Model.AlertMessageTitle)),
				text: @Html.Raw(Json.Serialize(Model.AlertMessageContent))
			});
		}
	});
</script>
