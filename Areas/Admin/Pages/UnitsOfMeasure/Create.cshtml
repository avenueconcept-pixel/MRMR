@page
@model MyApp.Areas.Admin.Pages.UnitsOfMeasure.CreateModel
@{
  ViewData["title"] = await T.GetAsync("UnitOfMeasure.AddTitle");
}

@section VendorStyles {
  <link rel="stylesheet" href="~/vendor/libs/sweetalert2/sweetalert2.dist.css" />
}

<div class="d-flex justify-content-between align-items-center py-3 mb-4">
  <h4 class="mb-0">@await T.GetAsync("UnitOfMeasure.AddTitle")</h4>
  <a asp-area="Admin" asp-page="/UnitsOfMeasure/Index" class="btn btn-outline-secondary">
    <i class="ri ri-arrow-left-line me-1"></i> @await T.GetAsync("BackToList")
  </a>
</div>

<div class="card">
  <div class="card-body">
    <form method="post" asp-page-handler="Create">

      <div class="row g-4">
        <div class="col-md-6">
          <label class="form-label" for="txtUomCode">
            @await T.GetAsync("UnitOfMeasure.UomCode") <span class="text-danger">*</span>
          </label>
          <input type="text" id="txtUomCode" name="txtUomCode" class="form-control"
                 maxlength="20" value="@Model.txtUomCode"
                 placeholder="@await T.GetAsync("UnitOfMeasure.UomCodePlaceholder")" />
          <div class="form-text">@await T.GetAsync("UnitOfMeasure.UomCodeHint")</div>
        </div>
        <div class="col-md-6">
          <label class="form-label" for="ddlStatus">@await T.GetAsync("Status")</label>
          <select asp-for="ddlStatus" class="form-select" asp-items="@Model.StatusOptions"></select>
        </div>
      </div>

      <hr class="my-4" />
      <h6 class="mb-3">@await T.GetAsync("UnitOfMeasure.NameTranslations")</h6>

      <div class="row g-4">
        @foreach (var lang in Model.TranslationInputs)
        {
          <div class="col-md-6">
            <label class="form-label" for="txtName_@lang.LanguageCode">@lang.Label</label>
            <input type="text" id="txtName_@lang.LanguageCode" name="txtName_@lang.LanguageCode"
                   class="form-control" value="@lang.Value" placeholder="@lang.Placeholder" />
          </div>
        }
      </div>

      <div class="mt-4 d-flex gap-2">
        <button type="submit" class="btn btn-primary">@await T.GetAsync("Save")</button>
        <a asp-area="Admin" asp-page="/UnitsOfMeasure/Index" class="btn btn-outline-secondary">@await T.GetAsync("Cancel")</a>
      </div>

    </form>
  </div>
</div>

@section VendorScripts {
  <script src="~/vendor/libs/sweetalert2/sweetalert2.dist.js"></script>
}

@section PageScripts {
<script>
  document.getElementById('txtUomCode').addEventListener('input', function () {
    this.value = this.value.toUpperCase();
  });

  document.addEventListener("DOMContentLoaded", function () {
    var messageType = '@Model.AlertMessageType';
    if (messageType !== '') {
      Swal.fire({
        icon: messageType,
        title: @Html.Raw(Json.Serialize(Model.AlertMessageTitle)),
        text: @Html.Raw(Json.Serialize(Model.AlertMessageContent))
      });
    }
  });
</script>
}
