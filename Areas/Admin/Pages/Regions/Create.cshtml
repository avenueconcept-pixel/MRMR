@page
@model MyApp.Areas.Admin.Pages.Regions.CreateModel
@{
  ViewData["title"] = await T.GetAsync("Region.AddTitle");
}

@section VendorStyles {
  <link rel="stylesheet" href="~/vendor/libs/sweetalert2/sweetalert2.dist.css" />
}

<div class="d-flex justify-content-between align-items-center py-3 mb-4">
  <h4 class="mb-0">@await T.GetAsync("Region.AddTitle")</h4>
  <a asp-area="Admin" asp-page="/Regions/Index" class="btn btn-outline-secondary">
    <i class="ri ri-arrow-left-line me-1"></i> @await T.GetAsync("BackToList")
  </a>
</div>

<div class="card">
  <div class="card-body">
    <form method="post" asp-page-handler="Create">

      <div class="row g-4">
        <div class="col-md-6">
          <label class="form-label" for="txtRegionCode">
            @await T.GetAsync("RegionCode") <span class="text-danger">*</span>
          </label>
          <input type="text" id="txtRegionCode" name="txtRegionCode"
                 class="form-control text-uppercase"
                 maxlength="50" value="@Model.txtRegionCode"
                 placeholder="@await T.GetAsync("Region.RegionCodeHint")" />
        </div>
        <div class="col-md-6">
          <label class="form-label" for="txtRegionName">
            @await T.GetAsync("RegionName") <span class="text-danger">*</span>
          </label>
          <input type="text" id="txtRegionName" name="txtRegionName"
                 class="form-control" maxlength="100" value="@Model.txtRegionName" />
        </div>
        <div class="col-md-6">
          <label class="form-label" for="ddlStatus">@await T.GetAsync("Status")</label>
          <select asp-for="ddlStatus" id="ddlStatus" class="form-select" asp-items="@Model.StatusOptions"></select>
        </div>
      </div>

      <hr class="my-4" />
      <h6 class="mb-3">@await T.GetAsync("Region.AssignCountries")</h6>

      <div class="row g-2">
        @foreach (var country in Model.AllCountries)
        {
          <div class="col-md-3">
            <div class="form-check">
              <input type="checkbox"
                     class="form-check-input"
                     name="SelectedCountries"
                     value="@country.CountryCode"
                     id="chk_@country.CountryCode"
                     @(Model.SelectedCountries.Contains(country.CountryCode) ? "checked" : "") />
              <label class="form-check-label" for="chk_@country.CountryCode">
                @country.Translations.FirstOrDefault()?.CountryName
                <small class="text-muted">(@country.CountryCode)</small>
              </label>
            </div>
          </div>
        }
      </div>

      <div class="mt-4 d-flex gap-2">
        <button type="submit" class="btn btn-primary">@await T.GetAsync("Save")</button>
        <a asp-area="Admin" asp-page="/Regions/Index" class="btn btn-outline-secondary">@await T.GetAsync("Cancel")</a>
      </div>

    </form>
  </div>
</div>

@section VendorScripts {
  <script src="~/vendor/libs/sweetalert2/sweetalert2.dist.js"></script>
}

@section PageScripts {
<script>
  document.getElementById('txtRegionCode').addEventListener('input', function () {
    this.value = this.value.toUpperCase();
  });

  document.addEventListener("DOMContentLoaded", function () {
    var messageType = '@Model.AlertMessageType';
    if (messageType !== '') {
      Swal.fire({
        icon: messageType,
        title: @Html.Raw(Json.Serialize(Model.AlertMessageTitle)),
        text: @Html.Raw(Json.Serialize(Model.AlertMessageContent))
      });
    }
  });
</script>
}
