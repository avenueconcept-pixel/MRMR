@page "{id:int}"
@model MyApp.Areas.Admin.Pages.Maintenances.EditModel
@{
  ViewData["title"] = await T.GetAsync("MaintenanceSchedule.Title");
}

@section VendorStyles {
  <link rel="stylesheet" href="~/vendor/libs/sweetalert2/sweetalert2.dist.css" />
  <link rel="stylesheet" href="~/vendor/libs/quill/editor.dist.css" />
}

<div class="d-flex justify-content-between align-items-center py-3 mb-4">
  <h4 class="mb-0">@await T.GetAsync("Edit") — @await T.GetAsync("Menu.Maintenances")</h4>
  <a asp-area="Admin" asp-page="/Maintenances/Index" class="btn btn-outline-secondary">
    <i class="ri ri-arrow-left-line me-1"></i>@await T.GetAsync("BackToList")
  </a>
</div>

<div class="card">
  <div class="card-body">
    <form method="post" asp-page-handler="Update" id="frmEdit">

      <div class="row g-4">
        <div class="col-12">
          <label class="form-label" for="txtTitle">
            @await T.GetAsync("Maintenance.ScheduleTitle") <span class="text-danger">*</span>
          </label>
          <input type="text" id="txtTitle" name="txtTitle" class="form-control"
                 maxlength="200" value="@Model.txtTitle" />
        </div>
        <div class="col-md-6">
          <label class="form-label" for="txtStartAt">
            @await T.GetAsync("Maintenance.StartAt") <span class="text-danger">*</span>
          </label>
          <input type="datetime-local" id="txtStartAt" name="txtStartAt" class="form-control"
                 value="@Model.txtStartAt" />
        </div>
        <div class="col-md-6">
          <label class="form-label" for="txtEndAt">
            @await T.GetAsync("Maintenance.EndAt") <span class="text-danger">*</span>
          </label>
          <input type="datetime-local" id="txtEndAt" name="txtEndAt" class="form-control"
                 value="@Model.txtEndAt" />
        </div>

        <div class="col-12">
          <label class="form-label">
            @await T.GetAsync("Maintenance.AffectedSystems") <span class="text-danger">*</span>
          </label>
          <div class="d-flex flex-wrap gap-3">
            @foreach (var sys in Model.Systems)
            {
              var isChecked = Model.SelectedSystems.Contains(sys.SystemCode);
              <div class="form-check">
                <input class="form-check-input" type="checkbox" name="chkSystems"
                       value="@sys.SystemCode" id="chk_@sys.SystemCode"
                       @(isChecked ? "checked" : "") />
                <label class="form-check-label" for="chk_@sys.SystemCode">@sys.SystemName</label>
              </div>
            }
          </div>
        </div>

        <div class="col-12">
          <label class="form-label">@await T.GetAsync("Maintenance.Message")</label>
          <small class="text-muted d-block mb-2">@await T.GetAsync("Maintenance.Message.Hint")</small>

          @if (Model.Languages.Count > 0)
          {
            <ul class="nav nav-tabs mb-3" id="msgTabs">
              @foreach (var lang in Model.Languages)
              {
                <li class="nav-item">
                  <a class="nav-link @(lang == Model.Languages.First() ? "active" : "")"
                     data-bs-toggle="tab" href="#tab_@lang.LanguageCode">
                    @lang.LanguageName
                  </a>
                </li>
              }
            </ul>
            <div class="tab-content">
              @foreach (var lang in Model.Languages)
              {
                var existing = Model.ExistingMessages.TryGetValue(lang.LanguageCode, out var msg) ? msg : string.Empty;
                <div class="tab-pane @(lang == Model.Languages.First() ? "active" : "")" id="tab_@lang.LanguageCode">
                  <input type="hidden" name="txtMessage_@lang.LanguageCode"
                         id="hdnMessage_@lang.LanguageCode" value="@existing" />
                  <div id="editor_@lang.LanguageCode" style="height:200px;"></div>
                </div>
              }
            </div>
          }
        </div>
      </div>

      <div class="mt-4 d-flex gap-2">
        <button type="submit" class="btn btn-primary">@await T.GetAsync("SaveChanges")</button>
        <a asp-area="Admin" asp-page="/Maintenances/Index" class="btn btn-outline-secondary">@await T.GetAsync("Cancel")</a>
        <a href="#" id="btnDelete" class="btn btn-outline-danger ms-auto" data-id="@Model.ScheduleId">
          <i class="ri ri-delete-bin-line me-1"></i>@Model.LabelDelete
        </a>
      </div>

    </form>

    <hr class="my-4" />
    <div class="row g-3">
      <div class="col-md-6">
        <label class="form-label text-muted small">@await T.GetAsync("CreatedBy")</label>
        <p class="mb-0">@Model.CreatedBy</p>
      </div>
      <div class="col-md-6">
        <label class="form-label text-muted small">@await T.GetAsync("CreatedAt")</label>
        <p class="mb-0">@Model.CreatedAt.ToUserLocalTime(Model.UserTimezone, AppConstants.DateTimeFormat)</p>
      </div>
      <div class="col-md-6">
        <label class="form-label text-muted small">@await T.GetAsync("UpdatedBy")</label>
        <p class="mb-0">@Model.UpdatedBy</p>
      </div>
      <div class="col-md-6">
        <label class="form-label text-muted small">@await T.GetAsync("UpdatedAt")</label>
        <p class="mb-0">@Model.UpdatedAt.ToUserLocalTime(Model.UserTimezone, AppConstants.DateTimeFormat)</p>
      </div>
    </div>
  </div>
</div>

<form id="formAjax" method="post">
  @Html.AntiForgeryToken()
</form>

@section VendorScripts {
  <script src="~/vendor/libs/sweetalert2/sweetalert2.dist.js"></script>
  <script src="~/vendor/libs/quill/quill.dist.js"></script>
}

@section PageScripts {
<script>
  var editors = {};

  @foreach (var lang in Model.Languages)
  {
    <text>
  editors['@lang.LanguageCode'] = new Quill('#editor_@lang.LanguageCode', { theme: 'snow' });
  var existing_@(lang.LanguageCode.Replace("-","_")) = document.getElementById('hdnMessage_@lang.LanguageCode').value;
  if (existing_@(lang.LanguageCode.Replace("-","_"))) {
    editors['@lang.LanguageCode'].clipboard.dangerouslyPasteHTML(existing_@(lang.LanguageCode.Replace("-","_")));
  }
    </text>
  }

  document.getElementById('frmEdit').addEventListener('submit', function () {
    @foreach (var lang in Model.Languages)
    {
      <text>
    document.getElementById('hdnMessage_@lang.LanguageCode').value =
        editors['@lang.LanguageCode'].root.innerHTML;
      </text>
    }
  });

  var pageMsg = {
    deleteConfirmTitle: '@Html.Raw(Model.MsgDeleteConfirmTitle)',
    deleteConfirmText:  '@Html.Raw(Model.MsgDeleteConfirmText)',
    deleteConfirmBtn:   '@Html.Raw(Model.MsgDeleteConfirmBtn)',
    cancelBtn:          '@Html.Raw(Model.MsgCancelBtn)',
    deleteSuccess:      '@Html.Raw(Model.MsgDeleteSuccess)',
    deleteError:        '@Html.Raw(Model.MsgDeleteError)'
  };

  document.getElementById('btnDelete').addEventListener('click', function (e) {
    e.preventDefault();
    var scheduleId = this.getAttribute('data-id');
    Swal.fire({
      title: pageMsg.deleteConfirmTitle, text: pageMsg.deleteConfirmText,
      icon: 'warning', showCancelButton: true,
      confirmButtonText: pageMsg.deleteConfirmBtn, cancelButtonText: pageMsg.cancelBtn,
      confirmButtonColor: '#dc3545'
    }).then(function (result) {
      if (result.isConfirmed) {
        $.post('?handler=SoftDelete&id=' + encodeURIComponent(scheduleId), {
          __RequestVerificationToken: $('#formAjax input[name="__RequestVerificationToken"]').val()
        }, function (data) {
          if (data.success) {
            Swal.fire({ icon: 'success', title: pageMsg.deleteSuccess, timer: 1500, showConfirmButton: false })
              .then(function () { window.location.href = '@Url.Page(Routes.AdminMaintenances)'; });
          } else {
            Swal.fire({ icon: 'error', text: data.message || pageMsg.deleteError });
          }
        }).fail(function () {
          Swal.fire({ icon: 'error', text: pageMsg.deleteError });
        });
      }
    });
  });

  document.addEventListener("DOMContentLoaded", function () {
    var messageType = '@Model.AlertMessageType';
    if (messageType !== '') {
      Swal.fire({
        icon: messageType,
        title: @Html.Raw(Json.Serialize(Model.AlertMessageTitle)),
        text: @Html.Raw(Json.Serialize(Model.AlertMessageContent))
      });
    }
  });
</script>
}
