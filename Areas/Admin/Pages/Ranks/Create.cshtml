@page
@model MyApp.Areas.Admin.Pages.Ranks.CreateModel
@{
  ViewData["title"] = await T.GetAsync("Rank.AddTitle");
}

@section VendorStyles {
  <link rel="stylesheet" href="~/vendor/libs/sweetalert2/sweetalert2.dist.css" />
}

<div class="d-flex justify-content-between align-items-center py-3 mb-4">
  <h4 class="mb-0">@await T.GetAsync("Rank.AddTitle")</h4>
  <a asp-area="Admin" asp-page="/Ranks/Index" class="btn btn-outline-secondary">
    <i class="ri ri-arrow-left-line me-1"></i> @await T.GetAsync("BackToList")
  </a>
</div>

<div class="card">
  <div class="card-body">
    <form method="post" asp-page-handler="Create">

      <div class="row g-4">
        <div class="col-md-6">
          <label class="form-label" for="txtRankCode">
            @await T.GetAsync("Rank.RankCode") <span class="text-danger">*</span>
          </label>
          <input type="text" id="txtRankCode" name="txtRankCode" class="form-control"
                 maxlength="20" value="@Model.txtRankCode"
                 placeholder="@await T.GetAsync("Rank.RankCodePlaceholder")" />
          <div class="form-text">@await T.GetAsync("Rank.RankCodeHint")</div>
        </div>
        <div class="col-md-6">
          <label class="form-label" for="txtRankName">
            @await T.GetAsync("Rank.RankName") <span class="text-danger">*</span>
          </label>
          <input type="text" id="txtRankName" name="txtRankName" class="form-control"
                 maxlength="100" value="@Model.txtRankName"
                 placeholder="@await T.GetAsync("Rank.RankNamePlaceholder")" />
        </div>
        <div class="col-md-6">
          <label class="form-label" for="txtSortOrder">@await T.GetAsync("Rank.SortOrder")</label>
          <input type="number" id="txtSortOrder" name="txtSortOrder" class="form-control"
                 value="@Model.txtSortOrder" min="0" />
        </div>
        <div class="col-md-6">
          <label class="form-label" for="ddlStatus">@await T.GetAsync("Status")</label>
          <select asp-for="ddlStatus" class="form-select" asp-items="@Model.StatusOptions"></select>
        </div>
      </div>

      <div class="mt-4 d-flex gap-2">
        <button type="submit" class="btn btn-primary">@await T.GetAsync("Save")</button>
        <a asp-area="Admin" asp-page="/Ranks/Index" class="btn btn-outline-secondary">@await T.GetAsync("Cancel")</a>
      </div>

    </form>
  </div>
</div>

@section VendorScripts {
  <script src="~/vendor/libs/sweetalert2/sweetalert2.dist.js"></script>
}

@section PageScripts {
<script>
  document.getElementById('txtRankCode').addEventListener('input', function () {
    this.value = this.value.toUpperCase();
  });

  document.addEventListener("DOMContentLoaded", function () {
    var messageType = '@Model.AlertMessageType';
    if (messageType !== '') {
      Swal.fire({
        icon: messageType,
        title: @Html.Raw(Json.Serialize(Model.AlertMessageTitle)),
        text: @Html.Raw(Json.Serialize(Model.AlertMessageContent))
      });
    }
  });
</script>
}
