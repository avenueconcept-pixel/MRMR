@page "{productCode}"
@model MyApp.Areas.Admin.Pages.Products.EditModel
@{
  ViewData["title"] = await T.GetAsync("Products.Edit.Title");
}

@section VendorStyles {
  <link rel="stylesheet" href="~/vendor/libs/sweetalert2/sweetalert2.dist.css" />
  <link rel="stylesheet" href="~/vendor/libs/select2/select2.dist.css" />
  <link rel="stylesheet" href="~/vendor/libs/quill/editor.dist.css" />
}

<div class="d-flex justify-content-between align-items-center py-3 mb-4">
  <div>
    <h4 class="mb-0">@await T.GetAsync("Products.Edit.Title") — <span class="text-muted">@Model.CurrentProductCode</span></h4>
    <small class="text-muted">@await T.GetAsync("Products.Edit.Subtitle")</small>
  </div>
  <a asp-area="Admin" asp-page="/Products/Index" class="btn btn-outline-secondary">
    <i class="ri ri-arrow-left-line me-1"></i>@await T.GetAsync("BackToList")
  </a>
</div>

<div class="card">
  <div class="card-body">
    <form method="post" asp-page-handler="Update" enctype="multipart/form-data">

      @* ── Basic Info ─────────────────────────────────── *@
      <div class="row g-4">
        <div class="col-md-4">
          <label class="form-label">@await T.GetAsync("Products.ProductCode")</label>
          <input type="text" class="form-control" value="@Model.CurrentProductCode" readonly />
        </div>
        <div class="col-md-4">
          <label class="form-label" for="ddlProductType">@await T.GetAsync("Products.ProductType")</label>
          <select asp-for="ddlProductType" asp-items="@Model.ProductTypeOptions" class="form-select"></select>
        </div>
        <div class="col-md-4">
          <label class="form-label" for="ddlProductNature">@await T.GetAsync("Products.ProductNature")</label>
          <select asp-for="ddlProductNature" asp-items="@Model.ProductNatureOptions" class="form-select"></select>
        </div>
        <div class="col-md-4">
          <label class="form-label" for="ddlUom">@await T.GetAsync("Products.Uom")</label>
          <select asp-for="ddlUom" asp-items="@Model.UomOptions" class="form-select"></select>
        </div>
        <div class="col-md-2">
          <label class="form-label" for="txtPv">@await T.GetAsync("Products.Pv")</label>
          <input type="number" id="txtPv" name="txtPv" class="form-control"
                 step="0.01" min="0" value="@Model.txtPv" />
        </div>
        <div class="col-md-2">
          <label class="form-label" for="txtSortOrder">@await T.GetAsync("Products.SortOrder")</label>
          <input type="number" id="txtSortOrder" name="txtSortOrder" class="form-control"
                 min="0" value="@Model.txtSortOrder" />
        </div>
        <div class="col-md-4">
          <label class="form-label" for="ddlStatus">@await T.GetAsync("Status")</label>
          <select asp-for="ddlStatus" asp-items="@Model.StatusOptions" class="form-select"></select>
        </div>
      </div>

      <hr class="my-4" />

      @* ── Translations ────────────────────────────────── *@
      <h6 class="mb-3">@await T.GetAsync("Products.Translations")</h6>
      @foreach (var lang in Model.TranslationInputs)
      {
        <div class="mb-4 p-3 border rounded">
          <h6 class="text-muted mb-3">@lang.LanguageName</h6>
          <div class="row g-3">
            <div class="col-md-6">
              <label class="form-label small" for="txtProductName_@lang.LanguageCode">
                @await T.GetAsync("Products.Tab.ProductName")
              </label>
              <input type="text" id="txtProductName_@lang.LanguageCode"
                     name="txtProductName_@lang.LanguageCode"
                     class="form-control" value="@lang.ProductName"
                     placeholder="@await T.GetAsync("Products.ProductName.Placeholder")" />
            </div>
            <div class="col-md-6">
              <label class="form-label small" for="txtShortDesc_@lang.LanguageCode">
                @await T.GetAsync("Products.Tab.ShortDescription")
              </label>
              <textarea id="txtShortDesc_@lang.LanguageCode"
                        name="txtShortDesc_@lang.LanguageCode"
                        class="form-control" rows="2"
                        placeholder="@await T.GetAsync("Products.ShortDescription.Placeholder")">@lang.ShortDescription</textarea>
            </div>
          </div>
        </div>
      }

      <hr class="my-4" />

      @* ── Categories ──────────────────────────────────── *@
      <div class="mb-4">
        <label class="form-label" for="ddlCategories">@await T.GetAsync("Products.Categories")</label>
        <select multiple id="ddlCategories" name="selectedCategories"
                class="form-select" asp-items="@Model.CategoriesSelectList">
        </select>
      </div>

      <hr class="my-4" />

      @* ── Country Availability ────────────────────────── *@
      <h6 class="mb-3">@await T.GetAsync("Products.CountryAvailability")</h6>
      @if (Model.CountrySelections.Count == 0)
      {
        <p class="text-muted small">@await T.GetAsync("Products.NoCountriesAvailable")</p>
      }
      else
      {
        <div class="row g-2">
          @foreach (var c in Model.CountrySelections)
          {
            <div class="col-md-4">
              <div class="d-flex align-items-center gap-3 p-2 border rounded">
                <div class="form-check mb-0 flex-shrink-0">
                  <input type="checkbox"
                         class="form-check-input country-check"
                         id="countryCheck_@c.CountryCode"
                         name="countryCheck_@c.CountryCode"
                         data-country="@c.CountryCode"
                         @(c.IsSelected ? "checked" : "") />
                  <label class="form-check-label" for="countryCheck_@c.CountryCode">
                    @c.CountryName
                  </label>
                </div>
                <div id="stockDiv_@c.CountryCode" class="flex-grow-1"
                     style="@(c.IsSelected ? "" : "display:none;")">
                  <select name="countryStock_@c.CountryCode" class="form-select form-select-sm">
                    @foreach (var opt in Model.StockStatusOptions)
                    {
                      if (c.StockStatus == opt.Value)
                      {
                        <option value="@opt.Value" selected>@opt.Text</option>
                      }
                      else
                      {
                        <option value="@opt.Value">@opt.Text</option>
                      }
                    }
                  </select>
                </div>
              </div>
            </div>
          }
        </div>
      }

      <div class="mt-4 d-flex gap-2">
        <button type="submit" class="btn btn-primary">@await T.GetAsync("SaveChanges")</button>
        <a asp-area="Admin" asp-page="/Products/Index" class="btn btn-outline-secondary">@await T.GetAsync("Cancel")</a>
        <a href="#" id="btnDelete" class="btn btn-outline-danger ms-auto"
           data-code="@Model.CurrentProductCode">
          <i class="ri ri-delete-bin-line me-1"></i>@Model.LabelDelete
        </a>
      </div>

    </form>

    <hr class="my-4" />
    <div class="row g-3">
      <div class="col-md-6">
        <label class="form-label text-muted small">@await T.GetAsync("CreatedBy")</label>
        <p class="mb-0">@Model.CreatedBy</p>
      </div>
      <div class="col-md-6">
        <label class="form-label text-muted small">@await T.GetAsync("CreatedAt")</label>
        <p class="mb-0">@Model.CreatedAt.ToUserLocalTime(Model.UserTimezone, AppConstants.DateTimeFormat)</p>
      </div>
      <div class="col-md-6">
        <label class="form-label text-muted small">@await T.GetAsync("UpdatedBy")</label>
        <p class="mb-0">@Model.UpdatedBy</p>
      </div>
      <div class="col-md-6">
        <label class="form-label text-muted small">@await T.GetAsync("UpdatedAt")</label>
        <p class="mb-0">@Model.UpdatedAt.ToUserLocalTime(Model.UserTimezone, AppConstants.DateTimeFormat)</p>
      </div>
    </div>
  </div>
</div>

@* ── Images card ─────────────────────────────────────────────────────── *@
<div class="card mt-4">
  <div class="card-header d-flex justify-content-between align-items-center">
    <h5 class="mb-0">@await T.GetAsync("Products.Images.Title")</h5>
    <small class="text-muted">@await T.GetAsync("Products.Images.DragHint")</small>
  </div>
  <div class="card-body">

    @* Upload form *@
    <form method="post" asp-page-handler="UploadImage"
          asp-route-productCode="@Model.CurrentProductCode"
          enctype="multipart/form-data">
      @Html.AntiForgeryToken()
      <div class="row g-3 align-items-end">
        <div class="col-md-3">
          <label class="form-label small">@await T.GetAsync("Products.CountryAvailability")</label>
          <select name="ddlImageCountry" class="form-select">
            <option value="">@await T.GetAsync("Products.Images.SelectCountry")</option>
            @foreach (var item in Model.ImageCountryList)
            {
              <option value="@item.Value">@item.Text</option>
            }
          </select>
        </div>
        <div class="col-md-3">
          <label class="form-label small">@await T.GetAsync("Products.Images.SelectLanguage")</label>
          <select name="ddlImageLanguage" class="form-select">
            <option value="">@await T.GetAsync("Products.Images.SelectLanguage")</option>
            @foreach (var item in Model.ImageLanguageList)
            {
              <option value="@item.Value">@item.Text</option>
            }
          </select>
        </div>
        <div class="col-md-4">
          <label class="form-label small">@await T.GetAsync("Products.Images.Upload")</label>
          <input type="file" name="fileProductImage" class="form-control"
                 accept=".jpg,.jpeg,.png"
                 data-crop="true"
                 data-crop-ratio="1"
                 data-crop-output-width="800"
                 data-crop-output-height="800"
                 data-crop-preview="#imgUploadPreview" />
          <img id="imgUploadPreview" src="" alt=""
               style="display:none;height:80px;width:80px;object-fit:cover;border-radius:6px;margin-top:8px;" />
        </div>
        <div class="col-md-2">
          <button type="submit" class="btn btn-primary w-100">
            <i class="ri ri-upload-line me-1"></i>@await T.GetAsync("Products.Images.Upload")
          </button>
        </div>
      </div>
    </form>

    @* Image grid *@
    @if (Model.ProductImages.Count == 0)
    {
      <p class="text-muted small mt-3">@await T.GetAsync("Products.Images.Subtitle")</p>
    }
    else
    {
      <div id="imageGrid" class="row g-3 mt-2">
        @foreach (var img in Model.ProductImages)
        {
          <div class="col-xl-2 col-lg-3 col-md-4 col-sm-6" data-id="@img.Id">
            <div class="card h-100 @(img.IsPrimary ? "border-primary border-2" : "")">
              <img src="/uploads/product/@img.ImageFilename"
                   class="card-img-top" style="height:120px;object-fit:cover;cursor:grab;" />
              <div class="card-body p-2 text-center">
                <small class="text-muted d-block">
                  @(img.Country?.Translations.FirstOrDefault()?.CountryName ?? img.CountryCode)
                  / @img.LanguageCode
                </small>
                @if (img.IsPrimary)
                {
                  <span class="badge bg-primary mt-1">@await T.GetAsync("Products.Images.Primary")</span>
                }
              </div>
              <div class="card-footer p-1 d-flex gap-1 justify-content-center">
                @if (!img.IsPrimary)
                {
                  <form method="post"
                        asp-page-handler="SetPrimaryImage"
                        asp-route-imageId="@img.Id"
                        asp-route-productCode="@Model.CurrentProductCode">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-sm btn-outline-primary"
                            title="@await T.GetAsync("Products.Images.SetPrimary")">
                      <i class="ri ri-star-line"></i>
                    </button>
                  </form>
                }
                <button type="button" class="btn btn-sm btn-outline-danger"
                        onclick="confirmDeleteImage(@img.Id, '@Html.Raw(Model.CurrentProductCode)')"
                        title="@await T.GetAsync("Btn.Delete")">
                  <i class="ri ri-delete-bin-line"></i>
                </button>
              </div>
            </div>
          </div>
        }
      </div>
    }

  </div>
</div>

@* ── Pricing card ─────────────────────────────────────────────────────── *@
<div class="card mt-4">
  <div class="card-header">
    <h5 class="mb-0">@await T.GetAsync("Products.Pricing.Title")</h5>
  </div>
  <div class="card-body">

    @* Add pricing row form *@
    <form method="post" asp-page-handler="AddPricing"
          asp-route-productCode="@Model.CurrentProductCode">
      @Html.AntiForgeryToken()
      <div class="row g-3 align-items-end mb-4">
        <div class="col-md-3">
          <label class="form-label small">@await T.GetAsync("Products.Pricing.Country")</label>
          <select name="ddlPricingCountry" class="form-select">
            @foreach (var item in Model.PricingCountryList)
            {
              <option value="@item.Value">@item.Text</option>
            }
          </select>
        </div>
        <div class="col-md-3">
          <label class="form-label small">@await T.GetAsync("Products.Pricing.Tier")</label>
          <select name="ddlPricingTier" class="form-select">
            @foreach (var item in Model.PricingTierList)
            {
              <option value="@item.Value">@item.Text</option>
            }
          </select>
        </div>
        <div class="col-md-2">
          <label class="form-label small">@await T.GetAsync("Products.Pricing.Variant")</label>
          <input type="text" name="txtPricingVariant" class="form-control"
                 placeholder="@await T.GetAsync("Products.Pricing.VariantPlaceholder")" />
        </div>
        <div class="col-md-2">
          <label class="form-label small">@await T.GetAsync("Products.Pricing.Price")</label>
          <input type="number" name="txtPricingPrice" class="form-control"
                 step="0.01" min="0.01" value="0" />
        </div>
        <div class="col-md-2">
          <button type="submit" class="btn btn-primary w-100">
            <i class="ri ri-add-line me-1"></i>@await T.GetAsync("Products.Pricing.AddBtn")
          </button>
        </div>
      </div>
    </form>

    @* Pricing table *@
    @if (Model.PricingRows.Count == 0)
    {
      <p class="text-muted small">@await T.GetAsync("Products.Pricing.Empty")</p>
    }
    else
    {
      <table class="table table-sm table-hover align-middle">
        <thead>
          <tr>
            <th>@await T.GetAsync("Products.Pricing.Country")</th>
            <th>@await T.GetAsync("Products.Pricing.Tier")</th>
            <th>@await T.GetAsync("Products.Pricing.Variant")</th>
            <th class="text-end">@await T.GetAsync("Products.Pricing.Price")</th>
            <th class="text-center" style="width:80px;">@await T.GetAsync("Actions")</th>
          </tr>
        </thead>
        <tbody>
          @foreach (var row in Model.PricingRows)
          {
            <tr>
              <td>@row.CountryName <small class="text-muted">(@row.CountryCode)</small></td>
              <td>@row.TierName</td>
              <td>@(string.IsNullOrEmpty(row.VariantCode) ? "—" : row.VariantCode)</td>
              <td class="text-end">@row.Price.ToString("N2")</td>
              <td class="text-center">
                <div class="dropdown">
                  <button type="button" class="btn btn-sm btn-outline-secondary dropdown-toggle"
                          data-bs-toggle="dropdown" aria-expanded="false">
                    <i class="ri ri-more-2-fill"></i>
                  </button>
                  <ul class="dropdown-menu dropdown-menu-end">
                    <li>
                      <button class="dropdown-item" type="button"
                              onclick="openEditPrice(@row.Id, @row.Price.ToString("F2", System.Globalization.CultureInfo.InvariantCulture))">
                        <i class="ri ri-edit-line me-1"></i>@await T.GetAsync("Edit")
                      </button>
                    </li>
                    <li>
                      <button class="dropdown-item text-danger" type="button"
                              onclick="confirmDeletePricing(@row.Id, '@Html.Raw(Model.CurrentProductCode)')">
                        <i class="ri ri-delete-bin-line me-1"></i>@await T.GetAsync("Btn.Delete")
                      </button>
                    </li>
                  </ul>
                </div>
              </td>
            </tr>
          }
        </tbody>
      </table>
    }

  </div>
</div>

@* ── Schedules card ───────────────────────────────────────────────────── *@
<div class="card mt-4">
  <div class="card-header">
    <h5 class="mb-0">@await T.GetAsync("Products.Schedule.Title")</h5>
  </div>
  <div class="card-body">

    @* Add schedule form *@
    <form method="post" asp-page-handler="AddPriceSchedule"
          asp-route-productCode="@Model.CurrentProductCode">
      @Html.AntiForgeryToken()
      <div class="row g-3 align-items-end mb-4">
        <div class="col-md-2">
          <label class="form-label small">@await T.GetAsync("Products.Pricing.Country")</label>
          <select name="ddlScheduleCountry" class="form-select">
            @foreach (var item in Model.PricingCountryList)
            {
              <option value="@item.Value">@item.Text</option>
            }
          </select>
        </div>
        <div class="col-md-2">
          <label class="form-label small">@await T.GetAsync("Products.Pricing.Tier")</label>
          <select name="ddlScheduleTier" class="form-select">
            @foreach (var item in Model.PricingTierList)
            {
              <option value="@item.Value">@item.Text</option>
            }
          </select>
        </div>
        <div class="col-md-2">
          <label class="form-label small">@await T.GetAsync("Products.Schedule.Type")</label>
          <select name="ddlScheduleType" class="form-select">
            @foreach (var item in Model.ScheduleTypeOptions)
            {
              <option value="@item.Value">@item.Text</option>
            }
          </select>
        </div>
        <div class="col-md-2">
          <label class="form-label small">@await T.GetAsync("Products.Schedule.ValidFrom")</label>
          <input type="datetime-local" name="txtValidFrom" class="form-control" />
        </div>
        <div class="col-md-2">
          <label class="form-label small">@await T.GetAsync("Products.Schedule.ValidTo")</label>
          <input type="datetime-local" name="txtValidTo" class="form-control" />
        </div>
        <div class="col-md-2">
          <button type="submit" class="btn btn-primary w-100">
            <i class="ri ri-add-line me-1"></i>@await T.GetAsync("Products.Schedule.AddBtn")
          </button>
        </div>
      </div>
    </form>

    @* Schedules table *@
    @if (Model.PriceSchedules.Count == 0)
    {
      <p class="text-muted small">@await T.GetAsync("Products.Schedule.Empty")</p>
    }
    else
    {
      <table class="table table-sm table-hover align-middle">
        <thead>
          <tr>
            <th>@await T.GetAsync("Products.Pricing.Country")</th>
            <th>@await T.GetAsync("Products.Pricing.Tier")</th>
            <th>@await T.GetAsync("Products.Schedule.Type")</th>
            <th>@await T.GetAsync("Products.Schedule.ValidFrom")</th>
            <th>@await T.GetAsync("Products.Schedule.ValidTo")</th>
            <th>@await T.GetAsync("Status")</th>
            <th class="text-center" style="width:80px;">@await T.GetAsync("Actions")</th>
          </tr>
        </thead>
        <tbody>
          @foreach (var sched in Model.PriceSchedules)
          {
            <tr>
              <td>@sched.CountryName <small class="text-muted">(@sched.CountryCode)</small></td>
              <td>@sched.TierName</td>
              <td>@sched.ScheduleType</td>
              <td>@sched.ValidFrom.ToUserLocalTime(Model.UserTimezone, AppConstants.DateTimeFormat)</td>
              <td>@(sched.ValidTo.HasValue ? sched.ValidTo.Value.ToUserLocalTime(Model.UserTimezone, AppConstants.DateTimeFormat) : "—")</td>
              <td>
                @{
                  var schedBadge = sched.Status switch
                  {
                    ScheduleStatusConstants.Pending   => "bg-warning text-dark",
                    ScheduleStatusConstants.Active    => "bg-success",
                    ScheduleStatusConstants.Processed => "bg-secondary",
                    ScheduleStatusConstants.Cancelled => "bg-danger",
                    _                                 => "bg-secondary"
                  };
                }
                <span class="badge @schedBadge">@sched.Status</span>
              </td>
              <td class="text-center">
                @if (sched.Status == ScheduleStatusConstants.Pending || sched.Status == ScheduleStatusConstants.Active)
                {
                  <form method="post" asp-page-handler="CancelSchedule"
                        asp-route-scheduleId="@sched.Id"
                        asp-route-productCode="@Model.CurrentProductCode"
                        style="display:inline;">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-sm btn-outline-danger"
                            title="@await T.GetAsync("Products.Schedule.Cancel")">
                      <i class="ri ri-close-line"></i>
                    </button>
                  </form>
                }
                else
                {
                  <span class="text-muted">—</span>
                }
              </td>
            </tr>
          }
        </tbody>
      </table>
    }

  </div>
</div>

@* ── Price History card ────────────────────────────────────────────────── *@
@{
  var histTotalPages = (int)Math.Ceiling((double)Model.PriceHistoryTotal / Model.PriceHistoryPageSize);
}
<div class="card mt-4">
  <div class="card-header d-flex align-items-center gap-2">
    <h5 class="mb-0">@await T.GetAsync("Products.History.Title")</h5>
    <span class="badge bg-secondary">@Model.PriceHistoryTotal</span>
  </div>
  <div class="card-body">

    @if (Model.PriceHistory.Count == 0)
    {
      <p class="text-muted small">@await T.GetAsync("Products.History.Empty")</p>
    }
    else
    {
      <table class="table table-sm table-hover align-middle">
        <thead>
          <tr>
            <th>@await T.GetAsync("Products.Pricing.Country")</th>
            <th>@await T.GetAsync("Products.Pricing.Tier")</th>
            <th>@await T.GetAsync("Products.History.ChangeType")</th>
            <th class="text-end">@await T.GetAsync("Products.History.From")</th>
            <th class="text-end">@await T.GetAsync("Products.History.To")</th>
            <th>@await T.GetAsync("ChangedBy")</th>
            <th>@await T.GetAsync("CreatedAt")</th>
          </tr>
        </thead>
        <tbody>
          @foreach (var hist in Model.PriceHistory)
          {
            <tr>
              <td>@hist.CountryCode</td>
              <td>@hist.TierCode</td>
              <td>@hist.ChangeType</td>
              <td class="text-end">@hist.ChangedFrom.ToString("N2")</td>
              <td class="text-end">@hist.ChangedTo.ToString("N2")</td>
              <td>@hist.ChangedBy</td>
              <td>@hist.CreatedAt.ToUserLocalTime(Model.UserTimezone, AppConstants.DateTimeFormat)</td>
            </tr>
          }
        </tbody>
      </table>

      @if (histTotalPages > 1)
      {
        <nav>
          <ul class="pagination pagination-sm justify-content-end mb-0">
            @for (int p = 1; p <= histTotalPages; p++)
            {
              <li class="page-item @(p == Model.PriceHistoryPage ? "active" : "")">
                <a class="page-link"
                   asp-page="/Products/Edit"
                   asp-route-productCode="@Model.CurrentProductCode"
                   asp-route-priceHistoryPage="@p">@p</a>
              </li>
            }
          </ul>
        </nav>
      }
    }

  </div>
</div>

@* ── Content Sections card ────────────────────────────────────────────── *@
<div class="card mt-4">
  <div class="card-header d-flex justify-content-between align-items-center">
    <h5 class="mb-0">@await T.GetAsync("Products.Sections.Title")</h5>
    <small class="text-muted">@await T.GetAsync("Products.Sections.DragHint")</small>
  </div>
  <div class="card-body">

    @* ── Add new section form ─────────────────────────────────────────── *@
    <form method="post" asp-page-handler="AddSection"
          asp-route-productCode="@Model.CurrentProductCode">
      @Html.AntiForgeryToken()
      <h6 class="mb-3">@await T.GetAsync("Products.Sections.AddSection")</h6>
      <div class="row g-3 mb-3">
        <div class="col-md-4">
          <select name="ddlSectionType" class="form-select"
                  asp-items="Model.SectionTypeOptions"></select>
        </div>
        <div class="col-md-2">
          <input type="number" name="txtSectionSort" class="form-control"
                 value="0" placeholder="@await T.GetAsync("Products.Sections.SortOrder")" />
        </div>
        <div class="col-md-6 d-flex align-items-end">
          <button type="submit" class="btn btn-outline-primary">
            <i class="ri ri-add-line me-1"></i>@await T.GetAsync("Products.Sections.AddSection")
          </button>
        </div>
      </div>
      @* Language tabs with Quill editors *@
      <ul class="nav nav-tabs mb-3" role="tablist">
        @foreach (var (inp, idx) in Model.SectionInputs.Select((x, i) => (x, i)))
        {
          <li class="nav-item" role="presentation">
            <button class="nav-link @(idx == 0 ? "active" : "")" type="button"
                    data-bs-toggle="tab"
                    data-bs-target="#sectionTab_@inp.LanguageCode"
                    role="tab">
              @inp.LanguageName
            </button>
          </li>
        }
      </ul>
      <div class="tab-content mb-3">
        @foreach (var (inp, idx) in Model.SectionInputs.Select((x, i) => (x, i)))
        {
          <div class="tab-pane fade @(idx == 0 ? "show active" : "")"
               id="sectionTab_@inp.LanguageCode" role="tabpanel">
            <input type="hidden"
                   name="txtSectionContent_@inp.LanguageCode"
                   id="hdnNewSection_@inp.LanguageCode"
                   value="@inp.Content" />
            <div id="editorNewSection_@inp.LanguageCode" style="height:200px;"></div>
          </div>
        }
      </div>
    </form>

    <hr class="my-4" />

    @* ── Existing sections — draggable cards ─────────────────────────── *@
    @if (Model.ProductSections.Count == 0)
    {
      <p class="text-muted small">@await T.GetAsync("Products.Sections.Subtitle")</p>
    }
    else
    {
      <div id="sectionList">
        @foreach (var sec in Model.ProductSections)
        {
          <div class="card mb-3 shadow-sm" data-id="@sec.Id">
            <div class="card-header d-flex align-items-center gap-2">
              <i class="ri ri-drag-move-line text-muted" style="cursor:grab;"></i>
              <strong>@sec.SectionName</strong>
              <span class="text-muted small ms-1">(@sec.SectionCode)</span>
              <div class="ms-auto d-flex gap-2">
                <button class="btn btn-sm btn-outline-secondary" type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#sectionEdit_@sec.Id"
                        aria-expanded="false">
                  <i class="ri ri-edit-line"></i>
                </button>
                <button class="btn btn-sm btn-outline-danger" type="button"
                        onclick="confirmDeleteSection(@sec.Id, '@Html.Raw(Model.CurrentProductCode)')">
                  <i class="ri ri-delete-bin-line"></i>
                </button>
              </div>
            </div>
            @* Collapsible edit form *@
            <div class="collapse" id="sectionEdit_@sec.Id">
              <div class="card-body">
                <form method="post" asp-page-handler="UpdateSection"
                      asp-route-productCode="@Model.CurrentProductCode">
                  @Html.AntiForgeryToken()
                  <input type="hidden" name="txtSectionId" value="@sec.Id" />
                  <div class="row g-3 mb-3">
                    <div class="col-md-4">
                      <label class="form-label small">@await T.GetAsync("Products.Sections.SelectType")</label>
                      <select name="ddlSectionType" class="form-select">
                        @foreach (var opt in Model.SectionTypeOptions)
                        {
                          if (opt.Value == sec.SectionCode)
                          {
                            <option value="@opt.Value" selected>@opt.Text</option>
                          }
                          else
                          {
                            <option value="@opt.Value">@opt.Text</option>
                          }
                        }
                      </select>
                    </div>
                    <div class="col-md-2">
                      <label class="form-label small">@await T.GetAsync("Products.Sections.SortOrder")</label>
                      <input type="number" name="txtSectionSort" class="form-control"
                             value="@sec.SortOrder" />
                    </div>
                  </div>
                  @* Language tabs with pre-filled Quill editors *@
                  <ul class="nav nav-tabs mb-3" role="tablist">
                    @foreach (var (t, idx) in sec.Translations.Select((x, i) => (x, i)))
                    {
                      <li class="nav-item" role="presentation">
                        <button class="nav-link @(idx == 0 ? "active" : "")" type="button"
                                data-bs-toggle="tab"
                                data-bs-target="#secEditTab_@(sec.Id)_@t.LanguageCode"
                                role="tab">
                          @t.LanguageCode
                        </button>
                      </li>
                    }
                  </ul>
                  <div class="tab-content mb-3">
                    @foreach (var (t, idx) in sec.Translations.Select((x, i) => (x, i)))
                    {
                      <div class="tab-pane fade @(idx == 0 ? "show active" : "")"
                           id="secEditTab_@(sec.Id)_@t.LanguageCode" role="tabpanel">
                        <input type="hidden"
                               name="txtSectionContent_@t.LanguageCode"
                               id="hdnEditSection_@(sec.Id)_@t.LanguageCode"
                               value="@t.Content" />
                        <div id="editorEditSection_@(sec.Id)_@t.LanguageCode"
                             style="height:200px;"></div>
                      </div>
                    }
                  </div>
                  <button type="submit" class="btn btn-primary">
                    @await T.GetAsync("SaveChanges")
                  </button>
                </form>
              </div>
            </div>
          </div>
        }
      </div>
    }

  </div>
</div>

@* Edit Price modal *@
<div class="modal fade" id="modalEditPrice" tabindex="-1">
  <div class="modal-dialog modal-sm">
    <div class="modal-content">
      <form method="post" asp-page-handler="UpdatePricing"
            asp-route-productCode="@Model.CurrentProductCode">
        @Html.AntiForgeryToken()
        <input type="hidden" name="txtUpdatePricingId" id="hdnUpdatePricingId" />
        <div class="modal-header">
          <h6 class="modal-title">@await T.GetAsync("Products.Pricing.EditPrice")</h6>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body">
          <label class="form-label small">@await T.GetAsync("Products.Pricing.Price")</label>
          <input type="number" name="txtUpdatePrice" id="txtUpdatePriceModal"
                 class="form-control" step="0.01" min="0" />
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-outline-secondary btn-sm"
                  data-bs-dismiss="modal">@await T.GetAsync("Btn.Cancel")</button>
          <button type="submit" class="btn btn-primary btn-sm">@await T.GetAsync("SaveChanges")</button>
        </div>
      </form>
    </div>
  </div>
</div>

@* Hidden form supplies antiforgery token for AJAX calls *@
<form id="formAjax" method="post">
  @Html.AntiForgeryToken()
</form>

@section VendorScripts {
  <script src="~/vendor/libs/sweetalert2/sweetalert2.dist.js"></script>
  <script src="~/vendor/libs/select2/select2.dist.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/Sortable/1.15.2/Sortable.min.js"></script>
  <script src="~/vendor/libs/quill/quill.dist.js"></script>
}

@section PageScripts {
<script>
  var pageMsg = {
    deleteConfirmTitle: '@Html.Raw(Model.MsgDeleteConfirmTitle)',
    deleteConfirmText:  '@Html.Raw(Model.MsgDeleteConfirmText)',
    deleteConfirmBtn:   '@Html.Raw(Model.MsgDeleteConfirmBtn)',
    cancelBtn:          '@Html.Raw(Model.MsgCancelBtn)',
    deleteSuccess:      '@Html.Raw(Model.MsgDeleteSuccess)',
    deleteError:        '@Html.Raw(Model.MsgDeleteError)'
  };

  $(document).ready(function () {
    $('#ddlCategories').select2({
      placeholder: '@await T.GetAsync("Products.Categories.Placeholder")',
      allowClear: true,
      width: '100%'
    });
  });

  document.querySelectorAll('.country-check').forEach(function (cb) {
    toggleCountryStock(cb);
    cb.addEventListener('change', function () { toggleCountryStock(this); });
  });

  function toggleCountryStock(checkbox) {
    var code     = checkbox.getAttribute('data-country');
    var stockDiv = document.getElementById('stockDiv_' + code);
    if (stockDiv) stockDiv.style.display = checkbox.checked ? '' : 'none';
  }

  document.getElementById('btnDelete').addEventListener('click', function (e) {
    e.preventDefault();
    var code = this.getAttribute('data-code');
    Swal.fire({
      title: pageMsg.deleteConfirmTitle,
      text: pageMsg.deleteConfirmText,
      icon: 'warning',
      showCancelButton: true,
      confirmButtonText: pageMsg.deleteConfirmBtn,
      cancelButtonText: pageMsg.cancelBtn,
      confirmButtonColor: '#dc3545'
    }).then(function (result) {
      if (result.isConfirmed) {
        $.post('?handler=SoftDelete&productCode=' + encodeURIComponent(code), {
          __RequestVerificationToken: $('#formAjax input[name="__RequestVerificationToken"]').val()
        }, function (data) {
          if (data.success) {
            Swal.fire({ icon: 'success', title: pageMsg.deleteSuccess, timer: 1500, showConfirmButton: false })
              .then(function () { window.location.href = '@Url.Page(Routes.AdminProducts)'; });
          } else {
            Swal.fire({ icon: 'error', text: data.message || pageMsg.deleteError });
          }
        }).fail(function () {
          Swal.fire({ icon: 'error', text: pageMsg.deleteError });
        });
      }
    });
  });

  @if (Model.ProductImages.Count > 0)
  {
    <text>
  var imageGrid = document.getElementById('imageGrid');
  if (imageGrid) {
    new Sortable(imageGrid, {
      animation: 150,
      onEnd: function () {
        var items = Array.from(imageGrid.querySelectorAll('[data-id]')).map(function (el, i) {
          return { id: parseInt(el.dataset.id), sortOrder: i };
        });
        fetch('?handler=SaveImageSort', {
          method:  'POST',
          headers: {
            'Content-Type':              'application/json',
            'RequestVerificationToken':  document.querySelector('#formAjax input[name="__RequestVerificationToken"]').value
          },
          body: JSON.stringify(items)
        });
      }
    });
  }
    </text>
  }

  async function confirmDeleteImage(imageId, productCode) {
    var result = await Swal.fire({
      icon: 'warning',
      title: pageMsg.deleteConfirmTitle,
      text:  pageMsg.deleteConfirmText,
      showCancelButton:   true,
      confirmButtonText:  pageMsg.deleteConfirmBtn,
      cancelButtonText:   pageMsg.cancelBtn,
      confirmButtonColor: '#dc3545'
    });
    if (!result.isConfirmed) return;
    var form  = document.createElement('form');
    form.method = 'post';
    form.action = '?handler=DeleteImage&imageId=' + imageId + '&productCode=' + encodeURIComponent(productCode);
    var token = document.createElement('input');
    token.type  = 'hidden';
    token.name  = '__RequestVerificationToken';
    token.value = document.querySelector('#formAjax input[name="__RequestVerificationToken"]').value;
    form.appendChild(token);
    document.body.appendChild(form);
    form.submit();
  }

  function openEditPrice(pricingId, currentPrice) {
    document.getElementById('hdnUpdatePricingId').value   = pricingId;
    document.getElementById('txtUpdatePriceModal').value  = currentPrice;
    new bootstrap.Modal(document.getElementById('modalEditPrice')).show();
  }

  async function confirmDeletePricing(pricingId, productCode) {
    var result = await Swal.fire({
      icon: 'warning',
      title: pageMsg.deleteConfirmTitle,
      text:  pageMsg.deleteConfirmText,
      showCancelButton:   true,
      confirmButtonText:  pageMsg.deleteConfirmBtn,
      cancelButtonText:   pageMsg.cancelBtn,
      confirmButtonColor: '#dc3545'
    });
    if (!result.isConfirmed) return;
    var form  = document.createElement('form');
    form.method = 'post';
    form.action = '?handler=DeletePricing&pricingId=' + pricingId + '&productCode=' + encodeURIComponent(productCode);
    var token = document.createElement('input');
    token.type  = 'hidden';
    token.name  = '__RequestVerificationToken';
    token.value = document.querySelector('#formAjax input[name="__RequestVerificationToken"]').value;
    form.appendChild(token);
    document.body.appendChild(form);
    form.submit();
  }

  // ── Section Quill editors ─────────────────────────────────────────────────
  var secEditors = {};

  @* Init editors for the Add-section form *@
  @foreach (var inp in Model.SectionInputs)
  {
    <text>
  secEditors['editorNewSection_@inp.LanguageCode'] = new Quill('#editorNewSection_@inp.LanguageCode', { theme: 'snow' });
    </text>
    if (!string.IsNullOrEmpty(inp.Content))
    {
      <text>
  secEditors['editorNewSection_@inp.LanguageCode'].clipboard.dangerouslyPasteHTML(@Html.Raw(Json.Serialize(inp.Content)));
      </text>
    }
  }

  @* Init editors for existing-section edit forms *@
  @foreach (var sec in Model.ProductSections)
  {
    foreach (var t in sec.Translations)
    {
      <text>
  secEditors['editorEditSection_@(sec.Id)_@t.LanguageCode'] = new Quill('#editorEditSection_@(sec.Id)_@t.LanguageCode', { theme: 'snow' });
  secEditors['editorEditSection_@(sec.Id)_@t.LanguageCode'].clipboard.dangerouslyPasteHTML(@Html.Raw(Json.Serialize(t.Content)));
      </text>
    }
  }

  @* Sync all editors to hidden inputs on their parent form's submit *@
  document.querySelectorAll('form').forEach(function (form) {
    form.addEventListener('submit', function () {
      Object.keys(secEditors).forEach(function (editorKey) {
        var hdnKey = editorKey.replace('editor', 'hdn');
        var hdn    = document.getElementById(hdnKey);
        if (hdn && form.contains(hdn)) {
          hdn.value = secEditors[editorKey].root.innerHTML;
        }
      });
    });
  });

  @* Section sort — drag to reorder *@
  var sectionList = document.getElementById('sectionList');
  if (sectionList) {
    new Sortable(sectionList, {
      animation: 150,
      handle:    '.ri-drag-move-line',
      onEnd: function () {
        var items = Array.from(sectionList.querySelectorAll('[data-id]')).map(function (el, i) {
          return { id: parseInt(el.dataset.id), sortOrder: i };
        });
        fetch('?handler=SaveSectionSort', {
          method:  'POST',
          headers: {
            'Content-Type':             'application/json',
            'RequestVerificationToken': document.querySelector('#formAjax input[name="__RequestVerificationToken"]').value
          },
          body: JSON.stringify(items)
        });
      }
    });
  }

  async function confirmDeleteSection(sectionId, productCode) {
    var result = await Swal.fire({
      icon: 'warning',
      title: pageMsg.deleteConfirmTitle,
      text:  pageMsg.deleteConfirmText,
      showCancelButton:   true,
      confirmButtonText:  pageMsg.deleteConfirmBtn,
      cancelButtonText:   pageMsg.cancelBtn,
      confirmButtonColor: '#dc3545'
    });
    if (!result.isConfirmed) return;
    var form  = document.createElement('form');
    form.method = 'post';
    form.action = '?handler=DeleteSection&sectionId=' + sectionId
                + '&productCode=' + encodeURIComponent(productCode);
    var token = document.createElement('input');
    token.type  = 'hidden';
    token.name  = '__RequestVerificationToken';
    token.value = document.querySelector('#formAjax input[name="__RequestVerificationToken"]').value;
    form.appendChild(token);
    document.body.appendChild(form);
    form.submit();
  }

  document.addEventListener("DOMContentLoaded", function () {
    var messageType = '@Model.AlertMessageType';
    if (messageType !== '') {
      Swal.fire({
        icon: messageType,
        title: @Html.Raw(Json.Serialize(Model.AlertMessageTitle)),
        text: @Html.Raw(Json.Serialize(Model.AlertMessageContent))
      });
    }
  });
</script>
}
