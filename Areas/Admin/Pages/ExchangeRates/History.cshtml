@page
@model MyApp.Areas.Admin.Pages.ExchangeRates.HistoryModel
@{
  ViewData["title"] = await T.GetAsync("ExchangeRates.Title.History");
}

<div class="d-flex justify-content-between align-items-center py-3 mb-4">
  <h4 class="mb-0">
    @await T.GetAsync("ExchangeRates.Title.History")
    @if (!string.IsNullOrEmpty(Model.FilterCurrency))
    {
      <span class="badge bg-primary ms-2">@Model.FilterCurrency</span>
    }
  </h4>
  <a asp-area="Admin" asp-page="/ExchangeRates/Index" class="btn btn-outline-secondary">
    <i class="ri ri-arrow-left-line me-1"></i>@await T.GetAsync("Btn.Back")
  </a>
</div>

@* ── Filters ── *@
<div class="card mb-4">
  <div class="card-body">
    <form method="get" asp-page="/ExchangeRates/History">
      <div class="row g-2 align-items-end">
        <div class="col-md-3">
          <label class="form-label">@await T.GetAsync("ExchangeRates.CurrencyCode")</label>
          <input type="text" asp-for="FilterCurrency" class="form-control text-uppercase"
                 placeholder="USD, MYR…" maxlength="10" />
        </div>
        <div class="col-auto">
          <button type="submit" class="btn btn-primary">
            <i class="ri ri-search-line me-1"></i>@await T.GetAsync("Btn.Search")
          </button>
          <a asp-area="Admin" asp-page="/ExchangeRates/History" class="btn btn-outline-secondary ms-1">
            @await T.GetAsync("Btn.Clear")
          </a>
        </div>
      </div>
    </form>
  </div>
</div>

<div class="card">
  <div class="card-body">
    <div class="table-responsive">
      <table class="table table-hover align-middle">
        <thead>
          <tr>
            <th>@await T.GetAsync("ExchangeRates.CurrencyCode")</th>
            <th>@await T.GetAsync("ExchangeRates.RateToBase")</th>
            <th>@await T.GetAsync("ExchangeRates.EffectiveDatetime")</th>
            <th>@await T.GetAsync("CreatedBy")</th>
            <th>@await T.GetAsync("CreatedAt")</th>
          </tr>
        </thead>
        <tbody>
          @foreach (var item in Model.Items)
          {
            <tr>
              <td><span class="badge bg-primary">@item.CurrencyCode</span></td>
              <td>@item.RateToBase.ToString("F6")</td>
              <td>@item.EffectiveDatetime.ToUserLocalTime(Model.UserTimezone, AppConstants.DateTimeFormat)</td>
              <td>@item.CreatedBy</td>
              <td>@item.CreatedAt.ToUserLocalTime(Model.UserTimezone, AppConstants.DateTimeFormat)</td>
            </tr>
          }
          @if (!Model.Items.Any())
          {
            <tr><td colspan="5" class="text-center text-muted py-4">—</td></tr>
          }
        </tbody>
      </table>
    </div>

    @* ── Pagination ── *@
    @if (Model.TotalPages > 1)
    {
      <nav class="mt-3">
        <ul class="pagination pagination-sm justify-content-center mb-0">
          @for (var p = 1; p <= Model.TotalPages; p++)
          {
            <li class="page-item @(p == Model.CurrentPage ? "active" : "")">
              <a class="page-link"
                 asp-area="Admin" asp-page="/ExchangeRates/History"
                 asp-route-currentPage="@p"
                 asp-route-filterCurrency="@Model.FilterCurrency">@p</a>
            </li>
          }
        </ul>
      </nav>
      <p class="text-muted small text-center mt-2">
        @await T.GetAsync("Pagination.Showing") @((Model.CurrentPage - 1) * Model.PageSize + 1)–@(Math.Min(Model.CurrentPage * Model.PageSize, Model.TotalCount)) @await T.GetAsync("Pagination.Of") @Model.TotalCount
      </p>
    }
  </div>
</div>
