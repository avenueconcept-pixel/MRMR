@page
@model MyApp.Areas.Admin.Pages.ExchangeRates.IndexModel
@{
  ViewData["title"] = await T.GetAsync("ExchangeRates.Title.Index");
}

@section VendorStyles {
  <link rel="stylesheet" href="~/vendor/libs/sweetalert2/sweetalert2.dist.css" />
}

<div class="d-flex justify-content-between align-items-center py-3 mb-4">
  <h4 class="mb-0">@await T.GetAsync("ExchangeRates.Title.Index")</h4>
  <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#modalAddRate">
    <i class="ri ri-add-line me-1"></i>@await T.GetAsync("Btn.AddNew")
  </button>
</div>

<div class="card">
  <div class="card-body">
    <div class="table-responsive">
      <table class="table table-hover align-middle">
        <thead>
          <tr>
            <th>@await T.GetAsync("ExchangeRates.CurrencyCode")</th>
            <th>@await T.GetAsync("ExchangeRates.RateToBase")</th>
            <th>@await T.GetAsync("ExchangeRates.EffectiveDatetime")</th>
            <th>@await T.GetAsync("CreatedBy")</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          @foreach (var item in Model.Items)
          {
            <tr>
              <td><span class="badge bg-primary">@item.CurrencyCode</span></td>
              <td>@item.RateToBase.ToString("F6")</td>
              <td>@item.EffectiveDatetime.ToUserLocalTime(Model.UserTimezone, AppConstants.DateTimeFormat)</td>
              <td>@item.CreatedBy</td>
              <td class="text-end">
                <button type="button" class="btn btn-sm btn-outline-secondary me-1"
                        onclick="openAddModal('@item.CurrencyCode')">
                  <i class="ri ri-add-line me-1"></i>@await T.GetAsync("Btn.AddRate")
                </button>
                <a asp-area="Admin" asp-page="/ExchangeRates/History"
                   asp-route-filterCurrency="@item.CurrencyCode"
                   class="btn btn-sm btn-outline-info">
                  <i class="ri ri-history-line me-1"></i>@await T.GetAsync("ExchangeRates.Title.History")
                </a>
              </td>
            </tr>
          }
          @if (!Model.Items.Any())
          {
            <tr><td colspan="5" class="text-center text-muted py-4">—</td></tr>
          }
        </tbody>
      </table>
    </div>
  </div>
</div>

@* ── Add Rate Modal ── *@
<div class="modal fade" id="modalAddRate" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">@await T.GetAsync("Btn.AddRate")</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <div class="mb-3">
          <label class="form-label">@await T.GetAsync("ExchangeRates.CurrencyCode")</label>
          <input type="text" id="modalCurrencyCode" class="form-control text-uppercase"
                 maxlength="10" placeholder="USD, MYR, SGD…" />
        </div>
        <div class="mb-3">
          <label class="form-label">@await T.GetAsync("ExchangeRates.RateToBase")</label>
          <input type="number" id="modalRateToBase" class="form-control"
                 step="0.000001" min="0" placeholder="1.000000" />
        </div>
        <div class="mb-3">
          <label class="form-label">@await T.GetAsync("ExchangeRates.EffectiveDatetime")</label>
          <input type="datetime-local" id="modalEffectiveDatetime" class="form-control" />
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">@await T.GetAsync("Btn.Cancel")</button>
        <button type="button" class="btn btn-primary" id="btnSaveRate">
          <i class="ri ri-save-line me-1"></i>@await T.GetAsync("Btn.Save")
        </button>
      </div>
    </div>
  </div>
</div>

@* Hidden antiforgery *@
<form id="formAjax" method="post">@Html.AntiForgeryToken()</form>

@section VendorScripts {
  <script src="~/vendor/libs/sweetalert2/sweetalert2.dist.js"></script>
}

@section PageScripts {
<script>
  var pageMsg = {
    saveSuccess: '@Html.Raw(Model.MsgSaveSuccess)',
    saveError:   '@Html.Raw(Model.MsgSaveError)'
  };
  var antiForgeryToken = $('#formAjax input[name="__RequestVerificationToken"]').val();

  function openAddModal(currencyCode) {
    document.getElementById('modalCurrencyCode').value = currencyCode || '';
    var modal = new bootstrap.Modal(document.getElementById('modalAddRate'));
    modal.show();
  }

  document.getElementById('btnSaveRate').addEventListener('click', function () {
    var currency  = document.getElementById('modalCurrencyCode').value.trim().toUpperCase();
    var rate      = document.getElementById('modalRateToBase').value;
    var effective = document.getElementById('modalEffectiveDatetime').value;

    if (!currency || !rate) {
      Swal.fire({ icon: 'warning', text: 'Currency code and rate are required.' });
      return;
    }

    $.post('?handler=Add', {
      txtCurrencyCode:     currency,
      txtRateToBase:       rate,
      txtEffectiveDatetime: effective,
      __RequestVerificationToken: antiForgeryToken
    }, function (res) {
      if (res.success) {
        Swal.fire({ icon: 'success', title: pageMsg.saveSuccess, timer: 1500, showConfirmButton: false })
          .then(function () { location.reload(); });
      } else {
        Swal.fire({ icon: 'error', text: res.message || pageMsg.saveError });
      }
    }).fail(function () {
      Swal.fire({ icon: 'error', text: pageMsg.saveError });
    });
  });
</script>
}
