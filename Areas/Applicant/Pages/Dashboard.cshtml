@page
@model MyApp.Areas.Applicant.Pages.DashboardModel
@{
    Layout = "Layouts/_PortalLayout";
    ViewData["Title"] = await T.GetAsync("Dashboard.Title");
}

<div class="row mt-4">
    <div class="col s12">
        <h5>@await T.GetAsync("Dashboard.Welcome"), @User.FindFirst(MyApp.Constants.CookieConstants.SessionKeys.FullName)?.Value!</h5>
    </div>
</div>

@if (Model.CurrentApplication != null)
{
    <div class="row">
        <div class="col s12 m6">
            <div class="card applicant-card">
                <div class="card-content">
                    <span class="card-title">@await T.GetAsync("Dashboard.ApplicationStatus")</span>
                    <p><strong>@await T.GetAsync("Dashboard.ApplicationId"):</strong> @Model.CurrentApplication.ApplicationId</p>
                    <p><strong>@await T.GetAsync("Dashboard.Category"):</strong> @Model.CurrentApplication.AwardCategory?.Name</p>
                    <p><strong>@await T.GetAsync("Dashboard.Status"):</strong>
                        <span class="badge-status blue lighten-4 blue-text">@Model.CurrentApplication.Status</span>
                    </p>
                </div>
            </div>
        </div>
    </div>
}
else
{
    <div class="card-panel blue lighten-5">
        <p>@await T.GetAsync("Dashboard.NoApplication")</p>
    </div>
}
