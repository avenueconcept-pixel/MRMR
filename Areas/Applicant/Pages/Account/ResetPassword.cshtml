@page
@model MyApp.Areas.Applicant.Pages.Account.ResetPasswordModel
@{
    Layout = "Layouts/_PublicLayout";
    ViewData["Title"] = await T.GetAsync("ResetPassword.Title");
}

<div class="card applicant-card">
    <div class="card-content">
        <span class="card-title">@await T.GetAsync("ResetPassword.Title")</span>

        @if (Model.TokenInvalid)
        {
            <div class="card-panel red lighten-4">
                <p>@await T.GetAsync("ResetPassword.TokenInvalid")</p>
                <a asp-area="Applicant" asp-page="/Account/ForgotPassword" class="btn-flat blue-text">
                    @await T.GetAsync("ResetPassword.RequestNewLink")
                </a>
            </div>
        }
        else if (Model.ResetSuccess)
        {
            <div class="card-panel green lighten-4">
                <p>@await T.GetAsync("ResetPassword.SuccessMessage")</p>
                <a asp-area="Applicant" asp-page="/Login" class="btn blue darken-3 mt-2">
                    @await T.GetAsync("ResetPassword.LoginNow")
                </a>
            </div>
        }
        else
        {
            @if (!string.IsNullOrEmpty(Model.AlertMessageContent))
            {
                <div class="card-panel red lighten-4"><span>@Model.AlertMessageContent</span></div>
            }

            <form method="post" asp-page-handler="Reset">
                @Html.AntiForgeryToken()
                <input type="hidden" name="Token" value="@Model.Token" />

                <div class="input-field">
                    <i class="ri ri-lock-password-line prefix"></i>
                    <input id="txtNewPassword" name="NewPassword" type="password" class="validate" minlength="8" required />
                    <label for="txtNewPassword">@await T.GetAsync("ResetPassword.NewPassword")</label>
                </div>

                <div class="input-field">
                    <i class="ri ri-lock-password-line prefix"></i>
                    <input id="txtConfirmPassword" name="ConfirmPassword" type="password" class="validate" minlength="8" required />
                    <label for="txtConfirmPassword">@await T.GetAsync("ResetPassword.ConfirmPassword")</label>
                </div>

                <button type="submit" class="btn blue darken-3 waves-effect waves-light" style="width:100%;">
                    @await T.GetAsync("ResetPassword.Submit")
                </button>
            </form>
        }
    </div>
</div>
