@page
@model MyApp.Areas.Applicant.Pages.Account.ChangePasswordModel
@{
    Layout = "Layouts/_PortalLayout";
    ViewData["Title"] = await T.GetAsync("ChangePassword.Title");
}

<div class="row mt-4">
    <div class="col s12 m6 offset-m3">
        <div class="card applicant-card">
            <div class="card-content">
                <span class="card-title">@await T.GetAsync("ChangePassword.Title")</span>

                @if (Model.IsFirstLogin)
                {
                    <div class="card-panel amber lighten-4 mb-3">
                        <i class="ri ri-information-line"></i>
                        @await T.GetAsync("ChangePassword.FirstLoginNotice")
                    </div>
                }

                @if (!string.IsNullOrEmpty(Model.AlertMessageContent))
                {
                    <div class="card-panel red lighten-4"><span>@Model.AlertMessageContent</span></div>
                }

                <form method="post" asp-page-handler="Change">
                    @Html.AntiForgeryToken()

                    <div class="input-field">
                        <i class="ri ri-lock-line prefix"></i>
                        <input id="txtCurrentPassword" name="CurrentPassword" type="password" class="validate" required />
                        <label for="txtCurrentPassword">@await T.GetAsync("ChangePassword.Current")</label>
                    </div>

                    <div class="input-field">
                        <i class="ri ri-lock-password-line prefix"></i>
                        <input id="txtNewPassword" name="NewPassword" type="password" class="validate" minlength="8" required />
                        <label for="txtNewPassword">@await T.GetAsync("ChangePassword.New")</label>
                    </div>

                    <div class="input-field">
                        <i class="ri ri-lock-password-line prefix"></i>
                        <input id="txtConfirmPassword" name="ConfirmPassword" type="password" class="validate" minlength="8" required />
                        <label for="txtConfirmPassword">@await T.GetAsync("ChangePassword.Confirm")</label>
                    </div>

                    <button type="submit" class="btn blue darken-3 waves-effect waves-light" style="width:100%;">
                        @await T.GetAsync("ChangePassword.Submit")
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
