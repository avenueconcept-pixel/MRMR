@page
@model MyApp.Areas.Applicant.Pages.Announcements.ListModel
@{
  ViewData["title"] = await T.GetAsync("Announcement.ListTitle");
  var relPath = "uploads/announcements";
}

<div class="py-3 mb-4">
  <h4 class="mb-0">@await T.GetAsync("Announcement.ListTitle")</h4>
</div>

@if (Model.Items.Count == 0)
{
  <div class="alert alert-info">@await T.GetAsync("Announcement.NoActive")</div>
}
else
{
  @foreach (var ann in Model.Items)
  {
    var trans = ann.Translations.FirstOrDefault();
    <div class="card mb-4">
      <div class="card-body">
        @if (!string.IsNullOrEmpty(trans?.Title))
        {
          <h5 class="card-title">@trans.Title</h5>
        }
        <p class="text-muted small mb-2">
          @ann.StartAt.ToUserLocalTime(Model.UserTimezone, AppConstants.DateTimeFormat)
          — @ann.EndAt.ToUserLocalTime(Model.UserTimezone, AppConstants.DateTimeFormat)
        </p>
        @if (!string.IsNullOrEmpty(trans?.Body))
        {
          <div class="mb-3">@Html.Raw(trans.Body)</div>
        }
        @if (ann.Attachments.Any())
        {
          <hr />
          <h6>@await T.GetAsync("Announcement.Attachments")</h6>
          <div class="d-flex flex-wrap gap-2">
            @foreach (var att in ann.Attachments)
            {
              @if (att.FileType == "image")
              {
                <a href="/@relPath/@att.FileName" target="_blank">
                  <img src="/@relPath/@att.FileName" alt="@att.OriginalName"
                       style="height:80px;object-fit:cover;border-radius:4px;" />
                </a>
              }
              else
              {
                <a href="/@relPath/@att.FileName" target="_blank" class="btn btn-sm btn-outline-danger">
                  <i class="ri ri-file-pdf-line me-1"></i>@att.OriginalName
                </a>
              }
            }
          </div>
        }
      </div>
    </div>
  }
}
