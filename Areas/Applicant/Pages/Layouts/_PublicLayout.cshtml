@{
    Layout = "Layouts/_MasterLayout";
}

<div class="authentication-wrapper authentication-basic container-p-y">
    <div class="authentication-inner py-4">
        <div class="card p-md-4 p-2" style="max-width: 760px; margin: 0 auto;">
            <div class="card-body">
                @* Logo *@
                <div class="text-center mb-4">
                    <img src="~/img/mrmr-logo.png" alt="MRMR2026" height="60"
                         onerror="this.style.display='none'" />
                    <h5 class="mt-2 mb-0">MRMR2026 RISE Platform</h5>
                </div>

                @RenderBody()
            </div>
        </div>
    </div>
</div>

@section VendorStyles {
    @RenderSection("VendorStyles", required: false)
}

@section PageStyles {
    @RenderSection("PageStyles", required: false)
}

@section VendorScripts {
    @RenderSection("VendorScripts", required: false)
}

@section PageScripts {
    @RenderSection("PageScripts", required: false)
}
