<!DOCTYPE html>
<html lang="en" data-bs-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no,
          minimum-scale=1.0, maximum-scale=1.0" />
    <title>@(ViewData["Title"] as string ?? "") | MRMR2026</title>

    <link rel="icon" type="image/x-icon" href="~/img/favicon/favicon.ico" />

    @* Google Fonts *@
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />

    @* Core Template CSS (Bootstrap 5 + template styles) *@
    <link rel="stylesheet" href="~/vendor/fonts/iconify-icons.dist.css" />
    <link rel="stylesheet" href="~/vendor/libs/node-waves/node-waves.dist.css" />
    <link rel="stylesheet" href="~/vendor/css/core.dist.css" />
    <link rel="stylesheet" href="~/css/demo.css" />

    @* Remix Icons — covered by iconify-icons.dist.css above, no separate file needed *@

    @* SweetAlert2 *@
    <link rel="stylesheet" href="~/vendor/libs/sweetalert2/sweetalert2.dist.css" />

    @* Auth page styles *@
    <link rel="stylesheet" href="~/vendor/css/pages/page-auth.dist.css" />

    @RenderSection("VendorStyles", required: false)
    @RenderSection("PageStyles", required: false)
</head>
<body>

    @RenderBody()

    @* Core JS *@
    <script src="~/vendor/libs/jquery/jquery.dist.js"></script>
    <script src="~/vendor/libs/popper/popper.dist.js"></script>
    <script src="~/vendor/js/bootstrap.dist.js"></script>
    <script src="~/vendor/libs/node-waves/node-waves.dist.js"></script>
    <script src="~/js/site.dist.js"></script>

    @* SweetAlert2 *@
    <script src="~/vendor/libs/sweetalert2/sweetalert2.dist.js"></script>

    @RenderSection("VendorScripts", required: false)
    @RenderSection("PageScripts", required: false)
</body>
</html>
