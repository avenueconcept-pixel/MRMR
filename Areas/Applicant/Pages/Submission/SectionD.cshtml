@page
@model MyApp.Areas.Applicant.Pages.Submission.SectionDModel
@{
    Layout = "Layouts/_SubmissionLayout";
    ViewData["Title"] = await T.GetAsync("Submission.SectionD.Title");
}

<div class="card applicant-card">
    <div class="card-content">
        <span class="card-title">@await T.GetAsync("Submission.SectionD.Title")</span>
        <p class="grey-text">@await T.GetAsync("Submission.SectionD.Desc")</p>
        <p class="grey-text caption">@await T.GetAsync("Submission.SectionD.WordLimit")</p>

        @if (!string.IsNullOrEmpty(Model.AlertMessageContent))
        {
            <div class="card-panel @(Model.AlertMessageType == "success" ? "green" : "red") lighten-4">
                @Model.AlertMessageContent
            </div>
        }

        <form method="post" id="sectionDForm">
            @Html.AntiForgeryToken()
            <input type="hidden" name="ApplicationId" value="@Model.ApplicationId" />

            @* Hidden input — Quill writes HTML here on submit *@
            <input type="hidden" id="PositioningStatement" name="PositioningStatement"
                   value="@Html.Raw(Model.PositioningStatement)" />

            @* Quill editor container *@
            <div id="quill-editor" style="min-height: 300px;">
                @Html.Raw(Model.PositioningStatement)
            </div>
            <p class="grey-text caption right-align mt-1">
                <span id="word-count">0</span> @await T.GetAsync("Submission.Words")
            </p>

            @if (Model.CurrentApplication?.IsFinalSubmitted != true)
            {
                <div class="row mt-3">
                    <div class="col s12 right-align">
                        <a asp-area="Applicant" asp-page="/Submission/SectionC"
                           asp-route-applicationId="@Model.ApplicationId"
                           class="btn-flat grey-text waves-effect mr-2">
                            <i class="ri ri-arrow-left-line me-1"></i>@await T.GetAsync("Submission.Back")
                        </a>
                        <button type="submit" asp-page-handler="SaveDraft"
                                class="btn-flat blue-text waves-effect mr-2">
                            <i class="ri ri-save-line me-1"></i>@await T.GetAsync("Submission.SaveDraft")
                        </button>
                        <button type="submit" asp-page-handler="SaveNext"
                                class="btn blue darken-3 waves-effect waves-light">
                            @await T.GetAsync("Submission.SaveNext") <i class="ri ri-arrow-right-line ms-1"></i>
                        </button>
                    </div>
                </div>
            }
        </form>
    </div>
</div>

@section VendorStyles {
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/quill/1.3.7/quill.snow.min.css" />
}

@section VendorScripts {
<script src="https://cdnjs.cloudflare.com/ajax/libs/quill/1.3.7/quill.min.js"></script>
}

@section PageScripts {
<script>
    var quill = new Quill('#quill-editor', {
        theme: 'snow',
        modules: {
            toolbar: [
                ['bold', 'italic', 'underline'],
                [{ 'list': 'ordered' }, { 'list': 'bullet' }],
                ['clean']
            ]
        }
    });

    @if (Model.CurrentApplication?.IsFinalSubmitted == true)
    {
        <text>quill.disable();</text>
    }

    function updateWordCount() {
        var text = quill.getText().trim();
        document.getElementById('word-count').textContent = text.length > 0 ? text.split(/\s+/).length : 0;
    }
    quill.on('text-change', updateWordCount);
    updateWordCount();

    document.getElementById('sectionDForm').addEventListener('submit', function () {
        document.getElementById('PositioningStatement').value = quill.root.innerHTML;
    });
</script>
}
