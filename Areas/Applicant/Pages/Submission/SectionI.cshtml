@page
@model MyApp.Areas.Applicant.Pages.Submission.SectionIModel
@{
    Layout = "Layouts/_SubmissionLayout";
    ViewData["Title"] = await T.GetAsync("Submission.SectionI.Title");
    bool locked = Model.CurrentApplication?.IsFinalSubmitted == true;
}

<div class="card applicant-card">
    <div class="card-content">
        <span class="card-title">@await T.GetAsync("Submission.SectionI.Title")</span>
        <p class="grey-text">@await T.GetAsync("Submission.SectionI.Desc")</p>
        <div class="card-panel blue lighten-5 caption">
            <i class="ri ri-information-line blue-text me-1"></i>
            @await T.GetAsync("Submission.SectionI.CorpOnly")
        </div>

        @if (!string.IsNullOrEmpty(Model.AlertMessageContent))
        {
            <div class="card-panel @(Model.AlertMessageType == "success" ? "green" : "red") lighten-4">
                @Model.AlertMessageContent
            </div>
        }

        <form method="post" id="sectionIForm">
            @Html.AntiForgeryToken()
            <input type="hidden" name="ApplicationId"     value="@Model.ApplicationId" />
            <input type="hidden" id="FinancialHighlights" name="FinancialHighlights" value="@Html.Raw(Model.FinancialHighlights)" />

            @* Revenue Table *@
            <h6 class="mt-3">@await T.GetAsync("Submission.SectionI.Revenue") (RM) <span class="red-text">*</span></h6>
            <table class="striped">
                <thead>
                    <tr>
                        <th>@await T.GetAsync("Submission.SectionI.Year")</th>
                        <th>@await T.GetAsync("Submission.SectionI.Amount") (RM)</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var (year, field, val) in new[] {
                        ("2023", "Revenue2023", Model.Revenue2023),
                        ("2024", "Revenue2024", Model.Revenue2024),
                        ("2025", "Revenue2025", Model.Revenue2025)
                    })
                    {
                        <tr>
                            <td>@year</td>
                            <td>
                                <div class="input-field my-0">
                                    <input type="number" name="@field" value="@val"
                                           min="0" step="1" placeholder="0" @(locked ? "disabled" : "") />
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            @* Net Profit Table *@
            <h6 class="mt-4">@await T.GetAsync("Submission.SectionI.NetProfit") (RM)</h6>
            <table class="striped">
                <thead>
                    <tr>
                        <th>@await T.GetAsync("Submission.SectionI.Year")</th>
                        <th>@await T.GetAsync("Submission.SectionI.Amount") (RM)</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var (year, field, val) in new[] {
                        ("2023", "NetProfit2023", Model.NetProfit2023),
                        ("2024", "NetProfit2024", Model.NetProfit2024),
                        ("2025", "NetProfit2025", Model.NetProfit2025)
                    })
                    {
                        <tr>
                            <td>@year</td>
                            <td>
                                <div class="input-field my-0">
                                    <input type="number" name="@field" value="@val"
                                           min="-999999999" step="1" placeholder="0" @(locked ? "disabled" : "") />
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            @* Employee Count + Export % *@
            <div class="row mt-4">
                <div class="input-field col s12 m4">
                    <input id="employeeCount" type="number" name="EmployeeCount"
                           value="@Model.EmployeeCount" min="1" step="1"
                           @(locked ? "disabled" : "") />
                    <label for="employeeCount" class="@(!string.IsNullOrEmpty(Model.EmployeeCount) ? "active" : "")">
                        @await T.GetAsync("Submission.SectionI.EmployeeCount")
                    </label>
                </div>
                <div class="input-field col s12 m4">
                    <input id="exportPct" type="number" name="ExportRevenuePct"
                           value="@Model.ExportRevenuePct" min="0" max="100" step="1"
                           @(locked ? "disabled" : "") />
                    <label for="exportPct" class="@(!string.IsNullOrEmpty(Model.ExportRevenuePct) ? "active" : "")">
                        @await T.GetAsync("Submission.SectionI.ExportPct") (%)
                    </label>
                </div>
            </div>

            @* Financial Highlights — rich text *@
            <h6 class="mt-3">@await T.GetAsync("Submission.SectionI.Highlights")</h6>
            <p class="grey-text caption">@await T.GetAsync("Submission.SectionI.HighlightsHint")</p>
            <div id="quill-highlights" style="min-height:180px;">@Html.Raw(Model.FinancialHighlights)</div>
            <p class="grey-text caption right-align"><span id="wc-highlights">0</span> @await T.GetAsync("Submission.Words")</p>

            @if (!locked)
            {
                <div class="row mt-4">
                    <div class="col s12 right-align">
                        <a asp-area="Applicant" asp-page="/Submission/SectionH"
                           asp-route-applicationId="@Model.ApplicationId"
                           class="btn-flat grey-text waves-effect mr-2">
                            <i class="ri ri-arrow-left-line me-1"></i>@await T.GetAsync("Submission.Back")
                        </a>
                        <button type="submit" asp-page-handler="SaveDraft" class="btn-flat blue-text waves-effect mr-2">
                            <i class="ri ri-save-line me-1"></i>@await T.GetAsync("Submission.SaveDraft")
                        </button>
                        <button type="submit" asp-page-handler="SaveNext" class="btn blue darken-3 waves-effect waves-light">
                            @await T.GetAsync("Submission.SaveNext") <i class="ri ri-arrow-right-line ms-1"></i>
                        </button>
                    </div>
                </div>
            }
        </form>
    </div>
</div>

@section VendorStyles {
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/quill/1.3.7/quill.snow.min.css" />
}
@section VendorScripts {
<script src="https://cdnjs.cloudflare.com/ajax/libs/quill/1.3.7/quill.min.js"></script>
}
@section PageScripts {
<script>
    var locked = @(locked ? "true" : "false");
    var qHighlights = new Quill('#quill-highlights', {
        theme: 'snow',
        modules: { toolbar: locked ? false : [['bold','italic','underline'],[{'list':'ordered'},{'list':'bullet'}],['clean']] },
        readOnly: locked
    });
    function wc() {
        var t = qHighlights.getText().trim();
        document.getElementById('wc-highlights').textContent = t.length > 0 ? t.split(/\s+/).length : 0;
    }
    qHighlights.on('text-change', wc); wc();

    document.getElementById('sectionIForm').addEventListener('submit', function () {
        document.getElementById('FinancialHighlights').value = qHighlights.root.innerHTML;
    });
</script>
}
