@page
@model MyApp.Areas.Applicant.Pages.Submission.SectionFModel
@{
    Layout = "Layouts/_SubmissionLayout";
    ViewData["Title"] = await T.GetAsync("Submission.SectionF.Title");
    bool locked = Model.CurrentApplication?.IsFinalSubmitted == true;
}

<div class="card applicant-card">
    <div class="card-content">
        <span class="card-title">@await T.GetAsync("Submission.SectionF.Title")</span>
        <p class="grey-text">@await T.GetAsync("Submission.SectionF.Desc")</p>

        @if (!string.IsNullOrEmpty(Model.AlertMessageContent))
        {
            <div class="card-panel @(Model.AlertMessageType == "success" ? "green" : "red") lighten-4">
                @Model.AlertMessageContent
            </div>
        }

        <form method="post" id="sectionFForm">
            @Html.AntiForgeryToken()
            <input type="hidden" name="ApplicationId" value="@Model.ApplicationId" />
            <input type="hidden" id="BusinessImpact" name="BusinessImpact" value="@Html.Raw(Model.BusinessImpact)" />
            <input type="hidden" id="IndustryImpact" name="IndustryImpact" value="@Html.Raw(Model.IndustryImpact)" />

            <h6 class="mt-3">@await T.GetAsync("Submission.SectionF.BusinessImpact") <span class="red-text">*</span></h6>
            <p class="grey-text caption">@await T.GetAsync("Submission.SectionF.BusinessImpactHint")</p>
            <div id="quill-business" style="min-height:200px;">@Html.Raw(Model.BusinessImpact)</div>
            <p class="grey-text caption right-align"><span id="wc-business">0</span> @await T.GetAsync("Submission.Words")</p>

            <h6 class="mt-4">@await T.GetAsync("Submission.SectionF.IndustryImpact") <span class="red-text">*</span></h6>
            <p class="grey-text caption">@await T.GetAsync("Submission.SectionF.IndustryImpactHint")</p>
            <div id="quill-industry" style="min-height:200px;">@Html.Raw(Model.IndustryImpact)</div>
            <p class="grey-text caption right-align"><span id="wc-industry">0</span> @await T.GetAsync("Submission.Words")</p>

            @if (!locked)
            {
                <div class="row mt-4">
                    <div class="col s12 right-align">
                        <a asp-area="Applicant" asp-page="/Submission/SectionE"
                           asp-route-applicationId="@Model.ApplicationId"
                           class="btn-flat grey-text waves-effect mr-2">
                            <i class="ri ri-arrow-left-line me-1"></i>@await T.GetAsync("Submission.Back")
                        </a>
                        <button type="submit" asp-page-handler="SaveDraft"
                                class="btn-flat blue-text waves-effect mr-2">
                            <i class="ri ri-save-line me-1"></i>@await T.GetAsync("Submission.SaveDraft")
                        </button>
                        <button type="submit" asp-page-handler="SaveNext"
                                class="btn blue darken-3 waves-effect waves-light">
                            @await T.GetAsync("Submission.SaveNext") <i class="ri ri-arrow-right-line ms-1"></i>
                        </button>
                    </div>
                </div>
            }
        </form>
    </div>
</div>

@section VendorStyles {
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/quill/1.3.7/quill.snow.min.css" />
}
@section VendorScripts {
<script src="https://cdnjs.cloudflare.com/ajax/libs/quill/1.3.7/quill.min.js"></script>
}
@section PageScripts {
<script>
    var toolbarOptions = [['bold','italic','underline'],[{'list':'ordered'},{'list':'bullet'}],['clean']];
    var locked = @(locked ? "true" : "false");

    function makeQuill(id, wcId) {
        var q = new Quill('#' + id, {
            theme: 'snow',
            modules: { toolbar: locked ? false : { container: toolbarOptions } },
            readOnly: locked
        });
        function wc() {
            var t = q.getText().trim();
            document.getElementById(wcId).textContent = t.length > 0 ? t.split(/\s+/).length : 0;
        }
        q.on('text-change', wc); wc();
        return q;
    }

    var qBusiness = makeQuill('quill-business', 'wc-business');
    var qIndustry = makeQuill('quill-industry', 'wc-industry');

    document.getElementById('sectionFForm').addEventListener('submit', function () {
        document.getElementById('BusinessImpact').value = qBusiness.root.innerHTML;
        document.getElementById('IndustryImpact').value = qIndustry.root.innerHTML;
    });
</script>
}
