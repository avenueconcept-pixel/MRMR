@page
@model MyApp.Areas.Applicant.Pages.LoginModel
@{
    Layout = "Layouts/_PublicLayout";
    ViewData["Title"] = await T.GetAsync("Login.Title");
}

<div class="card applicant-card">
    <div class="card-content">
        <span class="card-title center-align">@await T.GetAsync("Login.Title")</span>

        @if (!string.IsNullOrEmpty(Model.AlertMessageContent))
        {
            <div class="card-panel @(Model.AlertMessageType == "error" ? "red" : "green") lighten-4">
                <span>@Model.AlertMessageContent</span>
            </div>
        }

        <form method="post" asp-page-handler="Login">
            @Html.AntiForgeryToken()

            <div class="input-field">
                <i class="ri ri-user-line prefix"></i>
                <input id="txtUsername" name="Username" type="text" class="validate" value="@Model.Username" required />
                <label for="txtUsername">@await T.GetAsync("Login.Username")</label>
            </div>

            <div class="input-field">
                <i class="ri ri-lock-line prefix"></i>
                <input id="txtPassword" name="Password" type="password" class="validate" required />
                <label for="txtPassword">@await T.GetAsync("Login.Password")</label>
            </div>

            <div class="right-align mb-2">
                <a asp-area="Applicant" asp-page="/Account/ForgotPassword" class="blue-text">
                    @await T.GetAsync("Login.ForgotPassword")
                </a>
            </div>

            <button type="submit" class="btn blue darken-3 waves-effect waves-light" style="width:100%;">
                @await T.GetAsync("Login.Submit")
            </button>
        </form>

        <div class="center-align mt-3">
            <a asp-area="Applicant" asp-page="/Register" class="blue-text">
                @await T.GetAsync("Login.RegisterLink")
            </a>
        </div>
    </div>
</div>
