@page
@model MyApp.Areas.Applicant.Pages.LoginModel
@{
    Layout = "Layouts/_PublicLayout";
    ViewData["Title"] = await T.GetAsync("Login.Title");
}

<h5 class="card-title text-center mb-3">@await T.GetAsync("Login.Title")</h5>

@if (!string.IsNullOrEmpty(Model.AlertMessageContent))
{
    <div class="alert @(Model.AlertMessageType == "error" ? "alert-danger" : "alert-success") d-flex align-items-center gap-2 mb-3">
        <i class="ri ri-error-warning-line"></i>
        @Model.AlertMessageContent
    </div>
}

<form method="post" asp-page-handler="Login">
    @Html.AntiForgeryToken()

    <div class="mb-3">
        <label class="form-label" for="txtUsername">@await T.GetAsync("Login.Username")</label>
        <div class="input-group">
            <span class="input-group-text"><i class="ri ri-user-line"></i></span>
            <input id="txtUsername" name="Username" type="text" class="form-control" value="@Model.Username" required />
        </div>
    </div>

    <div class="mb-3">
        <label class="form-label" for="txtPassword">@await T.GetAsync("Login.Password")</label>
        <div class="input-group">
            <span class="input-group-text"><i class="ri ri-lock-line"></i></span>
            <input id="txtPassword" name="Password" type="password" class="form-control" required />
            <button class="btn btn-outline-secondary" type="button" id="btnTogglePwd" tabindex="-1">
                <i id="iconTogglePwd" class="ri ri-eye-off-line"></i>
            </button>
        </div>
    </div>

    <div class="text-end mb-3">
        <a asp-area="Applicant" asp-page="/Account/ForgotPassword" class="text-primary">
            @await T.GetAsync("Login.ForgotPassword")
        </a>
    </div>

    <button type="submit" class="btn btn-primary waves-effect waves-light w-100">
        @await T.GetAsync("Login.Submit")
    </button>
</form>

<div class="text-center mt-3">
    <a asp-area="Applicant" asp-page="/Register" class="text-primary">
        @await T.GetAsync("Login.RegisterLink")
    </a>
</div>

@section PageScripts {
<script>
    $('#btnTogglePwd').on('click', function () {
        var $pwd = $('#txtPassword');
        var isPassword = $pwd.attr('type') === 'password';
        $pwd.attr('type', isPassword ? 'text' : 'password');
        $('#iconTogglePwd').toggleClass('ri-eye-off-line', !isPassword).toggleClass('ri-eye-line', isPassword);
    });
</script>
}
